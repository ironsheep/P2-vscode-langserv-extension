' ═══════════════════════════════════════════════════════════════════════════════
' CONDITIONAL COMPILATION - Optional Feature Modules
' ═══════════════════════════════════════════════════════════════════════════════
' Default: MINIMAL driver (core file operations only)
' To enable optional features, use #pragma exportdef in your top-level file:
'
'   #pragma exportdef SD_INCLUDE_RAW        ' Raw sector access
'   #pragma exportdef SD_INCLUDE_REGISTERS  ' Card register access (CID/CSD/SCR)
'   #pragma exportdef SD_INCLUDE_SPEED      ' High-speed mode control (requires SD_INCLUDE_REGISTERS)
'   #pragma exportdef SD_INCLUDE_DEBUG      ' Debug/diagnostic methods & CRC getters
'   #pragma exportdef SD_INCLUDE_DEFRAG     ' Defragmentation: fileFragments, compactFile, createFileContiguous
'
'   OBJ
'       sd : "micro_sd_fat32_fs"
'
' Or define SD_INCLUDE_ALL to include everything:
'   #pragma exportdef SD_INCLUDE_ALL
' ═══════════════════════════════════════════════════════════════════════════════

#ifdef SD_INCLUDE_ALL
#ifndef SD_INCLUDE_RAW
#define SD_INCLUDE_RAW
#endif
#ifndef SD_INCLUDE_REGISTERS
#define SD_INCLUDE_REGISTERS
#endif
#ifndef SD_INCLUDE_SPEED
#define SD_INCLUDE_SPEED
#endif
#ifndef SD_INCLUDE_DEBUG
#define SD_INCLUDE_DEBUG
#endif
#ifndef SD_INCLUDE_DEFRAG
#define SD_INCLUDE_DEFRAG
#endif
#endif

#ifdef SD_INCLUDE_STACK_CHECK
OBJ
    stackUtils : "isp_stack_check"
#endif

CON  ' flags
  F_NEWDIR  = decod 1
  F_MOUNTED = decod 3

CON ' debug channel assignments for selective debug output
  ' All debug() uses debug[CH_xxx]() — DEBUG_MASK controls which channels compile.
  ' Set DEBUG_MASK = 0 for production (no debug code compiled).
  ' Enable 2-3 channels at a time to stay under the 255-record compiler limit.
  CH_INIT    = 0              ' Card initialization, pin setup, speed config
  CH_MOUNT   = 1              ' Mount/unmount, filesystem geometry, FSInfo
  CH_FILE    = 2              ' File handle operations: open, close, read, write, seek, sync
  CH_DIR     = 3              ' Directory operations: search, create, rename, move
  CH_SECTOR  = 4              ' Sector I/O, FAT chain walking, cluster allocation
  CH_STATUS  = 5              ' CMD13/CMD23 probe and runtime status checks
  CH_IDENT   = 6              ' Card identity: CID/CSD/SCR parsing, timeouts
  CH_HSPEED  = 7              ' High-speed mode: CMD6 query, switch, verification
  CH_API     = 8              ' Public API entry points, worker cog, stack guard
  CH_RECOVER = 9              ' Error recovery: CMD12, bus recovery, wait timeouts

  ' To debug, set DEBUG_MASK to enable channels you need:
  '   DEBUG_MASK = (1 << CH_INIT) | (1 << CH_MOUNT)           ' Debug mount failures
  '   DEBUG_MASK = (1 << CH_FILE) | (1 << CH_SECTOR)          ' Debug file read/write
  '   DEBUG_MASK = (1 << CH_STATUS)                           ' Debug CMD13 issues
  '   DEBUG_MASK = -1                                         ' ALL channels (will exceed 255!)
  DEBUG_MASK = 0                                               ' Production: all debug suppressed

CON ' driver mode (enforces valid command sequences)
  MODE_NONE       = 0       ' Not initialized - only mount() or initCardOnly() allowed
  MODE_RAW        = 1       ' Raw sector access only - initCardOnly() was called
  MODE_FILESYSTEM = 2       ' Full filesystem access - mount() was called

CON ' command codes for worker cog
  CMD_NONE      = 0         ' Idle / command complete
  CMD_MOUNT     = 1         ' Mount filesystem
  CMD_UNMOUNT   = 2         ' Unmount filesystem
  CMD_NEWDIR    = 9         ' Create new directory: param0=dirname ptr
  CMD_DELETE    = 10        ' Delete file: param0=filename ptr
  CMD_RENAME    = 11        ' Rename: param0=oldname, param1=newname
  CMD_CHDIR     = 12        ' Change directory: param0=dirname ptr
  CMD_READDIR   = 13        ' Read directory entry: param0=index
  CMD_FILESIZE  = 14        ' Get file size
  CMD_FREESPACE = 15        ' Get free space
  CMD_SYNC      = 16        ' Flush buffers
  CMD_MOVEFILE  = 17        ' Move file: param0=name, param1=dest folder
#ifdef SD_INCLUDE_DEBUG
  CMD_DEBUG_SLOW_READ  = 25 ' DEBUG: Byte-by-byte sector read (no streamer)
  CMD_DEBUG_CLEAR_ROOT = 26 ' DEBUG: Clear root directory (fixes corruption)
#endif
#ifdef SD_INCLUDE_STACK_CHECK
  CMD_STACK_DEPTH      = 50 ' DIAG: Report stack depth used
#endif

  CMD_READ_SECTOR_RAW  = 20 ' Raw single sector read: param0=sector, param1=buffer ptr (infrastructure - used across multiple feature flags)

#ifdef SD_INCLUDE_RAW
  CMD_INIT_CARD_ONLY = 22   ' Initialize card without filesystem (raw mode)
  CMD_GET_CARD_SIZE  = 23   ' Get card size in sectors: returns in data0
  CMD_READ_SECTORS  = 18    ' Raw multi-block read: param0=start_sector, param1=count, param2=buffer ptr
  CMD_WRITE_SECTORS = 19    ' Raw multi-block write: param0=start_sector, param1=count, param2=buffer ptr
  CMD_WRITE_SECTOR_RAW = 21 ' Raw single sector write: param0=sector, param1=buffer ptr
  CMD_TEST_CMD13     = 82   ' Test CMD13: returns R2 response in data0
#endif

#ifdef SD_INCLUDE_REGISTERS
  CMD_READ_SCR       = 24   ' Read SCR register: param0=buffer ptr
  CMD_READ_CID         = 27 ' Read CID register: param0=buffer ptr
  CMD_READ_CSD         = 28 ' Read CSD register: param0=buffer ptr
  CMD_READ_SD_STATUS   = 29 ' Read SD Status (ACMD13): 64-byte register via CMD55+CMD13
#endif

#ifdef SD_INCLUDE_SPEED
#ifndef SD_INCLUDE_REGISTERS
#error "SD_INCLUDE_SPEED requires SD_INCLUDE_REGISTERS"
#endif
  CMD_ATTEMPT_HIGH_SPEED = 83  ' Attempt 50 MHz high-speed: returns data0=boolean
  CMD_CHECK_HS_CAPABILITY = 84 ' Check CMD6 high-speed support: returns data0=boolean
  CMD_SET_SPI_SPEED = 85       ' Set SPI clock frequency: param0=target Hz, returns data0=actual Hz
#endif

  ' ═══════════════════════════════════════════════════════════════════════════
  ' V3 Handle-Based File Commands (multi-file support)
  ' ═══════════════════════════════════════════════════════════════════════════
  CMD_OPEN_READ   = 30      ' Open file for reading: param0=path ptr, returns data0=handle
  CMD_OPEN_WRITE  = 31      ' Open file for writing (append): param0=path ptr, returns data0=handle
  CMD_CREATE      = 32      ' Create new file for writing: param0=path ptr, returns data0=handle
  CMD_CLOSE_H     = 33      ' Close file handle: param0=handle
  CMD_READ_H      = 34      ' Read from handle: param0=handle, param1=buffer ptr, param2=count, returns data0=bytes_read
  CMD_WRITE_H     = 35      ' Write to handle: param0=handle, param1=buffer ptr, param2=count, returns data0=bytes_written
  CMD_SEEK_H      = 36      ' Seek in handle: param0=handle, param1=position
  CMD_TELL_H      = 37      ' Get position: param0=handle, returns data0=position
  CMD_FILESIZE_H  = 38      ' Get file size: param0=handle, returns data0=size
  CMD_SYNC_H      = 39      ' Sync handle buffer to disk: param0=handle
  CMD_SYNC_ALL    = 40      ' Sync all open file handles
  CMD_EOF_H       = 41      ' Check end of file: param0=handle, returns data0=true/false
  CMD_OPEN_DIR    = 43      ' Open directory: param0=path ptr, returns data0=handle
  CMD_READ_DIR_H  = 44      ' Read next dir entry: param0=handle, returns data0=ptr
  CMD_CLOSE_DIR_H = 45      ' Close directory handle: param0=handle
  CMD_SET_VOL_LABEL = 46    ' Set volume label: param0=new label string ptr
#ifdef SD_INCLUDE_DEFRAG
  CMD_CREATE_CONTIGUOUS = 47  ' Create file with pre-allocated contiguous chain: param0=path ptr, param1=file_size, returns data0=handle
  CMD_COMPACT_FILE      = 48  ' Defragment a single file: param0=path ptr
  CMD_FILE_FRAGMENTS    = 49  ' Count file fragmentation: param0=path ptr, returns data0=fragment_count
#endif

CON ' buffer types for sector read/write (diagnostic: separate buffers to isolate conflicts)
  BUF_DIR  = 0      ' Directory sector buffer
  BUF_FAT  = 1      ' FAT sector buffer
  BUF_DATA = 2      ' Data sector buffer

CON ' error codes
  {Spin2_Doc_CON}
  SUCCESS           = 0
  E_TIMEOUT         = -1        ' Card didn't respond in time
  E_NO_RESPONSE     = -2        ' Card not responding
  E_BAD_RESPONSE    = -3        ' Unexpected response from card
  E_CRC_ERROR       = -4        ' Data CRC mismatch
  E_WRITE_REJECTED  = -5        ' Card rejected write operation
  E_CARD_BUSY       = -6        ' Card busy
  E_IO_ERROR        = -7        ' General I/O error during read/write
  E_NO_CARD         = -8        ' No card detected in slot (MISO idle during CMD0 probe)
  E_NOT_MOUNTED     = -20       ' Filesystem not mounted
  E_INIT_FAILED     = -21       ' Card initialization failed
  E_NOT_FAT32       = -22       ' Card not formatted as FAT32
  E_BAD_SECTOR_SIZE = -23       ' Sector size not 512 bytes
  E_FILE_NOT_FOUND  = -40       ' File doesn't exist
  E_FILE_EXISTS     = -41       ' File already exists
  E_NOT_A_FILE      = -42       ' Expected file, found directory
  E_NOT_A_DIR       = -43       ' Expected directory, found file
  E_FILE_NOT_OPEN   = -45       ' File not open
  E_END_OF_FILE     = -46       ' Read past end of file
  E_DISK_FULL       = -60       ' No free clusters
#ifdef SD_INCLUDE_DEFRAG
  E_NO_CONTIGUOUS_SPACE  = -61  ' No contiguous run of sufficient length
  E_FILE_OPEN_FOR_COMPACT = -62 ' File is open (cannot compact while open)
  E_VERIFY_FAILED        = -63  ' Read-back verification failed after compact
#endif
  E_NO_LOCK         = -64       ' Couldn't allocate hardware lock

  ' ═══════════════════════════════════════════════════════════════════════════
  ' V3 Multi-File Handle Error Codes
  ' ═══════════════════════════════════════════════════════════════════════════
  E_TOO_MANY_FILES    = -90     ' All file handles are in use
  E_INVALID_HANDLE    = -91     ' Handle out of range or not open
  E_FILE_ALREADY_OPEN = -92     ' File is already open for writing (single-writer policy)
  E_NOT_A_DIR_HANDLE  = -93     ' Handle is not a directory handle (or vice versa)
  E_INVALID_PARAM     = -94     ' Parameter value out of valid range

CON ' card warning/capability flags
  {Spin2_Doc_CON}
  CW_NONE              = $00     ' No warnings or capabilities
  CW_CMD13_UNRELIABLE  = $01     ' CMD13 probe failed at init; status checks disabled for this card
  CW_CMD23_SUPPORTED   = $02     ' CMD23 (SET_BLOCK_COUNT) confirmed working in SPI mode

CON ' V3 multi-file handle configuration
  {Spin2_Doc_CON}
  ' ═══════════════════════════════════════════════════════════════════════════
  ' FILE HANDLE SYSTEM - V3 supports multiple simultaneously open files
  ' User can override MAX_OPEN_FILES in their top-level CON section before OBJ
  ' Memory cost: 544 bytes per handle (32 bytes state + 512 bytes buffer)
  ' Default 6 covers 2-3 cogs with mixed file/directory operations
  ' ═══════════════════════════════════════════════════════════════════════════
  MAX_OPEN_FILES = 6            ' Default number of handles (user-overridable)

  ' Handle state flags (stored in h_flags array)
  HF_FREE   = 0                 ' Handle slot is available
  HF_READ   = 1                 ' Handle is open for reading
  HF_WRITE  = 2                 ' Handle is open for writing
  HF_DIR    = 4                 ' Handle is a directory enumeration handle
  HF_DIRTY  = $80               ' Handle's buffer has pending writes (OR'd with mode)

CON ' worker cog stack size
  STACK_SIZE = 160              ' 160 longs = 640 bytes (measured peak: 113 longs, 29% headroom)
  STACK_GUARD_LONGS = 4         ' 4 longs = 16 bytes guard zone after stack
  STACK_GUARD_BYTE  = $CC       ' Sentinel value (matches isp_rt_utilities convention)

CON ' idle flush threshold
  IDLE_FLUSH_MS      = 200    ' Milliseconds idle before auto-flush

CON ' sector geometry (public)
  {Spin2_Doc_CON}
  SECTOR_SIZE        = 512    ' Bytes per sector (FAT32 standard)

CON ' sector geometry (internal)
  SECTOR_SHIFT       = 9     ' log2(SECTOR_SIZE) -- byte-to-sector conversion
  SECTOR_OFFSET_MASK = 511   ' SECTOR_SIZE - 1 -- byte offset within sector

CON ' FAT32 directory entry attribute flags
  {Spin2_Doc_CON}
  ATTR_READONLY   = $01     ' File is read-only
  ATTR_HIDDEN     = $02     ' File is hidden
  ATTR_SYSTEM     = $04     ' System file
  ATTR_VOLUME_ID  = $08     ' Volume label entry
  ATTR_DIRECTORY  = $10     ' Directory entry
  ATTR_ARCHIVE    = $20     ' Archive flag (set on write)
  ATTR_LFN        = $0F     ' Long filename entry (RO+HID+SYS+VOL)

CON ' FAT32 directory entry markers
  {Spin2_Doc_CON}
  DIR_ENTRY_DELETED = $E5   ' First byte marks deleted entry
  DIR_ENTRY_SIZE    = 32    ' Bytes per directory entry

CON ' FAT32 cluster chain markers (FAT32 File System Spec)
  FAT32_EOC_MIN       = $0FFF_FFF8  ' Minimum end-of-chain marker
  FAT32_EOC_MARK      = $0FFF_FFFF  ' End-of-chain marker for new allocations
  FAT32_ENTRY_MASK    = $0FFF_FFFF  ' Low 28 bits: cluster number
  FAT32_RESERVED_MASK = $F000_0000  ' High 4 bits: reserved (preserve on write)
  ROOT_CLUSTER        = 2           ' First data cluster (clusters 0,1 reserved)
  EXPECTED_FAT_COUNT  = 2           ' Standard FAT32 has 2 FATs

CON ' MBR/VBR/FSInfo structure constants
  MBR_PARTITION_OFFSET  = $1BE    ' Byte offset of first partition entry in MBR
  BOOT_SIGNATURE        = $AA55  ' MBR/VBR boot signature
  BOOT_SIG_OFFSET       = $1FE   ' Byte offset of boot signature in sector
  PART_TYPE_FAT32_LBA28 = $0B    ' FAT32 partition type (CHS/LBA < 2TB)
  PART_TYPE_FAT32_LBA   = $0C    ' FAT32 partition type (LBA)
  FAT_EPOCH_YEAR        = 1980   ' FAT timestamp base year

CON ' FSInfo sector signatures
  FSINFO_LEAD_SIG   = $4161_5252  ' FSInfo lead signature
  FSINFO_STRUCT_SIG = $6141_7272  ' FSInfo struct signature

CON ' 8.3 Short Filename (SFN) constants
  SFN_NAME_LEN       = 8
  SFN_TOTAL_LEN      = 11
  SFN_WITH_DOT_LEN   = 12

CON ' ASCII constants
  ASCII_CASE_OFFSET  = $20    ' lowercase - uppercase

CON ' Directory/FAT iteration counts
  FAT_ENTRIES_PER_SECTOR = 128  ' SECTOR_SIZE / 4
  DIR_ENTRIES_PER_SECTOR = 16   ' SECTOR_SIZE / DIR_ENTRY_SIZE
  LAST_DIR_ENTRY_OFFSET  = 480  ' (DIR_ENTRIES_PER_SECTOR - 1) * DIR_ENTRY_SIZE

CON ' Directory entry field byte offsets
  {Spin2_Doc_CON}
  DE_ATTR_OFFSET     = 11    ' Attributes byte
  DE_CRT_TIME_OFFSET = 14    ' Creation timestamp (long)
  DE_CLUS_HI_OFFSET  = 20    ' Start cluster high word
  DE_WRT_TIME_OFFSET = 22    ' Write/modification timestamp (long)
  DE_CLUS_LO_OFFSET  = 26    ' Start cluster low word
  DE_FILESIZE_OFFSET = 28    ' File size in bytes (long)

CON ' streamer configuration (compile-time constants for bulk sector transfers)
  ' Reference: flash_loader.spin2 pattern, P2 Silicon Doc streamer section
  ' Using explicit hex values from working flash_loader code:
  ' Mode word: [31:28]=mode [27:24]=options [23:17]=pin [16:0]=count
  ' $C0 = 1-pin input to WFBYTE (RX), $80 = RFBYTE to 1-pin output (TX)
  ' $81 = X_ALT_ON (MSB-first, bit 7) + X_WRITE_ON/X_PINS_ON (bit 0)
  STREAM_RX_BASE = $C081_0000   ' 1-pin input to hub, MSB-first (flash_loader wmode)
  STREAM_TX_BASE = $8081_0000   ' hub to 1-pin output, MSB-first (flash_loader rmode)

CON ' CRC-16-CCITT configuration (using P2 GETCRC instruction)
  ' Replaces 512-byte lookup table with hardware GETCRC + transformation
  ' Formula: crc := ((GETCRC(@data, CRC_POLY, 512) ^ CRC_BASE_512) REV 31) >> 16
  CRC_POLY_REFLECTED = $8408    ' CRC-16-CCITT in LSB-first (reflected) form
  CRC_BASE_512       = $2C68    ' GETCRC of 512 zero bytes with poly $8408

CON ' CRC retry configuration
  MAX_READ_CRC_RETRIES = 3       ' Number of read retries on CRC mismatch (industry standard)

CON ' SD SPI command numbers (SD Physical Layer Spec)
  CMD0   = 0                    ' GO_IDLE_STATE
  CMD6   = 6                    ' SWITCH_FUNC (high-speed mode)
  CMD8   = 8                    ' SEND_IF_COND (voltage check)
  CMD9   = 9                    ' SEND_CSD
  CMD10  = 10                   ' SEND_CID
  CMD12  = 12                   ' STOP_TRANSMISSION - terminates multi-block read/write
  CMD13  = 13                   ' SEND_STATUS - get card status register (R2 response)
  CMD17  = 17                   ' READ_SINGLE_BLOCK
  CMD18  = 18                   ' READ_MULTIPLE_BLOCK - read consecutive sectors
  CMD23  = 23                   ' SET_BLOCK_COUNT - pre-define sector count for CMD18/CMD25
  CMD24  = 24                   ' WRITE_BLOCK
  CMD25  = 25                   ' WRITE_MULTIPLE_BLOCK - write consecutive sectors
  ACMD41 = 41                   ' SD_SEND_OP_COND (requires CMD55 prefix)
  ACMD51 = 51                   ' SEND_SCR (requires CMD55 prefix)
  CMD55  = 55                   ' APP_CMD prefix
  CMD58  = 58                   ' READ_OCR

CON ' SPI R1 response bit masks (SD Physical Layer Spec section 7.3.2.1)
  R1_IN_IDLE        = $01
  R1_FATAL_MASK     = $64    ' Illegal + Address + Parameter
  R1_STALE_MASK     = $1B    ' Idle + Erase reset + CRC + Erase seq

CON ' Data response token mask
  DATA_RESPONSE_MASK = $1F

CON ' Pre-computed CRC bytes for fixed-argument commands
  CRC_CMD0   = $95
  CRC_CMD8   = $87
  CRC_CMD9   = $AF
  CRC_CMD10  = $1B
  CRC_CMD12  = $61
  CRC_CMD55  = $65
  CRC_ACMD51 = $55
  CRC_NONE   = $FF    ' CRC not validated in SPI mode after init

CON ' CMD8 / ACMD41 / OCR constants
  CMD8_CHECK_PATTERN = $000001AA  ' VHS=1, pattern=$AA
  CMD8_ECHO_MASK     = $FFF
  CMD8_ECHO_EXPECTED = $1AA
  ACMD41_HCS_BIT     = $40000000  ' Host Capacity Support
  OCR_CCS_SHIFT      = 30         ' Card Capacity Status bit position

CON ' Card initialization timing
  POWER_ON_DELAY_MS    = 100       ' VDD stabilization delay (spec: 1ms minimum)
  INIT_SPI_FREQ        = 400_000   ' 400 kHz per SD spec during init
  SMARTPIN_SETTLE_US   = 100       ' Smart pin configuration settle time
  RECOVERY_FLUSH_CLKS  = 4096     ' Enough clocks to flush stuck 512-byte transfer
  CMD0_MAX_RETRIES     = 5        ' GO_IDLE_STATE retry count
  CMD_RETRY_DELAY_MS   = 10       ' Delay between CMD0 retries
  ACMD41_TIMEOUT_SECS  = 2        ' ACMD41 init loop timeout
  ACMD41_POLL_DELAY_MS = 10       ' Delay between ACMD41 polls
  INIT_DUMMY_BYTES     = 10       ' Dummy bytes after smart pin init (80+ clocks)
  POST_INIT_DUMMY_REPS = 8        ' Dummy transfers after speed change (64 clocks)

  ' ═══════════════════════════════════════════════════════════════════════════
  ' Card Status Register (CSR) bits - returned by CMD13 (R2 response = R1 + status byte)
  ' Reference: SD Physical Layer Spec section 4.10.1
  ' ═══════════════════════════════════════════════════════════════════════════
  ' R2 response is 2 bytes: first byte = R1, second byte = status flags
  ' Status byte bit definitions (directly from SD spec):
  CSR_CARD_IS_LOCKED    = $01  ' Bit 0: Card is locked
  CSR_WP_ERASE_SKIP     = $02  ' Bit 1: Write protect erase skip / lock/unlock cmd failed
  CSR_ERROR             = $04  ' Bit 2: General/unknown error
  CSR_CC_ERROR          = $08  ' Bit 3: Card controller error
  CSR_CARD_ECC_FAILED   = $10  ' Bit 4: Card internal ECC failed
  CSR_WP_VIOLATION      = $20  ' Bit 5: Write protect violation
  CSR_ERASE_PARAM       = $40  ' Bit 6: Invalid erase parameter
  CSR_OUT_OF_RANGE      = $80  ' Bit 7: Out of range / CSD overwrite error

  ' ═══════════════════════════════════════════════════════════════════════════
  ' SD SPI Data Tokens (reference: SD Physical Layer Spec section 7.3.3)
  ' ═══════════════════════════════════════════════════════════════════════════
  TOKEN_START_BLOCK      = $FE ' Start token for single-block read/write and multi-block read
  TOKEN_START_MULTI_WRITE = $FC ' Start token for each block in multi-block WRITE
  TOKEN_STOP_TRAN        = $FD ' Stop token to terminate multi-block WRITE (not CMD12!)

  ' Data Response Token format (after each block write): xxx0sss1
  ' sss = status: 010 = accepted, 101 = CRC error, 110 = write error
  DATA_ACCEPTED          = $05 ' Lower 5 bits = xxx00101 = data accepted
  DATA_CRC_ERROR         = $0B ' Lower 5 bits = xxx01011 = CRC error
  DATA_WRITE_ERROR       = $0D ' Lower 5 bits = xxx01101 = write error

CON ' struct types - SD card register and FAT32 on-disk data structures
  {Spin2_Doc_CON}
  ' ═══════════════════════════════════════════════════════════════════════════
  ' Struct type definitions for card registers, filesystem structures, and
  ' directory entries. Exported automatically to consumer objects via OBJ.
  ' All structs are packed (Spin2 default) - offsets match hardware/on-disk layouts.
  ' ═══════════════════════════════════════════════════════════════════════════

  ' --- SD Card Registers ---

  ' CID register (16 bytes, big-endian from card):
  '  mid      - Manufacturer ID (1 byte)
  '  oid[2]   - OEM/Application ID (2 bytes ASCII)
  '  pnm[5]   - Product name (5 bytes ASCII)
  '  prv      - Product revision (1 byte, BCD: high=major, low=minor)
  '  psn[4]   - Product serial number (4 bytes)
  '  mdt[2]   - Manufacturing date (2 bytes: year offset from 2000, month)
  '  crc      - CRC7 checksum (1 byte)
  STRUCT cid_t(BYTE mid, BYTE oid[2], BYTE pnm[5], BYTE prv, BYTE psn[4], BYTE mdt[2], BYTE crc)

  ' SCR register (8 bytes, big-endian from card):
  '  sdSpec       - SD spec version (4 bits)
  '  sdSecurity   - Security protocol support (4 bits)
  '  sdSpec3Ext   - Spec 3.0 extended fields
  '  sdSpecXLo    - Spec extensions (lower bits)
  '  reserved[4]  - Reserved bytes
  STRUCT scr_t(BYTE sdSpec, BYTE sdSecurity, BYTE sdSpec3Ext, BYTE sdSpecXLo, BYTE reserved[4])

  ' --- FAT32 On-Disk Structures ---

  ' Directory entry (32 bytes, little-endian):
  '  name[8]    - Short filename (8 chars, space-padded)
  '  ext[3]     - Extension (3 chars, space-padded)
  '  attr       - Attribute flags (ATTR_READONLY, ATTR_DIRECTORY, etc.)
  '  ntRes      - Reserved for Windows NT (case info)
  '  crtTenth   - Creation time tenths of a second
  '  crtTime    - Creation time (hour:min:sec/2)
  '  crtDate    - Creation date (year-1980:month:day)
  '  accDate    - Last access date
  '  clusHI     - Start cluster high word
  '  wrtTime    - Last write time
  '  wrtDate    - Last write date
  '  clusLO     - Start cluster low word
  '  fileSize   - File size in bytes
  STRUCT dir_entry_t(BYTE name[8], BYTE ext[3], BYTE attr, BYTE ntRes, BYTE crtTenth, ...
    WORD crtTime, WORD crtDate, WORD accDate, WORD clusHI, ...
    WORD wrtTime, WORD wrtDate, WORD clusLO, LONG fileSize)

  ' MBR partition table entry (16 bytes, little-endian):
  '  bootFlag     - Boot indicator ($00=inactive, $80=active)
  '  chsStart[3]  - CHS address of first sector
  '  partType     - Partition type ($0B/$0C = FAT32)
  '  chsEnd[3]    - CHS address of last sector
  '  lbaStart     - LBA of first sector
  '  lbaSize      - Total sectors in partition
  STRUCT mbr_partition_t(BYTE bootFlag, BYTE chsStart[3], BYTE partType, ...
    BYTE chsEnd[3], LONG lbaStart, LONG lbaSize)

  ' VBR / FAT32 BPB (512 bytes, little-endian):
  '  -- Boot header --
  '  jumpBoot[3]     - Boot jump instruction ($EB xx $90)
  '  oemName[8]      - OEM name / formatting tool ID
  '  -- BPB geometry --
  '  bytesPerSec     - Bytes per sector (always 512)
  '  secPerClus      - Sectors per cluster (power of 2)
  '  reservedSec     - Reserved sectors before first FAT
  '  numFats         - Number of FAT copies (always 2)
  '  rootEntCnt      - Root entry count (0 for FAT32)
  '  totalSec16      - Total sectors 16-bit (0 for FAT32)
  '  mediaType       - Media type ($F8 = hard disk)
  '  secPerFat16     - Sectors per FAT 16-bit (0 for FAT32)
  '  secPerTrack     - Sectors per track (CHS geometry)
  '  numHeads        - Number of heads (CHS geometry)
  '  hiddenSec       - Hidden sectors before partition
  '  totalSec32      - Total sectors 32-bit
  '  -- FAT32 extended --
  '  secPerFat32     - Sectors per FAT (32-bit)
  '  extFlags        - FAT mirroring flags
  '  fsVersion       - Filesystem version (0.0)
  '  rootCluster     - Root directory first cluster (usually 2)
  '  fsInfoSec       - FSInfo sector number (usually 1)
  '  backBootSec     - Backup boot sector (usually 6)
  '  reserved2[12]   - Reserved
  '  driveNum        - BIOS drive number
  '  reserved3       - Reserved
  '  bootSig         - Extended boot signature ($29)
  '  volSerialNum    - Volume serial number
  '  volLabel[11]    - Volume label (space-padded)
  '  fsTypeLabel[8]  - Filesystem type string ("FAT32   ")
  '  bootCode[420]   - Boot code
  '  bootSignature   - Boot signature ($AA55)
  STRUCT vbr_t(BYTE jumpBoot[3], BYTE oemName[8], WORD bytesPerSec, BYTE secPerClus, ...
    WORD reservedSec, BYTE numFats, WORD rootEntCnt, WORD totalSec16, ...
    BYTE mediaType, WORD secPerFat16, WORD secPerTrack, WORD numHeads, ...
    LONG hiddenSec, LONG totalSec32, LONG secPerFat32, WORD extFlags, ...
    WORD fsVersion, LONG rootCluster, WORD fsInfoSec, WORD backBootSec, ...
    BYTE reserved2[12], BYTE driveNum, BYTE reserved3, BYTE bootSig, ...
    LONG volSerialNum, BYTE volLabel[11], BYTE fsTypeLabel[8], ...
    BYTE bootCode[420], WORD bootSignature)

  ' FSInfo sector (512 bytes, little-endian):
  '  leadSig        - Lead signature ($41615252)
  '  reserved1[480] - Reserved (must be zero)
  '  structSig      - Struct signature ($61417272)
  '  freeClusters   - Free cluster count ($FFFFFFFF if unknown)
  '  nextFreeHint   - Next free cluster hint ($FFFFFFFF if unknown)
  '  reserved2[12]  - Reserved
  '  trailSig       - Trail signature ($AA550000)
  STRUCT fsinfo_t(LONG leadSig, BYTE reserved1[480], LONG structSig, ...
    LONG freeClusters, LONG nextFreeHint, BYTE reserved2[12], LONG trailSig)

DAT ' ---- Singleton Control ----
  ' ═══════════════════════════════════════════════════════════════════════
  ' SINGLETON CONTROL - Must be initialized to "not started" state
  ' ═══════════════════════════════════════════════════════════════════════
  cog_id        LONG    -1              ' Worker cog ID (-1 = not started)
  api_lock      LONG    -1              ' Hardware lock ID (-1 = not allocated)
  driver_mode   LONG    0               ' Current mode: MODE_NONE, MODE_RAW, or MODE_FILESYSTEM
  last_init_error LONG  0               ' Specific error from last initCard() failure

  ' ═══════════════════════════════════════════════════════════════════════
  ' CMD13 STATUS STAGING - Preserved for diagnostic inspection
  ' ═══════════════════════════════════════════════════════════════════════
  last_cmd13_r1     BYTE    0           ' Last R1 byte from CMD13
  last_cmd13_status BYTE    0           ' Last STATUS byte from CMD13
  last_cmd13_error  WORD    0           ' Last non-zero R2 (preserved until next error)
  last_cmd18_r1     BYTE    0           ' Last R1 byte from CMD18 (for multi-block read diagnostics)
  last_cmd18_token  BYTE    0           ' Last data token or error token from CMD18 waitDataToken()
  last_cmd18_result BYTE    0           ' Last waitDataToken() result: 0=ok, 1=timeout, 2=error token
  last_cmd18_fail   BYTE    0           ' Failure path: 0=none, 1=R1 reject, 2=data token, 3=CMD12, 4=CMD13
  last_cmd18_sread  BYTE    0           ' sectors_read at end of loop (before CMD12/CMD13)
  last_cmd12_r1     BYTE    0           ' Last R1 from CMD12 (sendStopTransmission)
  last_cmd12_busy   BYTE    0           ' CMD12 busy result: 0=ok, 1=timeout, 2=R1 error, 3=busy timeout
  cmd12_capture_len BYTE    0           ' Number of bytes captured in cmd12_capture[]
  cmd12_capture     BYTE    0[16]       ' Raw byte stream after CMD12 stuff byte (for framing analysis)
  cmd12_pre_capture BYTE    0[7]        ' MISO bytes received DURING CMD12 command transmission (full-duplex)
  last_cmd23_r1     BYTE    0           ' Last R1 from CMD23 (SET_BLOCK_COUNT): $00=accepted, $FF=not sent
  last_cmd23_verify BYTE    0           ' Post-read verification byte: $FF=card stopped, other=still streaming
  last_cmd23_used   BYTE    FALSE       ' TRUE if CMD23 path was used for the last multi-block read
  cmd13_reliable    BYTE    TRUE        ' FALSE if CMD13 probe failed at init (default: enabled)
  cmd23_supported   BYTE    FALSE       ' TRUE if card advertises CMD23 in SCR CMD_SUPPORT
  card_warning_flags BYTE   CW_NONE    ' Advisory bitmask (queried via cardWarnings())
  cmd13_pre_capture BYTE    0[7]        ' MISO bytes received DURING CMD13 command transmission (full-duplex)
  cmd13_capture     BYTE    0[8]        ' Raw bytes post-command: NCR gap $FFs, R1, STATUS, extra bytes
  cmd13_capture_len BYTE    0           ' Position of first non-$FF byte in cmd13_capture (NCR gap length)
  test_force_cmd13  BYTE    FALSE       ' Diagnostic: force CMD13 even on cards flagged unreliable

  ' ═══════════════════════════════════════════════════════════════════════
  ' PARAMETER BLOCK - Communication between API and worker cog
  ' ═══════════════════════════════════════════════════════════════════════
  pb_cmd        LONG    0               ' Command (0 = idle/done)
  pb_status     LONG    0               ' Result status code
  pb_caller     LONG    0               ' Caller's cog ID (for COGATN signal)
  pb_param0     LONG    0               ' Parameter 0 (varies by command)
  pb_param1     LONG    0               ' Parameter 1
  pb_param2     LONG    0               ' Parameter 2
  pb_param3     LONG    0               ' Parameter 3
  pb_data0      LONG    0               ' Result data 0 (handle, count, etc.)
  pb_data1      LONG    0               ' Result data 1

  ' ═══════════════════════════════════════════════════════════════════════
  ' WORKER LOOP STATE (idle flush + clock tick)
  ' ═══════════════════════════════════════════════════════════════════════
  idle_timer        LONG    0           ' getct() at last command completion
  idle_flush_clocks LONG    0           ' Threshold in clock ticks (set at mount time)
  flush_done        BYTE    false       ' TRUE after idle flush completes (reset on next command)
  ct_active         BYTE    0           ' TRUE when live clock is enabled (set by setDate)
  ct_last_tick      LONG    0           ' getct() at last clock tick
  ct_tick_clocks    LONG    0           ' Clock ticks per 2-second interval (set at mount)
  async_active      BYTE    0           ' TRUE when an async operation is in flight
  async_caller      BYTE    0           ' Cog ID of the async caller

  ' ═══════════════════════════════════════════════════════════════════════
  ' WORKER COG STACK
  ' ═══════════════════════════════════════════════════════════════════════
  cog_stack     LONG    0[STACK_SIZE]   ' Worker cog stack
  cog_stack_guard LONG  0[STACK_GUARD_LONGS]  ' Stack overflow sentinel ($CC fill)

  ' ═══════════════════════════════════════════════════════════════════════
  ' SPI PIN CONFIGURATION (set once at start)
  ' ═══════════════════════════════════════════════════════════════════════
  cs            LONG    0               ' Chip select pin
  mosi          LONG    0               ' Master out, slave in pin
  miso          LONG    0               ' Master in, slave out pin
  sck           LONG    0               ' Serial clock pin

  ' ═══════════════════════════════════════════════════════════════════════
  ' SMART PIN SPI CONFIGURATION (Phase 1 Performance Sprint)
  ' P_TRANSITION for clock, P_SYNC_TX for transmit, P_SYNC_RX for receive
  ' B-input offset links MOSI/MISO to SCK for synchronized operation
  ' ═══════════════════════════════════════════════════════════════════════
  spi_clk_mode  LONG    0               ' P_PULSE | P_OE for SCK
  spi_tx_mode   LONG    0               ' P_SYNC_TX | P_OE for MOSI
  spi_rx_mode   LONG    0               ' P_SYNC_RX for MISO
  spi_period    LONG    0               ' Current SPI half-period (for sysclk-independent timing)
  spi_freq      LONG    0               ' Actual achieved SPI frequency (Hz)
  spi_event     LONG    0               ' Event config for waitse1 (%01_000000 | sck)
  sp_debug_ctr  LONG    0               ' Debug counter for sp_transfer_8

  ' ═══════════════════════════════════════════════════════════════════════
  ' FILESYSTEM STATE (moved from VAR)
  ' ═══════════════════════════════════════════════════════════════════════
  fat_sec       LONG    0               ' Starting sector of FAT
  fat2_sec      LONG    0               ' Starting sector of FAT2 (mirror)
  sec_per_fat   LONG    0               ' Sectors per FAT
  sec_per_clus  LONG    0               ' Sectors per cluster
  root_sec      LONG    0               ' Starting sector of root directory
  cluster_offset LONG   0               ' Cluster offset calculation
  cog_dir_sec   LONG    0[8]            ' Per-cog current directory sector
  entry_address LONG    0               ' Current entry byte address
  date_stamp    LONG    0               ' Timestamp for new files (live packed FAT32 date+time)

  ' FIELD pointers into date_stamp (initialized in worker startup)
  fld_yr        LONG    0               ' ^@date_stamp.[31..25]  Year-1980 (7 bits)
  fld_mon       LONG    0               ' ^@date_stamp.[24..21]  Month (4 bits)
  fld_day       LONG    0               ' ^@date_stamp.[20..16]  Day (5 bits)
  fld_hr        LONG    0               ' ^@date_stamp.[15..11]  Hour (5 bits)
  fld_min       LONG    0               ' ^@date_stamp.[10..5]   Minute (6 bits)
  fld_sec       LONG    0               ' ^@date_stamp.[4..0]    Second/2 (5 bits)
  days_table    BYTE    31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31
  n_sec         LONG    0               ' Current sector number
  flags         LONG    0               ' State flags (F_MOUNTED, F_NEWDIR)
  dir_sec_in_buf LONG   0               ' Directory sector currently in dir_buf
  fat_sec_in_buf LONG   0               ' FAT sector currently in fat_buf
  sec_in_buf    LONG    0               ' Data sector currently in buf
  bit_delay     LONG    0               ' SPI bit delay
  hcs           LONG    0               ' High capacity support flag
  fsinfo_sec    LONG    0               ' FSInfo sector number
  fsi_free_count LONG   0               ' Cached free cluster count
  fsi_nxt_free  LONG    0               ' Cached next free cluster hint
  vbr_sec       LONG    0               ' Volume Boot Record sector
  ocr_value     LONG    0               ' Cached OCR register (from CMD58)

  ' ═══════════════════════════════════════════════════════════════════════
  ' ADAPTIVE TIMING (Phase 2 - Card identification and speed adjustment)
  ' ═══════════════════════════════════════════════════════════════════════
  card_mfr_id   LONG    0               ' Manufacturer ID from CID (byte 0)
  card_max_speed_hz LONG 0              ' Maximum speed from CSD TRAN_SPEED (Hz)
  card_read_timeout_ms  LONG  100       ' Read timeout in ms (from CSD or spec default)
  card_write_timeout_ms LONG  500       ' Write timeout in ms (from CSD or spec default)

  ' ═══════════════════════════════════════════════════════════════════════
  ' PER-COG ERROR STORAGE (for thread-safe error reporting)
  ' ═══════════════════════════════════════════════════════════════════════
  last_error    LONG    0[8]            ' One slot per possible cog

  ' ═══════════════════════════════════════════════════════════════════════
  ' DIAGNOSTIC: Capture data inside readSector for debugging from test cog
  ' ═══════════════════════════════════════════════════════════════════════
  diag_last_sector   LONG    0          ' Last sector read
  diag_last_buftype  LONG    0          ' Last buf_type used
  diag_last_token    LONG    0          ' Last start token received
  diag_buf_byte0     LONG    0          ' First byte of buffer after streamer
  diag_buf_byte1     LONG    0          ' Second byte
  diag_buf_byte2     LONG    0          ' Third byte
  diag_buf_byte3     LONG    0          ' Fourth byte
  diag_p_buf         LONG    0          ' Buffer pointer used
  diag_before_b0     LONG    0          ' Buffer byte 0 BEFORE streamer
  diag_before_b1     LONG    0          ' Buffer byte 1 BEFORE streamer
  diag_before_b2     LONG    0          ' Buffer byte 2 BEFORE streamer
  diag_before_b3     LONG    0          ' Buffer byte 3 BEFORE streamer
  diag_spi_period    LONG    0          ' SPI period at time of read
  diag_recv_crc      WORD    0          ' CRC-16 received from card (high byte first)
  diag_calc_crc      WORD    0          ' CRC-16 calculated from data
  diag_sent_crc      WORD    0          ' CRC-16 sent with write data
  diag_crc_matches   LONG    0          ' Count of CRC matches (reads)
  diag_crc_mismatches LONG   0          ' Count of CRC mismatches (reads)
  diag_crc_retries   LONG    0          ' Count of CRC retry attempts
  diag_crc_enabled   BYTE    1          ' CRC validation enabled (1=on, 0=off)

  ' ═══════════════════════════════════════════════════════════════════════
  ' WRITE DIAGNOSTICS (set by writeSector, readable from any cog)
  ' Codes: 0=not called, 1=CMD24 fatal, 2=data-response timeout,
  '        3=data CRC reject, 4=data write-err reject, 5=data unknown reject,
  '        6=busy timeout, 7=success
  ' ═══════════════════════════════════════════════════════════════════════
  diag_write_result  LONG    0          ' Outcome code of last writeSector call
  diag_write_r1      LONG    0          ' CMD24 R1 response byte
  diag_write_dresp   LONG    0          ' Data response token from card
  diag_write_sector  LONG    0          ' Sector number attempted

  ' ═══════════════════════════════════════════════════════════════════════
  ' TEST HOOKS: Error injection for CRC validation testing
  ' Used by SD_RT_crc_validation_tests and SD_RT_recovery_tests
  ' ═══════════════════════════════════════════════════════════════════════
  test_force_read_crc_error   BYTE    0  ' Counter: force N read CRC mismatches
  test_force_write_crc_error  BYTE    0  ' Flag: corrupt next write CRC (one-shot)
  test_error_count            LONG    0  ' Count of injected errors triggered
  test_max_clusters           LONG    0  ' Limit: max allocatable cluster number (0 = no limit)

  ' ═══════════════════════════════════════════════════════════════════════
  ' BUFFERS (must be in DAT for worker cog access)
  ' DIAGNOSTIC: Separate buffers for each sector type to isolate conflicts
  ' ═══════════════════════════════════════════════════════════════════════
  dir_buf       BYTE    0[512]          ' Directory sector buffer
  fat_buf       BYTE    0[512]          ' FAT sector buffer
  buf           BYTE    0[512]          ' Data sector buffer
  entry_buffer  dir_entry_t
                BYTE    0[14]           ' name[8], ext[3], attr, ntRes, crtTenth
                WORD    0[7]            ' crtTime, crtDate, accDate, clusHI, wrtTime, wrtDate, clusLO
                LONG    0              ' fileSize
  vol_label     BYTE    0[12]           ' Volume label (11 chars + null)

  ' ═══════════════════════════════════════════════════════════════════════════
  ' V3 FILE HANDLE TABLE - 28 bytes per handle
  ' Each handle tracks an independently open file with its own state
  ' ═══════════════════════════════════════════════════════════════════════════
  h_flags       BYTE    0[MAX_OPEN_FILES]     ' Handle state: HF_FREE, HF_READ, HF_WRITE (| HF_DIRTY)
  h_attr        BYTE    0[MAX_OPEN_FILES]     ' FAT directory entry attributes byte
  h_dir_offset  WORD    0[MAX_OPEN_FILES]     ' Offset of dir entry within sector (0-511)
  h_position    LONG    0[MAX_OPEN_FILES]     ' Current byte position in file
  h_sector      LONG    0[MAX_OPEN_FILES]     ' Current sector number being accessed
  h_start_clus  LONG    0[MAX_OPEN_FILES]     ' First cluster of file (from dir entry)
  h_size        LONG    0[MAX_OPEN_FILES]     ' File size in bytes
  h_dir_sector  LONG    0[MAX_OPEN_FILES]     ' Sector containing directory entry
  h_cluster     LONG    0[MAX_OPEN_FILES]     ' Current cluster in FAT chain

  ' ═══════════════════════════════════════════════════════════════════════════
  ' V3 PER-HANDLE DATA BUFFERS - 512 bytes per handle
  ' Each handle has its own buffer to eliminate thrashing when switching files
  ' Cost: 512 bytes per handle, but provides significant performance benefit
  ' ═══════════════════════════════════════════════════════════════════════════
  h_buf         BYTE    0[512 * MAX_OPEN_FILES]   ' Per-handle sector buffers
  h_buf_sector  LONG    0[MAX_OPEN_FILES]         ' Sector currently in each buffer (-1 = invalid)
#ifdef SD_INCLUDE_DEFRAG
  h_prealloc_end LONG   0[MAX_OPEN_FILES]         ' Last pre-allocated cluster (0 = normal handle)
#endif


CON ' ---- Lifecycle ----

PUB null()
'' This is not a top-level object - placeholder to indicate driver must be instantiated as OBJ.


PUB start(_cs, _mosi, _miso, _sck) : result
'' Start worker cog (singleton) - initialize SD card driver and launch dedicated worker cog.
'' This method is idempotent - calling multiple times is safe.
''
'' @param _cs - Chip select pin number
'' @param _mosi - Master Out Slave In pin number
'' @param _miso - Master In Slave Out pin number
'' @param _sck - Serial clock pin number
'' @returns result - Cog ID (0-7) on success, -1 on failure

  ' Check if already started (singleton pattern)
  if cog_id <> -1
    debug[CH_API]("  [start] Already started (cog ", udec_(cog_id), ")")
    result := cog_id
  else
    ' Store pin configuration
    longmove(@cs, @_cs, 4)

    ' Allocate hardware lock for API serialization
    api_lock := locknew()
    if api_lock == -1
      debug[CH_API]("  [start] FAIL: Could not allocate lock")
      result := set_error(E_NO_LOCK)
    else
      ' Initialize parameter block
      pb_cmd := CMD_NONE
      pb_status := SUCCESS
      sec_in_buf := -1                                                          ' Invalidate buffer

      ' Initialize stack guard zone before launching worker
      bytefill(@cog_stack_guard, STACK_GUARD_BYTE, STACK_GUARD_LONGS * 4)
#ifdef SD_INCLUDE_STACK_CHECK
      ' Prepare stack for depth measurement (fills with sentinel pattern)
      stackUtils.prepStackForCheck(@cog_stack, STACK_SIZE)
#endif

      ' Launch worker cog
      cog_id := cogspin(NEWCOG, fs_worker(), @cog_stack)
      if cog_id == -1
        lockret(api_lock)
        api_lock := -1
        debug[CH_API]("  [start] FAIL: Could not start worker cog")
        result := set_error(E_NO_LOCK)
      else
        debug[CH_API]("  [start] Worker cog ", udec_(cog_id), " started, lock ", udec_(api_lock))
        result := cog_id


PUB stop()
'' Stop worker cog - cleanly shut down the worker cog and release resources.
'' Safe to call even if not started.

  if cog_id <> -1
    ' Send unmount command if mounted
    if flags & F_MOUNTED
      send_command(CMD_UNMOUNT, 0, 0, 0, 0)

    ' Stop the worker cog
    cogstop(cog_id)
    debug[CH_API]("  [stop] Worker cog ", udec_(cog_id), " stopped")
    cog_id := -1

  ' Release hardware lock
  if api_lock <> -1
    lockret(api_lock)
    api_lock := -1

  ' Clear state
  driver_mode := MODE_NONE   ' Reset mode so next init/mount starts fresh
  flags := 0
  sec_in_buf := -1


PUB mount(_cs, _mosi, _miso, _sck) : result
'' Mount SD card (multi-cog safe) - starts worker cog and mounts filesystem.
'' Supports MODE_RAW -> MODE_FILESYSTEM upgrade (card already initialized).
''
'' @param _cs - Chip select pin number
'' @param _mosi - Master Out Slave In pin number
'' @param _miso - Master In Slave Out pin number
'' @param _sck - Serial clock pin number
'' @returns result - SUCCESS (0) on success, negative error code on failure

  ' Check if already mounted
  if driver_mode == MODE_FILESYSTEM
    debug[CH_API]("  [mount] Already mounted")
    result := SUCCESS
  else
    ' MODE_RAW -> MODE_FILESYSTEM upgrade is allowed
    ' Worker is already running, just send mount command
    if driver_mode == MODE_RAW
      debug[CH_API]("  [mount] Upgrading from RAW to FILESYSTEM mode")

    ' Start worker cog if not already running (MODE_NONE case)
    if cog_id == -1
      if start(_cs, _mosi, _miso, _sck) == -1
        debug[CH_API]("  [mount] Failed to start worker cog")
        result := E_NO_LOCK

    ' Send mount command to worker (only if no error so far)
    if result == 0
      result := send_command(CMD_MOUNT, 0, 0, 0, 0)
      if result == SUCCESS
        debug[CH_API]("  [mount] Mount successful, mode=FILESYSTEM")
      else
        debug[CH_API]("  [mount] Mount failed with error ", sdec_(result))
        set_error(result)


PUB unmount() : result
'' Unmount SD card (multi-cog safe) - cleanly unmounts, flushing data and updating FSInfo.
''
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_UNMOUNT, 0, 0, 0, 0)
  debug[CH_API]("  [unmount] Card unmounted")
  if result <> SUCCESS
    set_error(result)


CON ' ---- File I/O ----

PUB openFileRead(p_path) : handle
'' Open file for reading (V3 multi-file) - opens existing file and returns handle.
'' Multiple files can be open simultaneously with independent positions.
'' Use closeFileHandle() when done.
''
'' @param p_path - Pointer to null-terminated path string
'' @returns handle - File handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure

  send_command(CMD_OPEN_READ, p_path, 0, 0, 0)
  handle := pb_data0
  if handle >= 0
    debug[CH_API]("  [openFileRead] Opened handle ", udec_(handle))
  else
    debug[CH_API]("  [openFileRead] Failed: ", sdec_(handle))
    set_error(handle)


PUB openFileWrite(p_path) : handle
'' Open file for writing/append (V3 multi-file) - opens for appending.
'' Position is set to end of file. Only one write handle per file allowed.
'' Use closeFileHandle() when done to flush data.
''
'' @param p_path - Pointer to null-terminated path string
'' @returns handle - File handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure

  send_command(CMD_OPEN_WRITE, p_path, 0, 0, 0)
  handle := pb_data0
  if handle >= 0
    debug[CH_API]("  [openFileWrite] Opened handle ", udec_(handle))
  else
    debug[CH_API]("  [openFileWrite] Failed: ", sdec_(handle))
    set_error(handle)


PUB createFileNew(p_path) : handle
'' Create new file for writing (V3 multi-file) - creates and opens for writing.
'' Returns error if file exists.
'' Use closeFileHandle() when done to flush data and finalize size.
''
'' @param p_path - Pointer to null-terminated path string
'' @returns handle - File handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure

  send_command(CMD_CREATE, p_path, 0, 0, 0)
  handle := pb_data0
  if handle >= 0
    debug[CH_API]("  [createFileNew] Created handle ", udec_(handle))
  else
    debug[CH_API]("  [createFileNew] Failed: ", sdec_(handle))
    set_error(handle)


PUB closeFileHandle(handle) : result
'' Close file handle (V3 multi-file) - closes handle, flushing pending writes.
'' For write handles, updates directory with final file size.
'' After close, handle is invalid and slot is available for reuse.
''
'' @param handle - File handle to close
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_CLOSE_H, handle, 0, 0, 0)
  if result == SUCCESS
    debug[CH_API]("  [closeFileHandle] Closed handle ", udec_(handle))
  else
    debug[CH_API]("  [closeFileHandle] Failed: ", sdec_(result))
    set_error(result)


PUB readHandle(handle, p_buffer, count) : bytes_read
'' Read from file handle (V3 multi-file) - reads up to count bytes into buffer.
'' Returns actual bytes read (may be less at EOF). Returns 0 at EOF.
'' Position advances by the number of bytes read.
''
'' @param handle - Valid read handle
'' @param p_buffer - Pointer to destination buffer
'' @param count - Number of bytes to read
'' @returns bytes_read - Number of bytes actually read (0 at EOF), negative on error

  send_command(CMD_READ_H, handle, p_buffer, count, 0)
  bytes_read := pb_data0
  if bytes_read < 0
    debug[CH_API]("  [readHandle] Failed: ", sdec_(bytes_read))
    set_error(bytes_read)


PUB writeHandle(handle, p_buffer, count) : bytes_written
'' Write to file handle (V3 multi-file) - writes count bytes from buffer.
'' File grows as needed with automatic cluster allocation.
'' Position advances by the number of bytes written.
''
'' @param handle - Valid write handle
'' @param p_buffer - Pointer to source data buffer
'' @param count - Number of bytes to write
'' @returns bytes_written - Number of bytes written, negative on error

  send_command(CMD_WRITE_H, handle, p_buffer, count, 0)
  bytes_written := pb_data0
  if bytes_written < 0
    debug[CH_API]("  [writeHandle] Failed: ", sdec_(bytes_written))
    set_error(bytes_written)


PUB seekHandle(handle, position) : result
'' Seek to position in file (V3 multi-file) - seeks to absolute byte position.
'' Position must be <= file size (cannot seek past EOF).
''
'' @param handle - Valid file handle
'' @param position - Absolute byte position to seek to
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_SEEK_H, handle, position, 0, 0)
  if result <> SUCCESS
    debug[CH_API]("  [seekHandle] Failed: ", sdec_(result))
    set_error(result)


PUB tellHandle(handle) : position
'' Get current position (V3 multi-file) - returns current byte position in file.
''
'' @param handle - Valid file handle
'' @returns position - Current position (0-based), negative on error

  send_command(CMD_TELL_H, handle, 0, 0, 0)
  if pb_status == SUCCESS
    position := pb_data0
  else
    position := pb_status
    set_error(position)


PUB eofHandle(handle) : is_eof
'' Check if at end of file (V3 multi-file) - returns TRUE if at or past EOF.
''
'' @param handle - Valid file handle
'' @returns is_eof - TRUE if at EOF, FALSE if not, negative on error

  send_command(CMD_EOF_H, handle, 0, 0, 0)
  if pb_status == SUCCESS
    is_eof := pb_data0 <> 0
  else
    is_eof := pb_status
    set_error(is_eof)


PUB fileSizeHandle(handle) : size
'' Get file size (V3 multi-file) - returns total size in bytes.
'' For write handles, reflects current size including pending writes.
''
'' @param handle - Valid file handle
'' @returns size - File size in bytes, negative on error

  send_command(CMD_FILESIZE_H, handle, 0, 0, 0)
  if pb_status == SUCCESS
    size := pb_data0
  else
    size := pb_status
    set_error(size)


PUB syncHandle(handle) : result
'' Flush handle to disk (V3 multi-file) - flushes pending writes and updates directory.
'' File remains open for further operations.
''
'' @param handle - Valid file handle
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_SYNC_H, handle, 0, 0, 0)
  if result <> SUCCESS
    debug[CH_API]("  [syncHandle] Failed: ", sdec_(result))
    set_error(result)


PUB syncAllHandles() : result
'' Flush all handles to disk (V3 multi-file) - flushes all open write handles.
'' Useful before risky operations or for periodic safety.
''
'' @returns result - SUCCESS (0) on success

  result := send_command(CMD_SYNC_ALL, 0, 0, 0, 0)
  if result <> SUCCESS
    debug[CH_API]("  [syncAllHandles] Failed: ", sdec_(result))
    set_error(result)


PUB sync() : result
'' Flush buffers (multi-cog safe) - flushes pending writes without closing file.
'' Use to checkpoint data during long operations.
''
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_SYNC, 0, 0, 0, 0)
  debug[CH_API]("  [sync] Buffers flushed")
  if result <> SUCCESS
    set_error(result)


CON ' ---- Directory ----

PUB openDirectory(p_path) : handle
'' Open directory for enumeration (multi-cog safe) - returns handle for iterating entries.
'' Use readDirectoryHandle() to get entries, closeDirectoryHandle() when done.
'' Pass "" or "." to enumerate calling cog's current working directory.
'' Handles share the existing file handle pool (MAX_OPEN_FILES total).
''
'' @param p_path - Pointer to null-terminated path string
'' @returns handle - Handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure

  send_command(CMD_OPEN_DIR, p_path, 0, 0, 0)
  handle := pb_data0


PUB readDirectoryHandle(handle) : p_entry
'' Read next entry from directory handle (multi-cog safe) - returns pointer to entry data.
'' Skips deleted, LFN, and hidden/system entries automatically.
'' After each call, use fileName() and attributes() to inspect the returned entry.
''
'' @param handle - Directory handle from openDirectory()
'' @returns p_entry - Pointer to entry_buffer on success, 0 at end of directory

  if send_command(CMD_READ_DIR_H, handle, 0, 0, 0) == SUCCESS
    p_entry := @entry_buffer


PUB closeDirectoryHandle(handle)
'' Close directory handle (multi-cog safe) - releases handle back to pool.
''
'' @param handle - Directory handle from openDirectory()

  send_command(CMD_CLOSE_DIR_H, handle, 0, 0, 0)


PUB readDirectory(entry) : result
'' Read directory entry (multi-cog safe) - iterates through directory entries.
''
'' @param entry - Entry index to read (0-based)
'' @returns result - Pointer to entry_buffer on success, 0 if entry doesn't exist

  if send_command(CMD_READDIR, entry, 0, 0, 0) == SUCCESS
    result := @entry_buffer


PUB newDirectory(name_ptr) : result
'' Create a new directory (multi-cog safe) in current directory.
''
'' @param name_ptr - Pointer to null-terminated directory name string
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_NEWDIR, name_ptr, 0, 0, 0)
  if result <> SUCCESS
    set_error(result)


PUB changeDirectory(name_ptr) : result
'' Change directory (multi-cog safe) - changes current directory.
''
'' @param name_ptr - Pointer to null-terminated directory name string
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_CHDIR, name_ptr, 0, 0, 0)
  if result <> SUCCESS
    set_error(result)


CON ' ---- Metadata ----

PUB deleteFile(name_ptr) : result
'' Delete file (multi-cog safe) - deletes file from current directory.
''
'' @param name_ptr - Pointer to null-terminated filename string
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_DELETE, name_ptr, 0, 0, 0)
  if result <> SUCCESS
    set_error(result)


PUB rename(old_name, new_name) : result
'' Rename file or directory (multi-cog safe).
''
'' @param old_name - Pointer to current filename string
'' @param new_name - Pointer to new filename string
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_RENAME, old_name, new_name, 0, 0)
  if result <> SUCCESS
    set_error(result)


PUB moveFile(name_ptr, dest_folder) : result
'' Move file to another directory (multi-cog safe).
''
'' @param name_ptr - Pointer to null-terminated filename to move
'' @param dest_folder - Pointer to null-terminated destination folder name
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_MOVEFILE, name_ptr, dest_folder, 0, 0)
  if result <> SUCCESS
    set_error(result)


PUB freeSpace() : result
'' Get free space in sectors (multi-cog safe).
'' This may take a while on large cards.
''
'' @returns result - Number of free sectors on the card

  if send_command(CMD_FREESPACE, 0, 0, 0, 0) == SUCCESS
    result := pb_data0


PUB setDate(year, month, day, hour, minute, second) : result
'' Set the current date and time for file timestamps.
'' Starts the auto-incrementing clock (CT1-based, 2-second tick).
''
'' @param year - Year (1980-2107)
'' @param month - Month (1-12)
'' @param day - Day (1-31)
'' @param hour - Hour (0-23)
'' @param minute - Minute (0-59)
'' @param second - Second (0-59)
'' @returns result - SUCCESS (0) or E_INVALID_PARAM

  if year < 1980 or year > 2107
    return set_error(E_INVALID_PARAM)
  if month < 1 or month > 12
    return set_error(E_INVALID_PARAM)
  if day < 1 or day > daysInMonth(year, month)
    return set_error(E_INVALID_PARAM)
  if hour > 23 or minute > 59 or second > 59
    return set_error(E_INVALID_PARAM)

  FIELD[fld_yr][0]  := year - FAT_EPOCH_YEAR
  FIELD[fld_mon][0] := month
  FIELD[fld_day][0] := day
  FIELD[fld_hr][0]  := hour
  FIELD[fld_min][0] := minute
  FIELD[fld_sec][0] := second >> 1
  ct_active := true
  ct_last_tick := getct()
  result := SUCCESS


PUB getDate() : year, month, day, hour, minute, second
'' Get the current date and time as the driver knows it.
'' Returns the live clock value maintained by the worker cog CT1 tick.
'' If setDate() was never called, returns the default timestamp.
''
'' @returns year - Year (e.g., 2026)
'' @returns month - Month (1-12)
'' @returns day - Day (1-31)
'' @returns hour - Hour (0-23)
'' @returns minute - Minute (0-59)
'' @returns second - Second (0-58, even values only)

  year   := FIELD[fld_yr][0] + FAT_EPOCH_YEAR
  month  := FIELD[fld_mon][0]
  day    := FIELD[fld_day][0]
  hour   := FIELD[fld_hr][0]
  minute := FIELD[fld_min][0]
  second := FIELD[fld_sec][0] << 1


#ifdef SD_INCLUDE_DEFRAG

CON ' ---- Defragmentation API ----

PUB fileFragments(p_path) : fragment_count
'' Count the number of non-contiguous fragments in a file's cluster chain.
'' A contiguous file returns 1. An empty file returns 0.
''
'' @param p_path - Pointer to null-terminated filename string
'' @returns fragment_count - Fragment count (1 = contiguous), 0 if empty, or negative error code

  fragment_count := send_command(CMD_FILE_FRAGMENTS, p_path, 0, 0, 0)
  if pb_status < 0
    set_error(pb_status)
    fragment_count := pb_status
  else
    fragment_count := pb_data0


PUB isFileContiguous(p_path) : result
'' Check if a file's clusters are stored contiguously on disk.
'' Convenience wrapper around fileFragments() (Decision #6).
''
'' @param p_path - Pointer to null-terminated filename string
'' @returns result - TRUE if contiguous (fragment_count == 1), FALSE otherwise, or negative error code

  result := fileFragments(p_path)
  if result >= 0
    result := (result == 1)


PUB createFileContiguous(p_path, file_size) : handle
'' Create a new file with a pre-allocated contiguous cluster chain.
'' The file's clusters are allocated upfront so writeHandle() never fragments.
'' If insufficient contiguous space exists, returns E_NO_CONTIGUOUS_SPACE.
''
'' @param p_path - Pointer to null-terminated filename string
'' @param file_size - Expected file size in bytes (determines cluster count)
'' @returns handle - Handle (0 to MAX_OPEN_FILES-1) on success, or negative error code

  handle := send_command(CMD_CREATE_CONTIGUOUS, p_path, file_size, 0, 0)
  if pb_status < 0
    set_error(pb_status)
    handle := pb_status
  else
    handle := pb_data0


PUB compactFile(p_path) : result
'' Relocate a file's clusters into a contiguous chain on disk.
'' The file must not be open (no active handles). If already contiguous, returns SUCCESS (no-op).
'' Uses copy-then-free strategy: file is always readable during compaction.
'' Read-back verification is performed after every copy (Decision #5).
''
'' @param p_path - Pointer to null-terminated filename string
'' @returns result - SUCCESS, E_FILE_NOT_FOUND, E_FILE_OPEN_FOR_COMPACT, E_NO_CONTIGUOUS_SPACE, E_VERIFY_FAILED, E_IO_ERROR

  result := send_command(CMD_COMPACT_FILE, p_path, 0, 0, 0)
  if pb_status < 0
    set_error(pb_status)
    result := pb_status
  else
    result := pb_status

#endif  ' SD_INCLUDE_DEFRAG


#ifdef SD_INCLUDE_ASYNC

CON ' ---- Non-Blocking File I/O ----
  {Spin2_Doc_CON}
  PENDING         = 1                   ' Returned by start*() to indicate operation launched
  E_ASYNC_BUSY    = -95                 ' An async operation is already in flight
  E_NO_ASYNC_OP   = -96                 ' No async operation to get result from

PUB startReadHandle(handle, p_buffer, count) : status
'' Begin an asynchronous read. Returns immediately with PENDING.
'' Caller must call isComplete()/getResult() to get the data.
'' The api_lock is held until getResult() or cancelAsync() is called.
''
'' @param handle - Valid read handle
'' @param p_buffer - Pointer to destination buffer
'' @param count - Number of bytes to read
'' @returns status - PENDING (1) on success, negative error on failure

  if async_active
    return set_error(E_ASYNC_BUSY)
  if cog_id == -1
    return set_error(E_NOT_MOUNTED)

  repeat until locktry(api_lock)

  pb_caller := COGID()
  pb_param0 := handle
  pb_param1 := p_buffer
  pb_param2 := count
  pb_cmd := CMD_READ_H

  async_active := true
  async_caller := COGID()
  status := PENDING


PUB startWriteHandle(handle, p_buffer, count) : status
'' Begin an asynchronous write. Returns immediately with PENDING.
'' Caller must call isComplete()/getResult() to get the result.
''
'' @param handle - Valid write handle
'' @param p_buffer - Pointer to source data
'' @param count - Number of bytes to write
'' @returns status - PENDING (1) on success, negative error on failure

  if async_active
    return set_error(E_ASYNC_BUSY)
  if cog_id == -1
    return set_error(E_NOT_MOUNTED)

  repeat until locktry(api_lock)

  pb_caller := COGID()
  pb_param0 := handle
  pb_param1 := p_buffer
  pb_param2 := count
  pb_cmd := CMD_WRITE_H

  async_active := true
  async_caller := COGID()
  status := PENDING


PUB isComplete() : done
'' Check if the current async operation has completed.
'' Does NOT release the lock or consume the result.
''
'' @returns done - TRUE if complete, FALSE if still in progress

  done := async_active and (pb_cmd == CMD_NONE)


PUB getResult() : result
'' Get the result of a completed async operation and release the lock.
'' After this call, new commands can be issued.
''
'' @returns result - Bytes read/written, or negative error code

  if not async_active
    return set_error(E_NO_ASYNC_OP)

  ' Wait for completion if not already done
  repeat until pb_cmd == CMD_NONE

  if pb_status < 0
    result := pb_status
    set_error(pb_status)
  else
    result := pb_data0

  async_active := false
  if POLLATN()                           ' Drain stale COGATN from worker completion
  lockrel(api_lock)


PUB cancelAsync() : result
'' Cancel a pending async operation and release the lock.
'' Waits for the worker to finish (cannot interrupt SPI mid-transfer),
'' then discards the result.
''
'' @returns result - SUCCESS

  if not async_active
    return set_error(E_NO_ASYNC_OP)

  repeat until pb_cmd == CMD_NONE

  async_active := false
  if POLLATN()                           ' Drain stale COGATN from worker completion
  lockrel(api_lock)
  result := SUCCESS

#endif  ' SD_INCLUDE_ASYNC

CON ' ---- Legacy ----

PUB fileName() : result | p_temp, idx
'' Return the 8.3 filename of the currently opened file.
''
'' @returns result - Pointer to filename string
' @local p_temp - Pointer to temporary filename buffer
' @local idx - Loop counter for parsing

  p_temp := @"filename.txt"
  bytemove(p_temp, @entry_buffer, SFN_TOTAL_LEN)
  idx := 0
  repeat until byte[p_temp + idx++] == " " or idx == 9
  bytemove(p_temp + idx,p_temp + 8,3)
  if attributes() & ATTR_DIRECTORY
    byte[p_temp + idx-1] := $00
  else
    byte[p_temp + idx-1] := "."
    byte[p_temp + idx+3] := $00
  result := p_temp


PUB fileSize() : result
'' Return the size of the currently opened file in bytes.
''
'' @returns result - File size from directory entry

  result := dirEntFileSize(@entry_buffer)


PUB attributes() : result
'' Return the attribute byte of the currently opened file.
''
'' @returns result - FAT attribute byte

  result := dirEntAttr(@entry_buffer)


PUB volumeLabel() : result
'' Return pointer to volume label string.
''
'' @returns result - Pointer to volume label (11 chars + null)

  result := @vol_label


PUB setVolumeLabel(p_label) : result
'' Set the volume label on the mounted SD card.
'' Updates both the BPB and root directory volume label entry.
''
'' @param p_label - Pointer to new volume label string (max 11 chars)
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_SET_VOL_LABEL, p_label, 0, 0, 0)
  if result <> SUCCESS
    set_error(result)


PUB syncDirCache()
'' Force directory cache invalidation - invalidates the directory sector cache.
'' The next read will re-fetch from card.
'' Use after file operations to ensure consistency when multiple files are accessed.
'' This is safe to call from any cog (just sets a DAT variable to -1).

  dir_sec_in_buf := -1


CON ' ---- Error / Diagnostic ----

PUB error() : status
'' Get last error for this cog - returns the error code from the most recent operation.
'' Thread-safe: each cog has its own error slot.
''
'' @returns status - Error code from the most recent operation on this cog

  status := LONG[@last_error][COGID()]


PUB cardWarnings() : warning_flags
'' Get card capability and advisory flags discovered during mount.
'' Returns bitmask of conditions probed at init time.
'' Check after mount() to learn what the card actually supports in SPI mode.
''
''   CW_CMD13_UNRELIABLE ($01) - CMD13 status checks disabled (broken SPI implementation)
''   CW_CMD23_SUPPORTED  ($02) - CMD23 SET_BLOCK_COUNT confirmed working in SPI mode
''
'' @returns warning_flags - Bitmask of CW_* constants (CW_NONE if no flags set)

  warning_flags := card_warning_flags


PUB checkStackGuard() : bIntact | idx
'' Verify worker cog stack guard is intact.
'' Returns TRUE if all guard bytes are $CC (no overflow detected).
'' Returns FALSE and reports via debug if any guard byte is corrupted.
''
'' @returns bIntact - TRUE if stack guard is intact, FALSE if overflow detected

  bIntact := true
  repeat idx from 0 to (STACK_GUARD_LONGS * 4) - 1
    if BYTE[@cog_stack_guard][idx] <> STACK_GUARD_BYTE
      bIntact := false
      debug[CH_API]("  STACK GUARD VIOLATION at offset ", udec_(idx), ": $", uhex_byte_(BYTE[@cog_stack_guard][idx]), " (expected $CC)")
      quit


#ifdef SD_INCLUDE_STACK_CHECK

PUB reportStackDepth() : depth
'' DIAG: Ask worker cog to report stack depth used (high-water mark).
'' Returns the number of stack longs used. Compare against STACK_SIZE.
'' Returns -1 if the command failed (e.g., worker not running).
''
'' @returns depth - Number of longs used (high-water mark), or -1 on failure

  if send_command(CMD_STACK_DEPTH, 0, 0, 0, 0) == SUCCESS
    depth := pb_data0
  else
    depth := -1

#endif

CON ' ---- Raw Sector Access [SD_INCLUDE_RAW] ----

#ifdef SD_INCLUDE_RAW

PUB initCardOnly(_cs, _mosi, _miso, _sck) : result
'' Initialize SD card without mounting filesystem - for raw sector access.
'' Use this for low-level operations like formatting. Does NOT read filesystem.
'' Starts worker cog and initializes card for raw sector access (MODE_RAW).
''
'' @param _cs - Chip select pin number
'' @param _mosi - Master Out Slave In pin number
'' @param _miso - Master In Slave Out pin number
'' @param _sck - Serial clock pin number
'' @returns result - SUCCESS (0) on success, negative error code on failure

  debug[CH_INIT]("  [initCardOnly] Pins: CS=P", udec_(_cs), " MOSI=P", udec_(_mosi), " MISO=P", udec_(_miso), " SCK=P", udec_(_sck))

  ' Check if already in filesystem mode - reject (must unmount first)
  if driver_mode == MODE_FILESYSTEM
    debug[CH_INIT]("  [initCardOnly] REJECTED: Already mounted as filesystem, unmount first")
    result := E_NOT_MOUNTED
  elseif driver_mode == MODE_RAW
    ' Already in raw mode - already initialized
    debug[CH_INIT]("  [initCardOnly] Already initialized in raw mode")
    result := SUCCESS
  else
    ' Start worker cog if not already running
    if cog_id == -1
      if start(_cs, _mosi, _miso, _sck) == -1
        debug[CH_INIT]("  [initCardOnly] FAIL: Could not start worker cog")
        result := E_NO_LOCK
    ' Send init command to worker (only if cog started OK)
    if result == 0
      result := send_command(CMD_INIT_CARD_ONLY, 0, 0, 0, 0)
      if result == SUCCESS
        debug[CH_INIT]("  [initCardOnly] Card initialized successfully via worker")
      else
        debug[CH_INIT]("  [initCardOnly] Card initialization failed, error=", sdec_(result))
        set_error(result)


PUB cardSizeSectors() : result
'' Get total sectors on card via worker cog.
'' Must call initCardOnly() or mount() first.
''
'' @returns result - Total number of 512-byte sectors on the card

  if cog_id == -1
    debug[CH_API]("  [cardSizeSectors] ERROR: Worker not running")
  else
    send_command(CMD_GET_CARD_SIZE, 0, 0, 0, 0)
    result := pb_data0
    debug[CH_API]("  [cardSizeSectors] ", udec(result), " sectors")


PUB testCMD13() : r2_response | r1, status
'' TEST ONLY: Send CMD13 and return raw R2 response.
'' Routes through worker cog which owns the SPI pins.
'' NOTE: This is a diagnostic method - not for normal operation.
''
'' @returns r2_response - R2 response word ($0000=OK, $FFFF=timeout, other=error)
' @local r1 - R1 response byte (decoded from R2 for debug output)
' @local status - Status byte (decoded from R2 for debug output)

  if cog_id == -1
    r2_response := $FFFF
  else
    send_command(CMD_TEST_CMD13, 0, 0, 0, 0)
    r2_response := pb_data0

    ' Decode R1 and status bytes for debug output
    r1 := r2_response >> 8
    status := r2_response & $FF

    ' Log detailed results
    debug[CH_STATUS]("  [testCMD13] R1=$", uhex_byte_(r1), " STATUS=$", uhex_byte_(status), " -> R2=$", uhex_word_(r2_response))
    if r1 <> 0
      debug[CH_STATUS]("    R1 errors:")
      if r1 & $40
        debug[CH_STATUS]("      -> PARAMETER_ERROR")
      if r1 & $20
        debug[CH_STATUS]("      -> ADDRESS_ERROR")
      if r1 & $10
        debug[CH_STATUS]("      -> ERASE_SEQ_ERROR")
      if r1 & $08
        debug[CH_STATUS]("      -> COM_CRC_ERROR")
      if r1 & $04
        debug[CH_STATUS]("      -> ILLEGAL_COMMAND")
      if r1 & $02
        debug[CH_STATUS]("      -> ERASE_RESET")
      if r1 & $01
        debug[CH_STATUS]("      -> IN_IDLE_STATE")
    if status <> 0
      debug[CH_STATUS]("    STATUS errors:")
      if status & CSR_OUT_OF_RANGE
        debug[CH_STATUS]("      -> OUT_OF_RANGE")
      if status & CSR_ERASE_PARAM
        debug[CH_STATUS]("      -> ERASE_PARAM")
      if status & CSR_WP_VIOLATION
        debug[CH_STATUS]("      -> WP_VIOLATION")
      if status & CSR_CARD_ECC_FAILED
        debug[CH_STATUS]("      -> CARD_ECC_FAILED")
      if status & CSR_CC_ERROR
        debug[CH_STATUS]("      -> CC_ERROR")
      if status & CSR_ERROR
        debug[CH_STATUS]("      -> ERROR")
      if status & CSR_WP_ERASE_SKIP
        debug[CH_STATUS]("      -> WP_ERASE_SKIP")
      if status & CSR_CARD_IS_LOCKED
        debug[CH_STATUS]("      -> CARD_IS_LOCKED")


PUB readSectorRaw(sector, p_buffer) : result
'' Read a sector at absolute LBA address - low-level for verification.
'' Bypasses filesystem. Requires initCardOnly() or mount() first.
''
'' @param sector - Absolute LBA sector number
'' @param p_buffer - Pointer to 512-byte buffer to receive data
'' @returns result - SUCCESS (0) on success, negative error code on failure

  ' Require worker cog to be running (no direct access allowed)
  if cog_id == -1
    debug[CH_SECTOR]("  [readSectorRaw] ERROR: Worker not running - call initCardOnly() or mount() first")
    result := E_NOT_MOUNTED
  else
    result := send_command(CMD_READ_SECTOR_RAW, sector, p_buffer, 0, 0)
    if result <> SUCCESS
      set_error(result)
    debug[CH_SECTOR]("  [readSectorRaw] Read sector ", udec(sector))


PUB writeSectorRaw(sector, p_buffer) : result
'' Write a sector at absolute LBA address - low-level for formatting/partitioning.
'' Bypasses filesystem. Requires initCardOnly() or mount() first.
''
'' @param sector - Absolute LBA sector number
'' @param p_buffer - Pointer to 512 bytes of data to write
'' @returns result - SUCCESS (0) on success, negative error code on failure

  ' Require worker cog to be running (no direct access allowed)
  if cog_id == -1
    debug[CH_SECTOR]("  [writeSectorRaw] ERROR: Worker not running - call initCardOnly() or mount() first")
    result := E_NOT_MOUNTED
  else
    result := send_command(CMD_WRITE_SECTOR_RAW, sector, p_buffer, 0, 0)
    if result == SUCCESS
      debug[CH_SECTOR]("  [writeSectorRaw] Wrote sector ", udec(sector))
    else
      debug[CH_SECTOR]("  [writeSectorRaw] FAILED to write sector ", udec(sector))
      set_error(result)


PUB readSectorsRaw(start_sector, count, p_buffer) : result
'' Read multiple consecutive sectors - multi-block read using CMD18.
'' More efficient than calling readSectorRaw() in a loop.
''
'' @param start_sector - First sector to read (absolute LBA)
'' @param count - Number of sectors to read
'' @param p_buffer - Pointer to buffer (must be count * 512 bytes)
'' @returns result - Number of sectors successfully read

  if send_command(CMD_READ_SECTORS, start_sector, count, p_buffer, 0) == SUCCESS
    result := pb_data0
  else
    result := 0


PUB writeSectorsRaw(start_sector, count, p_buffer) : result
'' Write multiple consecutive sectors - multi-block write using CMD25.
'' More efficient than calling writeSectorRaw() in a loop.
''
'' @param start_sector - First sector to write (absolute LBA)
'' @param count - Number of sectors to write
'' @param p_buffer - Pointer to buffer with data (must be count * 512 bytes)
'' @returns result - Number of sectors successfully written

  if send_command(CMD_WRITE_SECTORS, start_sector, count, p_buffer, 0) == SUCCESS
    result := pb_data0
  else
    result := 0


PUB readVBRRaw(p_buf) : result
'' Read Volume Boot Record (512 bytes) into buffer.
'' Routes through worker cog which owns the SPI pins.
'' Card must be mounted for this method to work (VBR location determined at mount).
''
'' @param p_buf - Pointer to 512-byte buffer to receive VBR data
'' @returns result - SUCCESS (0) on success, negative error code on failure

  if not (flags & F_MOUNTED)
    debug[CH_SECTOR]("  [readVBRRaw] FAILED: Card not mounted")
    result := E_NOT_MOUNTED
  else
    result := send_command(CMD_READ_SECTOR_RAW, vbr_sec, p_buf, 0, 0)
    if result <> SUCCESS
      set_error(result)

#endif


CON ' ---- Card Registers [SD_INCLUDE_REGISTERS] ----

#ifdef SD_INCLUDE_REGISTERS

PUB readCIDRaw(p_buf) : result
'' Read CID register (16 bytes) into buffer.
'' Contains manufacturer ID, product name, serial number, and manufacturing date.
'' Routes through worker cog which owns the SPI pins.
''
'' @param p_buf - Pointer to 16-byte buffer to receive CID data
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_READ_CID, p_buf, 0, 0, 0)
  if result == SUCCESS
    debug[CH_IDENT]("  [readCIDRaw] CID read successfully")
  else
    debug[CH_IDENT]("  [readCIDRaw] CID read FAILED")
    set_error(result)


PUB readCSDRaw(p_buf) : result
'' Read CSD register (16 bytes) into buffer.
'' Contains card capacity, speed, and features.
'' Routes through worker cog which owns the SPI pins.
''
'' @param p_buf - Pointer to 16-byte buffer to receive CSD data
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_READ_CSD, p_buf, 0, 0, 0)
  if result == SUCCESS
    debug[CH_IDENT]("  [readCSDRaw] CSD read successfully")
  else
    debug[CH_IDENT]("  [readCSDRaw] CSD read FAILED")
    set_error(result)


PUB readSCRRaw(p_buf) : result
'' Read SCR register (8 bytes) into buffer.
'' Contains SD spec version and bus widths.
'' Routes through worker cog which owns the SPI pins.
''
'' @param p_buf - Pointer to 8-byte buffer to receive SCR data
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_READ_SCR, p_buf, 0, 0, 0)
  if result == SUCCESS
    debug[CH_IDENT]("  [readSCRRaw] SCR read successfully")
  else
    debug[CH_IDENT]("  [readSCRRaw] SCR read FAILED")
    set_error(result)


PUB readSDStatusRaw(p_buf) : result
'' Read SD Status register (ACMD13) - returns 64 bytes of card status.
'' Contains Speed Class, UHS Speed Grade, Video Speed Class, and more.
''
'' @param p_buf - Pointer to 64-byte buffer to receive SD Status data
'' @returns result - SUCCESS (0) on success, negative error code on failure

  result := send_command(CMD_READ_SD_STATUS, p_buf, 0, 0, 0)
  if result == SUCCESS
    debug[CH_IDENT]("  [readSDStatusRaw] SD Status read successfully")
  else
    debug[CH_IDENT]("  [readSDStatusRaw] SD Status read FAILED")
    set_error(result)


PUB getOCR() : ocr
'' Get cached OCR register value - Operating Conditions Register from card init.
'' Contains card capacity status (CCS) and voltage range.
''
'' @returns ocr - 32-bit OCR value, or 0 if card not initialized

  ocr := ocr_value
  debug[CH_IDENT]("  [getOCR] OCR = $", uhex_long(ocr))

#endif


CON ' ---- Speed Control [SD_INCLUDE_SPEED] + Card Info ----

#ifdef SD_INCLUDE_SPEED

PUB attemptHighSpeed() : hs_ok
'' Attempt to enable 50 MHz high-speed mode with verification.
'' Routes through worker cog which owns the SPI pins.
'' Queries capability, switches mode, verifies with sector read/write.
'' Safe to call - will not break operation on failure.
''
'' @returns hs_ok - TRUE if 50 MHz active, FALSE if fell back to 25 MHz

  if cog_id <> -1
    send_command(CMD_ATTEMPT_HIGH_SPEED, 0, 0, 0, 0)
    hs_ok := pb_data0


PUB checkCMD6Support() : supported | scr[2], sd_spec
'' Check if card supports CMD6 command - reads SCR for SD spec version.
'' CMD6 supported by SD 2.0 and later cards (SD_SPEC >= 2).
''
'' @returns supported - TRUE if CMD6 is available
' @local scr - SCR register data (2 longs = 8 bytes)
' @local sd_spec - SD spec version from SCR

  if readSCRRaw(@scr) < 0
    debug[CH_HSPEED]("  [checkCMD6Support] Failed to read SCR")
  else
    sd_spec := scr.byte[0] & $0F                                                '  SD_SPEC in bits [3:0]
    debug[CH_HSPEED]("  [checkCMD6Support] SCR: $", uhex_byte_(scr.byte[0]), " $", uhex_byte_(scr.byte[1]), " SD_SPEC=", udec_(sd_spec))
    supported := sd_spec >= 2                                                    '  CMD6 supported in SD 2.0+


PUB checkHighSpeedCapability() : capable
'' Check if card reports high-speed capability - queries function group 1.
'' Routes through worker cog which owns the SPI pins.
'' Uses CMD6 mode 0 (check without switch).
'' Requires CMD6 support - call checkCMD6Support() first.
''
'' @returns capable - TRUE if high-speed function is supported

  if cog_id <> -1
    send_command(CMD_CHECK_HS_CAPABILITY, 0, 0, 0, 0)
    capable := pb_data0


PUB setSPISpeed(freq) : actual_hz
'' Set SPI clock frequency. Routes through worker cog which owns the SPI pins.
'' Frequency is rounded to nearest achievable value based on P2 clock divider.
''
'' @param freq - Target SPI frequency in Hz
'' @returns actual_hz - Actual frequency achieved (may differ due to divider rounding)

  if cog_id <> -1
    send_command(CMD_SET_SPI_SPEED, freq, 0, 0, 0)
    actual_hz := pb_data0

#endif


PUB getSPIFrequency() : hz
'' Get current SPI clock frequency in Hz.
''
'' @returns hz - Current SPI clock frequency in Hz

  hz := spi_freq


PUB getCardMaxSpeed() : hz
'' Get card's reported maximum speed from CSD TRAN_SPEED field.
''
'' @returns hz - Card's maximum speed in Hz

  hz := card_max_speed_hz


PUB getManufacturerID() : mid
'' Get card manufacturer ID (MID) from CID register.
'' Common IDs: $03=SanDisk, $1D=PNY/AData, $27=Samsung.
''
'' @returns mid - Manufacturer ID byte

  mid := card_mfr_id


PUB getReadTimeout() : ms
'' Get read timeout from CSD register in milliseconds.
'' SDHC/SDXC: Fixed 100ms per spec. SDSC: Calculated from TAAC/NSAC.
''
'' @returns ms - Read timeout in milliseconds

  ms := card_read_timeout_ms


PUB getWriteTimeout() : ms
'' Get write timeout from CSD register in milliseconds.
'' SDHC/SDXC: Fixed 250ms per spec. SDSC: Read timeout * R2W_FACTOR.
''
'' @returns ms - Write timeout in milliseconds

  ms := card_write_timeout_ms


PUB isHighSpeedActive() : active
'' Check if high-speed mode is active (running at 50 MHz).
''
'' @returns active - TRUE if running at 50 MHz or higher

  active := spi_freq >= 50_000_000


CON ' ---- Debug / Diagnostics [SD_INCLUDE_DEBUG] ----

#ifdef SD_INCLUDE_DEBUG

PUB getWriteDiag() : result_code, r1_resp, data_resp, sector_num
'' Get diagnostic info from last writeSector call.
'' Codes: 0=not called, 1=CMD24 fatal, 2=data-response timeout,
''        3=data CRC reject, 4=data write-err, 5=data unknown reject,
''        6=busy timeout, 7=success
''
'' @returns result_code - Outcome code
'' @returns r1_resp - CMD24 R1 response byte
'' @returns data_resp - Data response token
'' @returns sector_num - Sector number attempted

  result_code := diag_write_result
  r1_resp := diag_write_r1
  data_resp := diag_write_dresp
  sector_num := diag_write_sector


PUB getLastCMD13() : r2
'' Get last CMD13 result (R1 in high byte, STATUS in low byte).
'' Value is from most recent CMD13, regardless of success/failure.
''
'' @returns r2 - Combined R2 response word

  r2 := (last_cmd13_r1 << 8) | last_cmd13_status


PUB getLastCMD13Error() : r2
'' Get last CMD13 error - returns last non-zero CMD13 result (preserved until next error).
'' Useful for diagnostics - shows most recent error even after recovery.
''
'' @returns r2 - Last non-zero R2 response word

  r2 := last_cmd13_error


PUB getLastCMD13Capture(p_dest) : count
'' Copy CMD13 raw byte stream capture to caller's buffer.
'' Returns NCR gap length (position of first non-$FF byte).
'' Buffer contains: NCR gap $FF bytes, R1 byte, STATUS byte, extra bytes.
'' Caller must provide an 8-byte buffer.
''
'' @param p_dest - Pointer to 8-byte destination buffer
'' @returns count - NCR gap length (position of first non-$FF byte)

  bytemove(p_dest, @cmd13_capture, 8)
  count := cmd13_capture_len


PUB getLastCMD13PreCapture(p_dest)
'' Copy the 7 MISO bytes received DURING CMD13 command transmission (full-duplex capture).
'' These bytes reveal what the card was outputting while we were sending CMD13.
'' If any byte is not $FF, the card was still active (e.g., streaming data from a
'' previous operation that didn't fully terminate).
'' Caller must provide a 7-byte buffer.
''
'' @param p_dest - Pointer to 7-byte destination buffer

  bytemove(p_dest, @cmd13_pre_capture, 7)


PUB setForceCmd13(enabled)
'' Force CMD13 status checks even on cards flagged as unreliable.
'' Diagnostic use only: overrides the cmd13_reliable flag so checkCardStatus()
'' always sends CMD13. Use this to capture CMD13 byte streams on problem cards.
'' Set to FALSE (or call clearTestErrors()) to restore normal behavior.
''
'' @param enabled - TRUE to force CMD13, FALSE to respect probe result

  test_force_cmd13 := (enabled <> 0) ? TRUE : FALSE


PUB getLastCMD18R1() : r1
'' Get last CMD18 R1 response - returns the R1 byte from the most recent CMD18 (READ_MULTIPLE_BLOCK).
'' $00 = accepted, non-zero = rejected (see R1 bit definitions).
''
'' @returns r1 - R1 response byte from last CMD18

  r1 := last_cmd18_r1


PUB getLastCMD18Token() : token
'' Get last data token from CMD18 - returns the token byte from the most recent waitDataToken().
'' $FE = success (data start), $01-$0F = error tokens, $FF = no token received (timeout).
''
'' @returns token - Token byte from last CMD18 data wait

  token := last_cmd18_token


PUB getLastCMD18Result() : code
'' Get last CMD18 outcome code - indicates which failure path was taken.
'' 0 = success (got $FE), 1 = timeout (never got non-$FF), 2 = error token received.
''
'' @returns code - Outcome code (0=ok, 1=timeout, 2=error token)

  code := last_cmd18_result


PUB getLastCMD18FailPath() : path
'' Get last CMD18 failure path - indicates where readSectors() failed.
'' 0 = no failure, 1 = R1 reject, 2 = data token fail, 3 = CMD12 fail, 4 = CMD13 fail.
''
'' @returns path - Failure path code

  path := last_cmd18_fail


PUB getLastCMD18SectorsRead() : count
'' Get sectors successfully read in last CMD18 operation before any post-read failure.
''
'' @returns count - Number of sectors read

  count := last_cmd18_sread


PUB getLastCMD12R1() : r1
'' Get last CMD12 R1 response - returns the R1 byte from the most recent sendStopTransmission().
''
'' @returns r1 - R1 response byte (negative if timeout)

  r1 := last_cmd12_r1


PUB getLastCMD12Result() : code
'' Get last CMD12 outcome - 0=ok, 1=R1 timeout, 2=R1 error bits, 3=busy timeout.
''
'' @returns code - Outcome code

  code := last_cmd12_busy


PUB getLastCMD12Capture(p_dest) : count
'' Copy CMD12 raw byte stream capture to caller's buffer.
'' Returns count of bytes before first non-$FF (NCR gap length).
'' Buffer is 16 bytes: pre-R1 $FF padding, R1 byte, post-R1 bytes.
'' Caller must provide a 16-byte buffer.
''
'' @param p_dest - Pointer to 16-byte destination buffer
'' @returns count - Position of first non-$FF byte (NCR gap length)

  bytemove(p_dest, @cmd12_capture, 16)
  count := cmd12_capture_len

PUB getLastCMD12PreCapture(p_dest)
'' Copy the 7 MISO bytes received DURING CMD12 command transmission (full-duplex capture).
'' These bytes reveal what the card was outputting while we were sending CMD12.
'' If byte[0] is $FE, the card was already streaming the next data token.
'' Caller must provide a 7-byte buffer.
''
'' @param p_dest - Pointer to 7-byte destination buffer

  bytemove(p_dest, @cmd12_pre_capture, 7)

PUB getLastCMD23Used() : used
'' Get whether CMD23 path was used for the last multi-block read.
''
'' @returns used - TRUE if CMD23 was sent before CMD18, FALSE if CMD12 path was used

  used := last_cmd23_used

PUB getLastCMD23R1() : r1
'' Get R1 response from last CMD23. Returns $FF if CMD23 was not sent.
''
'' @returns r1 - R1 response byte from CMD23 ($00=accepted, $FF=not sent)

  r1 := last_cmd23_r1

PUB getLastCMD23Verify() : verify_byte
'' Get the post-read verification byte from CMD23 path.
'' After reading the last sector, one extra byte is clocked.
'' $FF means card stopped (auto-stop honored). Any other value means card was still streaming.
''
'' @returns verify_byte - MISO byte after last sector's CRC ($FF=stopped, other=still streaming)

  verify_byte := last_cmd23_verify

PUB getCmd23Supported() : supported
'' Get whether the current card supports CMD23 (SET_BLOCK_COUNT).
'' Determined from SCR CMD_SUPPORT field during init.
''
'' @returns supported - TRUE if CMD23 is available

  supported := cmd23_supported


PUB getLastReceivedCRC() : crc
'' Get CRC-16 from last sector read - returns the 16-bit CRC received from the SD card
'' after the most recent sector read operation. Use for validating CRC algorithm.
''
'' @returns crc - 16-bit CRC the card calculated and sent

  crc := diag_recv_crc


PUB getLastCalculatedCRC() : crc
'' Get CRC-16 calculated from data - returns the 16-bit CRC we calculated from received data.
'' Should match getLastReceivedCRC() if data transfer was clean.
''
'' @returns crc - 16-bit CRC calculated from data

  crc := diag_calc_crc


PUB getLastSentCRC() : crc
'' Get CRC-16 sent with last write - returns the 16-bit CRC we calculated and sent.
''
'' @returns crc - 16-bit CRC sent with the last write operation

  crc := diag_sent_crc


PUB getCRCMatchCount() : count
'' Get count of CRC matches - returns number of sector reads where CRC matched.
''
'' @returns count - Number of sector reads where calculated CRC matched received CRC

  count := diag_crc_matches


PUB getCRCMismatchCount() : count
'' Get count of CRC mismatches - returns number of sector reads where CRC did NOT match.
'' Non-zero indicates data corruption occurred during transfer.
''
'' @returns count - Number of sector reads where CRC did not match

  count := diag_crc_mismatches


PUB getCRCRetryCount() : count
'' Get count of CRC retry attempts - returns total number of read retries triggered by CRC mismatches.
'' Non-zero indicates transient bus errors were recovered.
''
'' @returns count - Total CRC retry attempts across all sector reads

  count := diag_crc_retries


PUB setCRCValidation(enabled)
'' Enable/disable CRC validation for sector reads.
'' When enabled, each sector read validates CRC and updates match/mismatch counts.
''
'' @param enabled - TRUE (non-zero) enables CRC checking, FALSE (0) disables

  diag_crc_enabled := (enabled <> 0) ? 1 : 0


PUB setTestForceReadError(count)
'' Set CRC error injection counter for reads. Each sector read will see a
'' forced CRC mismatch until the counter reaches zero.
'' Set to 1: one retry then success. Set to MAX_READ_CRC_RETRIES (3): all retries fail.
''
'' @param count - Number of read CRC mismatches to force

  test_force_read_crc_error := count


PUB setTestForceWriteError(enabled)
'' Arm one-shot CRC error injection for the next write. The next writeSector()
'' will send a corrupted CRC, causing the card to reject the data.
''
'' @param enabled - Non-zero arms, zero disarms

  test_force_write_crc_error := (enabled <> 0) ? 1 : 0


PUB getTestErrorCount() : count
'' Get count of injected test errors triggered since last clear.
''
'' @returns count - Number of injected errors triggered

  count := test_error_count


PUB setTestMaxClusters(maxClusters)
'' Set artificial cluster limit for disk-full testing. When non-zero,
'' allocateCluster() will fail once the cluster number reaches this limit.
'' Set to 0 to disable (normal operation).
''
'' @param maxClusters - Maximum cluster number (0 = no limit)

  test_max_clusters := maxClusters


PUB clearTestErrors()
'' Reset all test error injection state. Disarms read/write hooks,
'' zeroes the triggered error counter, and clears diagnostic overrides.

  test_force_read_crc_error := 0
  test_force_write_crc_error := 0
  test_error_count := 0
  test_force_cmd13 := FALSE
  test_max_clusters := 0


PUB debugGetRootSec() : result
'' DEBUG: Return root_sec for diagnostic.
''
'' @returns result - Root directory sector number

  result := root_sec


PUB debugGetDirSec() : result
'' DEBUG: Return calling cog's current directory sector for diagnostic.
''
'' @returns result - Current directory sector number for calling cog

  result := cog_dir_sec[COGID()]


PUB debugGetVbrSec() : result
'' DEBUG: Return VBR sector for diagnostic.
''
'' @returns result - Volume Boot Record sector number

  result := vbr_sec


PUB debugGetFatSec() : result
'' DEBUG: Return FAT sector for diagnostic.
''
'' @returns result - FAT start sector number

  result := fat_sec


PUB debugGetSecPerFat() : result
'' DEBUG: Return sectors per FAT for diagnostic.
''
'' @returns result - Number of sectors per FAT

  result := sec_per_fat


PUB debugClearRootDir() : result
'' DEBUG: Clear root directory (fixes corruption).
'' Clears the root directory by writing zeros to root_sec.
'' Use this to fix a corrupted root directory.
'' WARNING: This DELETES all files and folders!
''
'' @returns result - 0 on success, -1 on error

  result := send_command(CMD_DEBUG_CLEAR_ROOT, 0, 0, 0, 0)


PUB debugReadSectorSlow(sector, p_buffer) : result
'' DEBUG: Read sector byte-by-byte (no streamer) - for comparison with streamer.
'' This is SLOW but useful for debugging streamer issues.
'' Requires worker cog to be running (SPI pins configured).
''
'' NOTE: This runs in Cog0 and requires SPI smart pins to be configured for this cog.
''       It will NOT work with the normal V3 driver architecture.
''       This is for DIAGNOSTIC USE ONLY.
''
'' @param sector - Sector number to read
'' @param p_buffer - Pointer to 512-byte destination buffer
'' @returns result - 0 on success, -1 on timeout/error
  result := send_command(CMD_DEBUG_SLOW_READ, sector, p_buffer, 0, 0)


PUB debugGetReadSectorDiag(p_sector, p_buftype, p_token, p_b0, p_b1, p_b2, p_b3, p_pbuf)
'' DEBUG: Get readSector diagnostic data - copies diagnostic data from last readSector call.
'' Call this after readSectorRaw() to see what happened inside readSector.
''
'' @param p_sector - Pointer to receive last sector number
'' @param p_buftype - Pointer to receive last buffer type
'' @param p_token - Pointer to receive last token ($FE on success)
'' @param p_b0 - Pointer to receive buffer byte 0
'' @param p_b1 - Pointer to receive buffer byte 1
'' @param p_b2 - Pointer to receive buffer byte 2
'' @param p_b3 - Pointer to receive buffer byte 3
'' @param p_pbuf - Pointer to receive buffer pointer

  long[p_sector] := diag_last_sector
  long[p_buftype] := diag_last_buftype
  long[p_token] := diag_last_token
  long[p_b0] := diag_buf_byte0
  long[p_b1] := diag_buf_byte1
  long[p_b2] := diag_buf_byte2
  long[p_b3] := diag_buf_byte3
  long[p_pbuf] := diag_p_buf


PUB debugGetReadSectorDiagExt(p_before0, p_before1, p_before2, p_before3, p_spi_period)
'' DEBUG: Get extended readSector diagnostic data - buffer state BEFORE streamer and SPI timing.
''
'' @param p_before0 - Pointer to receive buffer byte 0 before streamer
'' @param p_before1 - Pointer to receive buffer byte 1 before streamer
'' @param p_before2 - Pointer to receive buffer byte 2 before streamer
'' @param p_before3 - Pointer to receive buffer byte 3 before streamer
'' @param p_spi_period - Pointer to receive SPI period value

  long[p_before0] := diag_before_b0
  long[p_before1] := diag_before_b1
  long[p_before2] := diag_before_b2
  long[p_before3] := diag_before_b3
  long[p_spi_period] := diag_spi_period


PUB debugDumpRootDir() | sec, idx, p_entry, local_buf[128]
'' DEBUG: Dump root directory entries to debug output.
'' Routes through worker cog which owns the SPI pins.
'' This is a diagnostic function for debugging. It reads the root directory
'' and prints each entry's first 11 bytes (filename) and first cluster.
'' Called from test cog so output appears in headless logs.
''
' @local sec - Current sector being read
' @local idx - Entry index counter
' @local p_entry - Pointer to current directory entry
' @local local_buf - Local 512-byte buffer for sector data

  sec := root_sec
  debug[CH_DIR]("  [debugDumpRootDir] root_sec=", udec_(sec), " cog_dir_sec=", udec_(cog_dir_sec[COGID()]))
  if send_command(CMD_READ_SECTOR_RAW, sec, @local_buf, 0, 0) <> SUCCESS
    debug[CH_DIR]("  [debugDumpRootDir] FAILED to read root directory sector")
  else
    debug[CH_DIR]("  [debugDumpRootDir] Read sector ", udec_(sec), " into local buffer")
    repeat idx from 0 to DIR_ENTRIES_PER_SECTOR - 1                              ' First 16 entries
      p_entry := @local_buf + (idx * DIR_ENTRY_SIZE)
      if byte[p_entry] == 0
        debug[CH_DIR]("  Entry ", udec_(idx), ": [END OF DIR]")
        quit
      elseif byte[p_entry] == DIR_ENTRY_DELETED
        debug[CH_DIR]("  Entry ", udec_(idx), ": [DELETED]")
      else
        debug[CH_DIR]("  Entry ", udec_(idx), ": [", lstr_(p_entry, 11), "] attr=$", uhex_byte_(byte[p_entry+11]), " clus=", udec_(word[p_entry+26] | (word[p_entry+20] << 16)))


PUB displaySector() | address, char, ascii_ptr, idx
'' Display sector in buffer - prints hex dump with ASCII representation.
''
' @local address - Current byte offset in buffer
' @local char - Current character being processed
' @local ascii_ptr - Pointer to ASCII representation string
' @local idx - Loop counter

  ascii_ptr := string("0123456789ABCDEF")
  repeat address from 0 to 495 step 16
    repeat idx from 0 to 15
      case char := (buf[address + idx])
        $20..$7E: byte[ascii_ptr + idx] := char
        other:
          if char == 0
            byte[ascii_ptr + idx] := "."
          else
            byte[ascii_ptr + idx] := char // 26 + "a"
    debug[CH_SECTOR](uhex_word_(address),uhex_byte_array_(@buf + address,8),"-",uhex_byte_array_(@buf + address + 8,8)," | ",lstr_(ascii_ptr,16))


PUB displayEntry() | address, char, ascii_ptr, idx
'' Display directory entry - prints hex dump of entry_buffer with ASCII representation.
''
' @local address - Current byte offset in entry
' @local char - Current character being processed
' @local ascii_ptr - Pointer to ASCII representation string
' @local idx - Loop counter

  ascii_ptr := string("0123456789ABCDEF")
  repeat address from 0 to 31 step 16
    repeat idx from 0 to 15
      case char := (BYTE[@entry_buffer][address + idx])
        $20..$7E: byte[ascii_ptr + idx] := char
        other:
          if char == 0
            byte[ascii_ptr + idx] := "."
          else
            byte[ascii_ptr + idx] := char // 26 + "a"
    debug[CH_RECOVER](uhex_word_(address),uhex_byte_array_(@entry_buffer + address,8),"-",uhex_byte_array_(@entry_buffer + address + 8,8)," | ",lstr_(ascii_ptr,16))


PUB displayFAT(cluster) | fat_sector, local_buf[128]
'' Display FAT sector containing cluster number - reads and displays FAT entries.
'' Routes through worker cog which owns the SPI pins.
''
'' @param cluster - Cluster number to display FAT sector for
' @local fat_sector - Computed FAT sector number
' @local local_buf - Local 512-byte buffer for sector data

  fat_sector := fat_sec + cluster >> 7
  if send_command(CMD_READ_SECTOR_RAW, fat_sector, @local_buf, 0, 0) <> SUCCESS
    debug[CH_SECTOR]("  [displayFAT] Read FAILED for sector ", udec_(fat_sector))
  else
    bytemove(@buf, @local_buf, SECTOR_SIZE)                                      ' Copy to buf for displaySector()
    displaySector()

#endif


CON ' ---- Worker Infrastructure ----

PRI set_error(error_code) : code_out
' Set error code for this cog - store error code in per-cog slot and return the code.
'
' @param error_code - Error code to store
' @returns code_out - The same error code (for chained returns)

  LONG[@last_error][COGID()] := error_code
  code_out := error_code


PRI fs_worker() | cur_cmd
' Worker cog main loop - runs in the dedicated worker cog.
' Owns the SPI pins and handles all filesystem operations.
'
' @local cur_cmd - Current command being processed

  debug[CH_API]("  [fs_worker] Starting on cog ", udec_(COGID()))

  ' Initialize SPI pins (this cog owns them)
  pinh(cs)                                                                      ' CS HIGH = deselected
  pinh(mosi)                                                                    ' MOSI HIGH idle
  pinl(sck)                                                                     ' SCK LOW (SPI mode 0)

  debug[CH_API]("  [fs_worker] Pins initialized: CS=P", udec_(cs), " MOSI=P", udec_(mosi), " MISO=P", udec_(miso), " SCK=P", udec_(sck))

  ' Initialize FIELD pointers for direct date_stamp access
  fld_yr  := ^@date_stamp.[31..25]
  fld_mon := ^@date_stamp.[24..21]
  fld_day := ^@date_stamp.[20..16]
  fld_hr  := ^@date_stamp.[15..11]
  fld_min := ^@date_stamp.[10..5]
  fld_sec := ^@date_stamp.[4..0]

  ' Main command loop (structured: clock tick, command dispatch, idle flush)
  idle_timer := getct()
  flush_done := true

  repeat
    ' --- Filesystem command (Priority 1) ---
    repeat until (cur_cmd := pb_cmd) <> CMD_NONE
      ' --- Clock tick (F2: 2-second live timestamp) ---
      if ct_active
        if (getct() - ct_last_tick) >= ct_tick_clocks
          tick_clock()
          ct_last_tick := getct()

      ' --- Auto-flush (F3: flush dirty handles after 200ms idle) ---
      if not flush_done
        if (getct() - idle_timer) >= idle_flush_clocks
          do_idle_flush()

#ifdef SD_INCLUDE_STACK_CHECK
    stackUtils.checkStack(@cog_stack, STACK_SIZE)
#endif

    debug[CH_API]("  [fs_worker] Received command ", udec_(cur_cmd))

    ' ═══════════════════════════════════════════════════════════════════════
    ' MODE ENFORCEMENT: Reject commands invalid for current mode
    ' ═══════════════════════════════════════════════════════════════════════
    ' File system commands require MODE_FILESYSTEM
    ' Raw sector commands are allowed in both MODE_RAW and MODE_FILESYSTEM
    ' Mode transitions (MOUNT, UNMOUNT, INIT_CARD_ONLY) have their own logic
    ' Filesystem commands (CMD_NEWDIR..CMD_MOVEFILE, CMD_OPEN_READ..CMD_SET_VOL_LABEL, CMD_CREATE_CONTIGUOUS..CMD_FILE_FRAGMENTS)
#ifdef SD_INCLUDE_DEFRAG
    if (cur_cmd >= CMD_NEWDIR and cur_cmd <= CMD_MOVEFILE) or (cur_cmd >= CMD_OPEN_READ and cur_cmd <= CMD_SET_VOL_LABEL) or (cur_cmd >= CMD_CREATE_CONTIGUOUS and cur_cmd <= CMD_FILE_FRAGMENTS)
#else
    if (cur_cmd >= CMD_NEWDIR and cur_cmd <= CMD_MOVEFILE) or (cur_cmd >= CMD_OPEN_READ and cur_cmd <= CMD_SET_VOL_LABEL)
#endif
      if driver_mode <> MODE_FILESYSTEM
        debug[CH_API]("  [fs_worker] REJECTED: File operation requires MODE_FILESYSTEM")
        pb_status := E_NOT_MOUNTED
        pb_data0 := E_NOT_MOUNTED
        pb_cmd := CMD_NONE
        COGATN(1 << pb_caller)
        next                                                                    ' Skip to next command

    ' Dispatch command
    case cur_cmd
      CMD_MOUNT:
        pb_status := do_mount()

      CMD_UNMOUNT:
        pb_status := do_unmount()

      CMD_NEWDIR:
        pb_status := do_newdir(pb_param0)

      CMD_DELETE:
        pb_status := do_delete(pb_param0)

      CMD_CHDIR:
        pb_status := do_chdir(pb_param0)

      CMD_FILESIZE:
        pb_data0 := fileSize()
        pb_status := SUCCESS

      CMD_FREESPACE:
        pb_data0 := do_freespace()
        pb_status := SUCCESS

      CMD_SYNC:
        do_sync()
        pb_status := SUCCESS

      CMD_RENAME:
        pb_status := do_rename(pb_param0, pb_param1)

      CMD_MOVEFILE:
        pb_status := do_movefile(pb_param0, pb_param1)

      CMD_READDIR:
        pb_status := do_readdir(pb_param0)

#ifdef SD_INCLUDE_DEBUG
      CMD_DEBUG_SLOW_READ:
        ' DEBUG: Read sector byte-by-byte without streamer for comparison
        pb_status := readSectorSlow(pb_param0, pb_param1)

      CMD_DEBUG_CLEAR_ROOT:
        ' DEBUG: Clear root directory by writing zeros
        bytefill(@buf, 0, SECTOR_SIZE)                                             ' Zero the buffer
        if writeSector(root_sec, BUF_DATA) == SUCCESS                            ' Write to root directory
          dir_sec_in_buf := -1                                                  ' Invalidate cache
          pb_status := SUCCESS
        else
          pb_status := E_IO_ERROR
#endif

      CMD_READ_SECTOR_RAW:
        sec_in_buf := -1                                                        ' Force re-read
        if readSector(pb_param0, BUF_DATA) == 0                                 ' readSector returns 0 on success, -1 on error
          bytemove(pb_param1, @buf, SECTOR_SIZE)
          pb_status := SUCCESS
        else
          pb_status := E_IO_ERROR

#ifdef SD_INCLUDE_RAW
      CMD_READ_SECTORS:
        pb_data0 := readSectors(pb_param0, pb_param1, pb_param2)
        pb_status := SUCCESS

      CMD_WRITE_SECTORS:
        pb_data0 := writeSectors(pb_param0, pb_param1, pb_param2)
        pb_status := SUCCESS

      CMD_WRITE_SECTOR_RAW:
        bytemove(@buf, pb_param1, SECTOR_SIZE)
        debug[CH_SECTOR]("  [WRITE_RAW] after bytemove: buf[0..3]=$", uhex_byte_(buf[0]), " $", uhex_byte_(buf[1]), " $", uhex_byte_(buf[2]), " $", uhex_byte_(buf[3]), " sig=$", uhex_word_(WORD[@buf + BOOT_SIG_OFFSET]))
        if writeSector(pb_param0, BUF_DATA) == SUCCESS
          pb_status := SUCCESS
        else
          pb_status := E_IO_ERROR

      CMD_INIT_CARD_ONLY:
        pb_status := do_init_card_only()

      CMD_GET_CARD_SIZE:
        pb_data0 := do_get_card_size()
        pb_status := SUCCESS

      CMD_TEST_CMD13:
        pb_data0 := do_test_cmd13()
        pb_status := SUCCESS
#endif

#ifdef SD_INCLUDE_SPEED
      CMD_ATTEMPT_HIGH_SPEED:
        pb_data0 := do_attempt_high_speed()
        pb_status := SUCCESS

      CMD_CHECK_HS_CAPABILITY:
        pb_data0 := do_check_hs_capability()
        pb_status := SUCCESS

      CMD_SET_SPI_SPEED:
        applySPISpeed(pb_param0)
        pb_data0 := spi_freq
        pb_status := SUCCESS
#endif

#ifdef SD_INCLUDE_REGISTERS
      CMD_READ_SCR:
        pb_status := do_read_scr(pb_param0)

      CMD_READ_CID:
        pb_status := do_read_cid(pb_param0)

      CMD_READ_CSD:
        pb_status := do_read_csd(pb_param0)

      CMD_READ_SD_STATUS:
        pb_status := do_read_sd_status(pb_param0)
#endif

      ' ═══════════════════════════════════════════════════════════════════════
      ' V3 Handle-Based File Commands
      ' ═══════════════════════════════════════════════════════════════════════
      CMD_OPEN_READ:
        pb_data0 := do_open_read(pb_param0)                                       ' Returns handle or error
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_OPEN_WRITE:
        pb_data0 := do_open_write(pb_param0)                                      ' Returns handle or error
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_CREATE:
        pb_data0 := do_create(pb_param0)                                          ' Returns handle or error
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_CLOSE_H:
        pb_status := do_close_h(pb_param0)                                        ' param0 = handle

      CMD_READ_H:
        pb_data0 := do_read_h(pb_param0, pb_param1, pb_param2)                    ' handle, buffer, count -> bytes_read
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_WRITE_H:
        pb_data0 := do_write_h(pb_param0, pb_param1, pb_param2)                   ' handle, buffer, count -> bytes_written
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_SEEK_H:
        pb_status := do_seek_h(pb_param0, pb_param1)                              ' handle, position

      CMD_TELL_H:
        if validateHandle(pb_param0)
          if h_flags[pb_param0] & HF_DIR
            pb_status := E_NOT_A_DIR_HANDLE
          else
            pb_data0 := h_position[pb_param0]
            pb_status := SUCCESS
        else
          pb_status := E_INVALID_HANDLE

      CMD_FILESIZE_H:
        if validateHandle(pb_param0)
          if h_flags[pb_param0] & HF_DIR
            pb_status := E_NOT_A_DIR_HANDLE
          else
            pb_data0 := h_size[pb_param0]
            pb_status := SUCCESS
        else
          pb_status := E_INVALID_HANDLE

      CMD_SYNC_H:
        pb_status := do_sync_h(pb_param0)                                         ' handle

      CMD_SYNC_ALL:
        pb_status := do_sync_all()

      CMD_EOF_H:
        if validateHandle(pb_param0)
          if h_flags[pb_param0] & HF_DIR
            pb_status := E_NOT_A_DIR_HANDLE
          else
            pb_data0 := h_position[pb_param0] >= h_size[pb_param0] ? 1 : 0
            pb_status := SUCCESS
        else
          pb_status := E_INVALID_HANDLE

      ' ═══════════════════════════════════════════════════════════════════════
      ' V3 Directory Handle Commands
      ' ═══════════════════════════════════════════════════════════════════════
      CMD_OPEN_DIR:
        pb_data0 := do_open_dir(pb_param0)                                           ' Returns handle or error
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_READ_DIR_H:
        pb_status := do_read_dir_h(pb_param0)
        if pb_status == SUCCESS
          pb_data0 := @entry_buffer

      CMD_CLOSE_DIR_H:
        pb_status := do_close_dir_h(pb_param0)

      CMD_SET_VOL_LABEL:
        pb_status := do_set_vol_label(pb_param0)

#ifdef SD_INCLUDE_DEFRAG
      CMD_FILE_FRAGMENTS:
        pb_data0 := do_file_fragments(pb_param0)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_COMPACT_FILE:
        pb_status := do_compact_file(pb_param0)

      CMD_CREATE_CONTIGUOUS:
        pb_data0 := do_create_contiguous(pb_param0, pb_param1)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS
#endif

#ifdef SD_INCLUDE_STACK_CHECK
      CMD_STACK_DEPTH:
        pb_data0 := stackUtils.getStackDepth(@cog_stack, STACK_SIZE)
        pb_status := SUCCESS
#endif

      other:
        debug[CH_API]("  [fs_worker] Unknown command: ", udec_(cur_cmd))
        pb_status := E_BAD_RESPONSE

    ' Signal completion and reset idle timer
    pb_cmd := CMD_NONE
    COGATN(1 << pb_caller)                                                      ' Wake the caller
    idle_timer := getct()
    flush_done := false


PRI tick_clock()
' Advance the live clock by 2 seconds. Operates directly on the packed
' date_stamp LONG via FIELD pointers — no unpacking, no repacking.

  FIELD[fld_sec][0]++
  if FIELD[fld_sec][0] >= 30
    FIELD[fld_sec][0]~
    FIELD[fld_min][0]++
    if FIELD[fld_min][0] >= 60
      FIELD[fld_min][0]~
      FIELD[fld_hr][0]++
      if FIELD[fld_hr][0] >= 24
        FIELD[fld_hr][0]~
        FIELD[fld_day][0]++
        if FIELD[fld_day][0] > daysInMonth(FIELD[fld_yr][0] + FAT_EPOCH_YEAR, FIELD[fld_mon][0])
          FIELD[fld_day][0] := 1
          FIELD[fld_mon][0]++
          if FIELD[fld_mon][0] > 12
            FIELD[fld_mon][0] := 1
            FIELD[fld_yr][0]++


PRI daysInMonth(year, month) : days
' Return the number of days in the given month.
'
' @param year - Full year (e.g., 2026)
' @param month - Month (1-12)
' @returns days - Number of days in that month

  days := BYTE[@days_table][month - 1]
  if month == 2 and isLeapYear(year)
    days := 29


PRI isLeapYear(year) : result
' Check if year is a leap year.
'
' @param year - Full year (e.g., 2024)
' @returns result - TRUE if leap year

  result := (year & 3) == 0
  if year == 2100
    result := false


PRI send_command(op_cmd, p0, p1, p2, p3) : status
' Send command to worker and wait - acquire lock, send command, wait for completion.
'
' @param op_cmd - Command opcode to send
' @param p0 - Parameter 0
' @param p1 - Parameter 1
' @param p2 - Parameter 2
' @param p3 - Parameter 3
' @returns status - Status code from worker

  ' Verify worker cog is running
  if cog_id == -1
    debug[CH_API]("  [send_command] ERROR: Worker not running")
    pb_data0 := E_NOT_MOUNTED
    status := E_NOT_MOUNTED
  else
    ' Acquire API lock (serialize multi-cog access)
    repeat until locktry(api_lock)

    ' Store caller ID and parameters
    pb_caller := COGID()
    pb_param0 := p0
    pb_param1 := p1
    pb_param2 := p2
    pb_param3 := p3

    ' Issue command (triggers worker)
    pb_cmd := op_cmd

    ' Wait for completion using WAITATN (efficient sleep)
    WAITATN()

    ' Check worker cog stack guard after every command
    if not checkStackGuard()
      debug[CH_API]("  [send_command] STACK OVERFLOW after cmd ", udec_(op_cmd))

    ' Get result
    status := pb_status

    ' Release lock
    lockrel(api_lock)


CON ' ---- Handle Management ----

PRI allocateHandle() : handle | idx
' Find and allocate a free handle slot by searching the handle table.
' NOTE: Does not set h_flags - caller must do that after populating handle state.
'
' @returns handle - Handle index (0 to MAX_OPEN_FILES-1) on success, E_TOO_MANY_FILES if all in use

  handle := E_TOO_MANY_FILES                    ' Default: no free slots
  repeat idx from 0 to MAX_OPEN_FILES - 1
    if h_flags[idx] == HF_FREE
      handle := idx
      quit                                      ' Found a free slot


PRI freeHandle(handle)
' Release a handle back to the free pool - clears all state and marks slot as available.
' Does NOT validate handle - caller must ensure handle is valid.
' Does NOT flush dirty buffers - caller must do that before calling.
'
' @param handle - Handle index to release

  h_flags[handle] := HF_FREE
  h_attr[handle] := 0
  h_dir_offset[handle] := 0
  h_position[handle] := 0
  h_sector[handle] := 0
  h_start_clus[handle] := 0
  h_size[handle] := 0
  h_dir_sector[handle] := 0
  h_cluster[handle] := 0
  h_buf_sector[handle] := -1                  ' Mark buffer as invalid


PRI validateHandle(handle) : result
' Check if handle is valid and in use - fast guard function for handle operations.
'
' @param handle - Handle index to validate
' @returns result - TRUE if valid and in use, FALSE if invalid or free

  if handle < 0 or handle >= MAX_OPEN_FILES
    result := FALSE
  elseif h_flags[handle] == HF_FREE
    result := FALSE
  else
    result := TRUE                            ' Handle is valid and in use


PRI isFileOpenForWrite(dir_sector, dir_offset) : result | handle
' Check if file is already open for write - enforces single-writer policy.
' Multiple read handles allowed, only one write handle per file.
'
' @param dir_sector - Directory sector containing the file entry
' @param dir_offset - Offset within sector of the file entry
' @returns result - TRUE if file is open for write, FALSE otherwise
' @local handle - Loop variable for handle search

  result := FALSE
  repeat handle from 0 to MAX_OPEN_FILES - 1
    if h_flags[handle] & HF_WRITE             ' Check if handle has write access
      if h_dir_sector[handle] == dir_sector and h_dir_offset[handle] == dir_offset
        result := TRUE                        ' File is already open for write
        quit


PRI getHandleBuffer(handle) : p_buffer
' Get pointer to handle's data buffer - each handle has a dedicated 512-byte buffer.
' Does NOT validate handle - caller must do that first.
'
' @param handle - Handle index
' @returns p_buffer - Address of the 512-byte buffer for this handle

  p_buffer := @h_buf + (handle << SECTOR_SHIFT)           ' handle * 512


PRI initHandleTable() | idx
' Initialize all handles to free state - called during mount() for clean state.
' Releases all handles and invalidates all buffer cache tracking.
'
' @local idx - Loop variable

  repeat idx from 0 to MAX_OPEN_FILES - 1
    freeHandle(idx)


CON ' ---- Struct Accessors ----

PRI partType(^mbr_partition_t pPart) : value
' Get partition type code from MBR partition entry.
'
' @param pPart - Pointer to MBR partition entry
' @returns value - Partition type code ($0B/$0C = FAT32)

  value := pPart.partType


PRI partLbaStart(^mbr_partition_t pPart) : value
' Get LBA start sector from MBR partition entry.
'
' @param pPart - Pointer to MBR partition entry
' @returns value - First sector of partition (LBA)

  value := pPart.lbaStart


PRI vbrBytesPerSec(^vbr_t pVBR) : value
' Get bytes per sector from VBR.
'
' @param pVBR - Pointer to Volume Boot Record
' @returns value - Bytes per sector (must be 512)

  value := pVBR.bytesPerSec


PRI vbrSecPerClus(^vbr_t pVBR) : value
' Get sectors per cluster from VBR.
'
' @param pVBR - Pointer to Volume Boot Record
' @returns value - Sectors per cluster (power of 2)

  value := pVBR.secPerClus


PRI vbrReservedSec(^vbr_t pVBR) : value
' Get reserved sector count from VBR.
'
' @param pVBR - Pointer to Volume Boot Record
' @returns value - Number of reserved sectors before FAT

  value := pVBR.reservedSec


PRI vbrNumFats(^vbr_t pVBR) : value
' Get number of FATs from VBR.
'
' @param pVBR - Pointer to Volume Boot Record
' @returns value - Number of FAT copies (typically 2)

  value := pVBR.numFats


PRI vbrSecPerFat32(^vbr_t pVBR) : value
' Get sectors per FAT from VBR.
'
' @param pVBR - Pointer to Volume Boot Record
' @returns value - Number of sectors per FAT

  value := pVBR.secPerFat32


PRI vbrFsInfoSec(^vbr_t pVBR) : value
' Get FSInfo sector offset from VBR.
'
' @param pVBR - Pointer to Volume Boot Record
' @returns value - FSInfo sector number (relative to VBR)

  value := pVBR.fsInfoSec


PRI vbrVolLabelAddr(^vbr_t pVBR) : addr
' Get address of volume label field in VBR.
'
' @param pVBR - Pointer to Volume Boot Record
' @returns addr - Hub address of 11-byte volume label field

  addr := @pVBR.volLabel


PRI fsiLeadSig(^fsinfo_t pFSI) : value
' Get FSInfo lead signature.
'
' @param pFSI - Pointer to FSInfo sector
' @returns value - Lead signature (must be $41615252)

  value := pFSI.leadSig


PRI fsiStructSig(^fsinfo_t pFSI) : value
' Get FSInfo struct signature.
'
' @param pFSI - Pointer to FSInfo sector
' @returns value - Struct signature (must be $61417272)

  value := pFSI.structSig


PRI fsiFreeClusters(^fsinfo_t pFSI) : value
' Get free cluster count from FSInfo.
'
' @param pFSI - Pointer to FSInfo sector
' @returns value - Number of free clusters ($FFFFFFFF if unknown)

  value := pFSI.freeClusters


PRI fsiNextFreeHint(^fsinfo_t pFSI) : value
' Get next free cluster hint from FSInfo.
'
' @param pFSI - Pointer to FSInfo sector
' @returns value - Suggested starting cluster for free space search

  value := pFSI.nextFreeHint


PRI fsiSetFreeClusters(^fsinfo_t pFSI, value)
' Set free cluster count in FSInfo.
'
' @param pFSI - Pointer to FSInfo sector
' @param value - New free cluster count

  pFSI.freeClusters := value


PRI fsiSetNextFreeHint(^fsinfo_t pFSI, value)
' Set next free cluster hint in FSInfo.
'
' @param pFSI - Pointer to FSInfo sector
' @param value - New next-free cluster hint

  pFSI.nextFreeHint := value


PRI dirEntAttr(^dir_entry_t pEntry) : value
' Get attribute byte from directory entry.
'
' @param pEntry - Pointer to directory entry
' @returns value - FAT attribute byte ($10=dir, $20=archive, $08=volume label)

  value := pEntry.attr


PRI dirEntStartClus(^dir_entry_t pEntry) : value
' Get start cluster from directory entry (combines high and low words).
'
' @param pEntry - Pointer to directory entry
' @returns value - 32-bit start cluster number

  value := pEntry.clusHI << 16 | pEntry.clusLO


PRI dirEntFileSize(^dir_entry_t pEntry) : value
' Get file size from directory entry.
'
' @param pEntry - Pointer to directory entry
' @returns value - File size in bytes

  value := pEntry.fileSize


PRI dirEntSetAttr(^dir_entry_t pEntry, value)
' Set attribute byte in directory entry.
'
' @param pEntry - Pointer to directory entry
' @param value - Attribute byte to set

  pEntry.attr := value


PRI dirEntSetStartClus(^dir_entry_t pEntry, value)
' Set start cluster in directory entry (splits into high and low words).
'
' @param pEntry - Pointer to directory entry
' @param value - 32-bit cluster number to set

  pEntry.clusHI := value >> 16
  pEntry.clusLO := value & $FFFF


PRI dirEntSetFileSize(^dir_entry_t pEntry, value)
' Set file size in directory entry.
'
' @param pEntry - Pointer to directory entry
' @param value - File size in bytes

  pEntry.fileSize := value


PRI dirEntSetCreateStamp(^dir_entry_t pEntry, stamp)
' Set creation timestamp in directory entry.
'
' @param pEntry - Pointer to directory entry
' @param stamp - Combined date/time stamp (date in upper 16, time in lower 16)

  pEntry.crtTime := stamp & $FFFF
  pEntry.crtDate := stamp >> 16


PRI dirEntSetModifyStamp(^dir_entry_t pEntry, stamp)
' Set modification timestamp in directory entry.
'
' @param pEntry - Pointer to directory entry
' @param stamp - Combined date/time stamp (date in upper 16, time in lower 16)

  pEntry.wrtTime := stamp & $FFFF
  pEntry.wrtDate := stamp >> 16


CON ' ---- SD Worker Operations ----

PRI do_mount() : result | reserved, pPart, pVBR, pFSI, idx, p_entry, cluster, sector, sec_idx, next_cluster, found
' Internal mount operation - initializes card and reads filesystem structures.
'
' @returns result - SUCCESS on success, error code on failure
' @local reserved - Reserved sector count from VBR
' @local pPart - Pointer to MBR partition entry
' @local pVBR - Pointer to Volume Boot Record overlay
' @local pFSI - Pointer to FSInfo sector overlay
' @local idx - Loop counter
' @local p_entry - Pointer to directory entry
' @local cluster - Current cluster number
' @local sector - Current sector number
' @local sec_idx - Sector index within cluster
' @local next_cluster - Next cluster in FAT chain
' @local found - Search result flag

  dir_sec_in_buf := -1
  fat_sec_in_buf := -1
  sec_in_buf := -1

  ' V3: Initialize handle table to clean state
  initHandleTable()

  ' Skip card init if already in RAW mode (card already initialized)
  ' This avoids reinitializing smart pins which would corrupt pin states
  if driver_mode == MODE_RAW
    debug[CH_MOUNT]("  [do_mount] Upgrading from RAW mode - skipping initCard()")
  else
    debug[CH_MOUNT]("  [do_mount] Calling initCard()...")
    if not initCard()
      debug[CH_MOUNT]("  [do_mount] FAIL: initCard() returned false")
      result := last_init_error

  ' Card is initialized (either fresh or from RAW mode)
  if result == 0
    debug[CH_MOUNT]("  [do_mount] Reading MBR sector 0...")
    if readSector(0, BUF_DATA) < 0                                              '  read master boot record
      debug[CH_MOUNT]("  [do_mount] FAIL: MBR read error")
      result := E_IO_ERROR
    else
      pPart := @buf + MBR_PARTITION_OFFSET                                       '  overlay partition entry 1
      debug[CH_MOUNT]("  [do_mount] MBR type code: ", uhex_(partType(pPart)))
      if partType(pPart) == PART_TYPE_FAT32_LBA28 or partType(pPart) == PART_TYPE_FAT32_LBA  '  FAT32 partition types
        vbr_sec := partLbaStart(pPart)                                          '  volume boot record sector number
        debug[CH_MOUNT]("  [do_mount] FAT32 detected, VBR at sector ", udec(vbr_sec))
        if readSector(vbr_sec, BUF_DATA) < 0                                    '  read volume boot record
          debug[CH_MOUNT]("  [do_mount] FAIL: VBR read error")
          result := E_IO_ERROR
      else
        debug[CH_MOUNT]("  [do_mount] FAIL: Not FAT32 (type=", uhex_(partType(pPart)), ")")
        result := E_NOT_FAT32

  if result == 0
    pVBR := @buf                                                                '  overlay VBR
    debug[CH_MOUNT]("  [do_mount] Bytes/sector: ", udec(vbrBytesPerSec(pVBR)))
    if vbrBytesPerSec(pVBR) <> SECTOR_SIZE
      debug[CH_MOUNT]("  [do_mount] FAIL: Bytes/sector not 512")
      result := E_BAD_SECTOR_SIZE
    else
      sec_per_clus := vbrSecPerClus(pVBR)
      debug[CH_MOUNT]("  [do_mount] Sectors/cluster: ", udec(sec_per_clus))
      if (sec_per_clus & (sec_per_clus - 1))
        debug[CH_MOUNT]("  [do_mount] FAIL: sec_per_clus not power of 2")
        result := E_NOT_FAT32
      else
        reserved := vbrReservedSec(pVBR)
        debug[CH_MOUNT]("  [do_mount] Reserved sectors: ", udec(reserved))
        debug[CH_MOUNT]("  [do_mount] Number of FATs: ", udec(vbrNumFats(pVBR)))
        if vbrNumFats(pVBR) <> 2
          debug[CH_MOUNT]("  [do_mount] FAIL: FAT count not 2")
          result := E_NOT_FAT32
        else
          sec_per_fat := vbrSecPerFat32(pVBR)
          fsinfo_sec := vbrFsInfoSec(pVBR)
          fat_sec := vbr_sec + reserved
          fat2_sec := fat_sec + sec_per_fat
          root_sec := (fat_sec + 2 * sec_per_fat)
          longfill(@cog_dir_sec, root_sec, 8)                                   ' All cogs start at root
          idle_flush_clocks := clkfreq / 1000 * IDLE_FLUSH_MS                   ' Auto-flush threshold
          ct_tick_clocks := clkfreq * 2                                            ' 2-second clock tick interval
          cluster_offset := root_sec // sec_per_clus
          bytemove(@vol_label, vbrVolLabelAddr(pVBR), SFN_TOTAL_LEN)
          vol_label[11] := 0
          debug[CH_MOUNT]("  [do_mount] VBR volume label: ", zstr(@vol_label))

          ' Check root directory for authoritative volume label entry (ATTR_VOLUME_ID)
          ' The root directory entry is the primary source per the FAT32 spec;
          ' the VBR copy is a fallback (Windows format may write "NO NAME" to VBR).
          ' Follow the root cluster chain so we find the label even if it's not in the first sector.
          cluster := ROOT_CLUSTER
          found := false
          repeat while cluster >= ROOT_CLUSTER and cluster +< FAT32_EOC_MIN and not found
            sector := clus2sec(cluster)
            repeat sec_idx from 0 to sec_per_clus - 1
              if readSector(sector + sec_idx, BUF_DIR) < 0
                debug[CH_MOUNT]("  [do_mount] Root dir read failed, using VBR label")
                found := true
                quit
              repeat idx from 0 to 15
                p_entry := @dir_buf + (idx * DIR_ENTRY_SIZE)
                if byte[p_entry] == $00                                                '  end of directory
                  found := true
                  quit
                if byte[p_entry] <> DIR_ENTRY_DELETED and dirEntAttr(p_entry) == ATTR_VOLUME_ID                 '  volume label entry
                  bytemove(@vol_label, p_entry, SFN_TOTAL_LEN)
                  vol_label[11] := 0
                  debug[CH_MOUNT]("  [do_mount] Root dir volume label: ", zstr(@vol_label))
                  found := true
                  quit
              if found
                quit
            ' Follow FAT chain to next cluster
            if not found
              if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0
                quit
              next_cluster := LONG[@fat_buf + ((cluster << 2) & SECTOR_OFFSET_MASK)]
              cluster := next_cluster

          ' Read FSInfo sector for free cluster count and next-free hint
          if fsinfo_sec > 0 and fsinfo_sec < reserved
            if readSector(vbr_sec + fsinfo_sec, BUF_DATA) < 0
              debug[CH_MOUNT]("  [do_mount] FSInfo read failed, continuing without free count")
              fsi_free_count := $FFFF_FFFF
              fsi_nxt_free := $FFFF_FFFF
            else
              pFSI := @buf                                                       '  overlay FSInfo
              if fsiLeadSig(pFSI) == FSINFO_LEAD_SIG and fsiStructSig(pFSI) == FSINFO_STRUCT_SIG
                fsi_free_count := fsiFreeClusters(pFSI)
                fsi_nxt_free := fsiNextFreeHint(pFSI)
                debug[CH_MOUNT]("  [do_mount] FSInfo: free_count=", udec(fsi_free_count), " nxt_free=", udec(fsi_nxt_free))
              else
                fsi_free_count := $FFFF_FFFF
                fsi_nxt_free := $FFFF_FFFF
                debug[CH_MOUNT]("  [do_mount] FSInfo: invalid signatures, ignoring")
          else
            fsi_free_count := $FFFF_FFFF
            fsi_nxt_free := $FFFF_FFFF
            debug[CH_MOUNT]("  [do_mount] FSInfo: sector not present")

          debug[CH_MOUNT]("  [do_mount] SUCCESS")
          if date_stamp == 0
            setdate(2009,01,27,07,00,00)
          flags |= F_MOUNTED

          driver_mode := MODE_FILESYSTEM
          debug[CH_MOUNT]("  [do_mount] SUCCESS, mode=FILESYSTEM")
          if card_warning_flags & CW_CMD13_UNRELIABLE
            debug[CH_MOUNT]("  [do_mount] WARNING: CMD13 unreliable on this card - status checks disabled")


PRI do_unmount() : result
' Internal unmount operation - syncs all handles and updates FSInfo.
'
' @returns result - SUCCESS on success

  ' V3: Sync all open handles before unmount
  do_sync_all()
  do_close()
  result := updateFSInfo()
  flags := flags & !F_MOUNTED
  driver_mode := MODE_NONE
  debug[CH_MOUNT]("  [do_unmount] Card unmounted cleanly, mode=NONE")
  result := SUCCESS


PRI do_open(name_ptr) : result | search_result
' Internal open file operation - finds existing file in directory.
' Used internally by do_movefile to locate source file.
'
' @param name_ptr - Pointer to null-terminated filename string
' @returns result - SUCCESS on success, E_FILE_NOT_FOUND on failure
' @local search_result - Result from searchDirectory

  do_close()
  search_result := searchDirectory(name_ptr)
  if search_result and (attributes() & (ATTR_HIDDEN | ATTR_SYSTEM | ATTR_VOLUME_ID | ATTR_DIRECTORY) == 0)
    result := SUCCESS
  else
    result := E_FILE_NOT_FOUND


PRI do_close() : result
' Internal close operation - flush pending directory entry to disk.
' Used internally by do_movefile, do_delete, do_chdir, and do_unmount.
'
' @returns result - SUCCESS (0) on success, E_IO_ERROR on write failure

  result := SUCCESS

  ' Update directory entry on disk if modified
  if flags & F_NEWDIR
    if readSector(entry_address >> SECTOR_SHIFT, BUF_DIR) < 0
      debug[CH_FILE]("  [do_close] Directory read FAILED for sector ", udec_(entry_address >> SECTOR_SHIFT))
      result := E_IO_ERROR
    else
      bytemove(@dir_buf + (entry_address & SECTOR_OFFSET_MASK), @entry_buffer, DIR_ENTRY_SIZE)
      if writeSector(entry_address >> SECTOR_SHIFT, BUF_DIR) < 0
        debug[CH_FILE]("  [do_close] Directory write FAILED for sector ", udec_(entry_address >> SECTOR_SHIFT))
        result := E_IO_ERROR

  bytefill(@entry_buffer, 0, DIR_ENTRY_SIZE)
  flags := flags & !F_NEWDIR


PRI do_open_read(p_path) : handle | start_cluster
' Open file for reading (V3 handle) - opens existing file and returns handle.
' Multiple files can be open simultaneously for reading.
' Each handle has its own position, enabling interleaved reads.
'
' @param p_path - Pointer to null-terminated path string
' @returns handle - Handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure
' @local start_cluster - Starting cluster of the file

  ' Allocate a handle slot
  handle := allocateHandle()
  if handle < 0
    debug[CH_FILE]("  [do_open_read] No free handles")
  elseif not searchDirectory(p_path)
    ' Search for the file
    debug[CH_FILE]("  [do_open_read] File not found: ", zstr_(p_path))
    freeHandle(handle)
    handle := E_FILE_NOT_FOUND
  elseif attributes() & ATTR_DIRECTORY                                              ' Directory bit
    ' Verify it's a file, not a directory
    debug[CH_FILE]("  [do_open_read] Path is a directory, not a file")
    freeHandle(handle)
    handle := E_NOT_A_FILE
  else
    ' Populate handle state from directory entry
    start_cluster := firstCluster()
    h_start_clus[handle] := start_cluster
    h_size[handle] := fileSize()
    h_attr[handle] := attributes()
    h_dir_sector[handle] := entry_address >> SECTOR_SHIFT
    h_dir_offset[handle] := entry_address & SECTOR_OFFSET_MASK
    h_cluster[handle] := start_cluster
    h_sector[handle] := clus2sec(start_cluster)
    h_position[handle] := 0
    h_buf_sector[handle] := -1                                                  ' No sector cached yet
    h_flags[handle] := HF_READ
    debug[CH_FILE]("  [do_open_read] Success: handle=", udec_(handle), " size=", udec_(h_size[handle]), " cluster=", udec_(start_cluster))


PRI do_open_write(p_path) : handle | start_cluster, current_cluster, fat_addr, file_size, cluster_count
' Open file for writing/append (V3 handle) - opens existing file for appending.
' Enforces single-writer policy: only one write handle per file allowed.
' Position is set to end of file for appending.
'
' @param p_path - Pointer to null-terminated path string
' @returns handle - Handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure
' @local start_cluster - Starting cluster of the file
' @local current_cluster - Current cluster during FAT chain walk
' @local fat_addr - Address of FAT entry
' @local file_size - Size of file in bytes
' @local cluster_count - Number of clusters to walk

  ' Allocate a handle slot
  handle := allocateHandle()
  if handle < 0
    debug[CH_FILE]("  [do_open_write] No free handles")
  elseif not searchDirectory(p_path)
    ' Search for the file
    debug[CH_FILE]("  [do_open_write] File not found: ", zstr_(p_path))
    freeHandle(handle)
    handle := E_FILE_NOT_FOUND
  elseif attributes() & ATTR_DIRECTORY                                              ' Directory bit
    ' Verify it's a file, not a directory
    debug[CH_FILE]("  [do_open_write] Path is a directory, not a file")
    freeHandle(handle)
    handle := E_NOT_A_FILE
  elseif isFileOpenForWrite(entry_address >> SECTOR_SHIFT, entry_address & SECTOR_OFFSET_MASK)
    ' Check single-writer policy
    debug[CH_FILE]("  [do_open_write] File already open for write")
    freeHandle(handle)
    handle := E_FILE_ALREADY_OPEN
  else
    ' Populate handle state from directory entry
    start_cluster := firstCluster()
    file_size := fileSize()
    h_start_clus[handle] := start_cluster
    h_size[handle] := file_size
    h_attr[handle] := attributes()
    h_dir_sector[handle] := entry_address >> SECTOR_SHIFT
    h_dir_offset[handle] := entry_address & SECTOR_OFFSET_MASK

    ' Position at end of file for append mode
    ' Walk FAT chain to find the last cluster
    h_position[handle] := file_size
    if file_size > 0
      ' Calculate which cluster contains the last byte
      cluster_count := (file_size - 1) / (sec_per_clus << SECTOR_SHIFT)
      current_cluster := start_cluster
      repeat cluster_count
        fat_addr := readFat(current_cluster)
        current_cluster := long[fat_addr]
        if current_cluster +>= FAT32_EOC_MIN                                       ' End of chain - shouldn't happen
          quit
      h_cluster[handle] := current_cluster
      h_sector[handle] := clus2sec(current_cluster) + ((file_size - 1) >> SECTOR_SHIFT) & (sec_per_clus - 1)
    else
      ' Empty file - position at start
      h_cluster[handle] := start_cluster
      h_sector[handle] := clus2sec(start_cluster)

    h_buf_sector[handle] := -1                                                  ' No sector cached yet
    h_flags[handle] := HF_WRITE
    debug[CH_FILE]("  [do_open_write] Success: handle=", udec_(handle), " size=", udec_(file_size), " pos=", udec_(h_position[handle]))


PRI do_create(p_path) : handle | temp, first_cluster
' Create new file (V3 handle) - creates empty file and opens for writing.
' If file already exists, returns error.
'
' @param p_path - Pointer to null-terminated path string
' @returns handle - Handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure
' @local temp - Temporary calculation variable
' @local first_cluster - First cluster allocated for the new file

  ' Allocate a handle slot
  handle := allocateHandle()
  if handle < 0
    debug[CH_FILE]("  [do_create] No free handles")
  elseif searchDirectory(p_path)
    ' Check if file already exists
    debug[CH_FILE]("  [do_create] File already exists: ", zstr_(p_path))
    freeHandle(handle)
    handle := E_FILE_EXISTS
  elseif entry_address == 0
    ' Guard: entry_address 0 means searchDirectory never found a valid directory
    debug[CH_FILE]("  [do_create] entry_address=0 -- path not valid, aborting")
    freeHandle(handle)
    handle := E_FILE_NOT_FOUND
  else
    ' searchDirectory() sets entry_address to first free directory entry
    ' Check if we need to allocate a new cluster for the directory
    temp := (entry_address + cluster_offset << SECTOR_SHIFT) & (sec_per_clus << SECTOR_SHIFT - 1)
    if temp == (sec_per_clus << SECTOR_SHIFT - DIR_ENTRY_SIZE)
      if dir_buf[LAST_DIR_ENTRY_OFFSET] == $00                                                    ' End of directory
        temp := allocateCluster(byte2clus(entry_address))
        if temp < 0
          debug[CH_FILE]("  [do_create] Failed to allocate dir cluster")
          freeHandle(handle)
          handle := E_DISK_FULL
        else
          clearCluster(temp)

    ' Allocate first cluster for the new file (if no error yet)
    if handle >= 0
      first_cluster := allocateCluster(0)
      if first_cluster < 0
        debug[CH_FILE]("  [do_create] Failed to allocate file cluster")
        freeHandle(handle)
        handle := E_DISK_FULL

    if handle >= 0
      ' Set up directory entry in entry_buffer
      dirEntSetAttr(@entry_buffer, ATTR_ARCHIVE)                                          ' Archive attribute
      dirEntSetCreateStamp(@entry_buffer, date_stamp)
      dirEntSetStartClus(@entry_buffer, first_cluster)
      dirEntSetModifyStamp(@entry_buffer, date_stamp)
      dirEntSetFileSize(@entry_buffer, 0)

      ' Write directory entry to disk
      if readSector(entry_address >> SECTOR_SHIFT, BUF_DIR) < 0
        debug[CH_FILE]("  [do_create] Directory read FAILED for sector ", udec_(entry_address >> SECTOR_SHIFT))
        freeHandle(handle)
        handle := E_IO_ERROR
      else
        bytemove(@dir_buf + (entry_address & SECTOR_OFFSET_MASK), @entry_buffer, DIR_ENTRY_SIZE)
        if writeSector(entry_address >> SECTOR_SHIFT, BUF_DIR) < 0
          debug[CH_FILE]("  [do_create] Directory write FAILED for sector ", udec_(entry_address >> SECTOR_SHIFT))
          freeHandle(handle)
          handle := E_IO_ERROR
        else
          ' Populate handle state
          h_start_clus[handle] := first_cluster
          h_size[handle] := 0
          h_attr[handle] := ATTR_ARCHIVE
          h_dir_sector[handle] := entry_address >> SECTOR_SHIFT
          h_dir_offset[handle] := entry_address & SECTOR_OFFSET_MASK
          h_cluster[handle] := first_cluster
          h_sector[handle] := clus2sec(first_cluster)
          h_position[handle] := 0
          h_buf_sector[handle] := -1                                            ' No sector cached yet
          h_flags[handle] := HF_WRITE
          debug[CH_FILE]("  [do_create] Success: handle=", udec_(handle), " cluster=", udec_(first_cluster))


PRI do_close_h(handle) : result | p_buf
' Close file handle (V3) - closes handle, flushing writes and updating directory.
' For write handles, the directory entry is updated with the final file size.
'
' @param handle - Handle to close
' @returns result - SUCCESS (0) on success, E_INVALID_HANDLE on failure
' @local p_buf - Pointer to handle's buffer

  ' Validate handle
  if not validateHandle(handle)
    debug[CH_FILE]("  [do_close_h] Invalid handle: ", sdec_(handle))
    result := E_INVALID_HANDLE
  elseif h_flags[handle] & HF_DIR
    result := E_NOT_A_DIR_HANDLE
  else
    result := SUCCESS

    ' If buffer is dirty, flush it to disk
    if h_flags[handle] & HF_DIRTY
      p_buf := getHandleBuffer(handle)
      bytemove(@buf, p_buf, SECTOR_SIZE)                                             ' Copy to shared buffer
      if writeSector(h_buf_sector[handle], BUF_DATA) < 0
        debug[CH_FILE]("  [do_close_h] Data write FAILED for sector ", udec_(h_buf_sector[handle]))
        result := E_IO_ERROR

    ' If opened for write, update directory entry with final size
    if h_flags[handle] & HF_WRITE
      if readSector(h_dir_sector[handle], BUF_DIR) < 0
        debug[CH_FILE]("  [do_close_h] Directory read FAILED for sector ", udec_(h_dir_sector[handle]))
        result := E_IO_ERROR
      else
        long[@dir_buf + h_dir_offset[handle] + DE_FILESIZE_OFFSET] := h_size[handle]  ' Update size field
        long[@dir_buf + h_dir_offset[handle] + DE_WRT_TIME_OFFSET] := date_stamp    ' Update modification timestamp
        if writeSector(h_dir_sector[handle], BUF_DIR) < 0
          debug[CH_FILE]("  [do_close_h] Directory write FAILED for sector ", udec_(h_dir_sector[handle]))
          result := E_IO_ERROR

#ifdef SD_INCLUDE_DEFRAG
    ' Clear pre-allocation tracking
    h_prealloc_end[handle] := 0
#endif
    ' Free the handle
    freeHandle(handle)


PRI do_read_h(handle, p_buffer, count) : bytes_read | p_hbuf, available, offset, to_read, cluster, fat_addr, next_cluster
' Handle-based read (V3) - reads data from file handle into user buffer.
' Uses per-handle buffer to avoid cache thrashing. Independent position per handle.
'
' @param handle - Valid read handle
' @param p_buffer - Pointer to destination buffer
' @param count - Number of bytes to read
' @returns bytes_read - Number of bytes actually read (0 at EOF), negative on error
' @local p_hbuf - Pointer to handle's buffer
' @local available - Bytes available to read
' @local offset - Offset within current sector
' @local to_read - Bytes to read from current sector
' @local cluster - Current cluster number
' @local fat_addr - Address of FAT entry
' @local next_cluster - Next cluster in chain

  ' Validate handle
  if not validateHandle(handle)
    debug[CH_FILE]("  [do_read_h] Invalid handle: ", sdec_(handle))
    bytes_read := E_INVALID_HANDLE
  elseif h_flags[handle] & HF_DIR
    bytes_read := E_NOT_A_DIR_HANDLE
  elseif h_size[handle] - h_position[handle] <= 0
    ' Calculate how many bytes we can actually read
    debug[CH_FILE]("  [do_read_h] EOF reached")
    bytes_read := 0                                                               ' EOF
  else
    available := h_size[handle] - h_position[handle]
    count := count <# available                                                   ' Cap at available bytes
    debug[CH_FILE]("  [do_read_h] handle=", udec_(handle), " pos=", udec_(h_position[handle]), " count=", udec_(count))

    ' Get pointer to handle's buffer
    p_hbuf := getHandleBuffer(handle)

    ' Advance past sector boundary left by previous read that ended exactly at 512-byte boundary.
    ' Without this, the next read returns stale data from the previous sector's buffer.
    if (h_position[handle] & SECTOR_OFFSET_MASK) == 0 and h_position[handle] > 0 and h_buf_sector[handle] == h_sector[handle]
      h_buf_sector[handle] := -1
      h_sector[handle]++
      if ((h_sector[handle] - cluster_offset) & (sec_per_clus - 1)) == 0
        ' Follow FAT chain to next cluster
        cluster := h_cluster[handle]
        if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0
          debug[CH_FILE]("  [do_read_h] FAT chain follow FAILED at boundary advance")
          count := 0                                                              ' Skip main loop
        else
          fat_addr := @fat_buf + ((cluster << 2) & SECTOR_OFFSET_MASK)
          next_cluster := long[fat_addr]
          if next_cluster +>= FAT32_EOC_MIN
            debug[CH_FILE]("  [do_read_h] End of chain at boundary advance")
            count := 0                                                            ' Skip main loop
          else
            h_cluster[handle] := next_cluster
            h_sector[handle] := clus2sec(next_cluster)

    bytes_read := 0
    repeat while count > 0
      ' Ensure current sector is loaded into handle's buffer
      if h_buf_sector[handle] <> h_sector[handle]
        ' Load sector into shared buffer, then copy to handle's buffer
        if readSector(h_sector[handle], BUF_DATA) < 0
          debug[CH_FILE]("  [do_read_h] Sector read FAILED for sector ", udec_(h_sector[handle]))
          quit                                                                    ' Return partial read count
        bytemove(p_hbuf, @buf, SECTOR_SIZE)
        h_buf_sector[handle] := h_sector[handle]

      ' Calculate offset within sector and bytes to read from this sector
      offset := h_position[handle] & SECTOR_OFFSET_MASK
      to_read := (SECTOR_SIZE - offset) <# count

      ' Copy data from handle buffer to user buffer
      bytemove(p_buffer, p_hbuf + offset, to_read)

      ' Advance positions
      p_buffer += to_read
      h_position[handle] += to_read
      bytes_read += to_read
      count -= to_read

      ' If we've finished this sector, advance to next
      if (h_position[handle] & SECTOR_OFFSET_MASK) == 0 and count > 0
        h_sector[handle]++
        ' Check if we crossed a cluster boundary
        if ((h_sector[handle] - cluster_offset) & (sec_per_clus - 1)) == 0
          ' Follow FAT chain to next cluster
          cluster := h_cluster[handle]
          if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0
            debug[CH_FILE]("  [do_read_h] FAT read FAILED for cluster ", udec_(cluster))
            quit                                                                  ' Return partial read count
          fat_addr := @fat_buf + ((cluster << 2) & SECTOR_OFFSET_MASK)
          next_cluster := long[fat_addr]
          if next_cluster +>= FAT32_EOC_MIN
            ' End of chain - shouldn't happen if h_size is correct
            debug[CH_FILE]("  [do_read_h] Unexpected end of FAT chain")
            quit
          h_cluster[handle] := next_cluster
          h_sector[handle] := clus2sec(next_cluster)

    debug[CH_FILE]("  [do_read_h] Read ", udec_(bytes_read), " bytes, pos now ", udec_(h_position[handle]))


PRI do_write_h(handle, p_buffer, count) : bytes_written | p_hbuf, offset, to_write, new_cluster
' Handle-based write (V3) - writes data from user buffer to file handle.
' Uses per-handle buffer with dirty tracking. File grows as needed.
' Clusters allocated when extending past current allocation.
'
' @param handle - Valid write handle (must have HF_WRITE set)
' @param p_buffer - Pointer to source data buffer
' @param count - Number of bytes to write
' @returns bytes_written - Number of bytes written, negative on error
' @local p_hbuf - Pointer to handle's buffer
' @local offset - Offset within current sector
' @local to_write - Bytes to write to current sector
' @local new_cluster - Newly allocated cluster

  ' Validate handle
  if not validateHandle(handle)
    debug[CH_FILE]("  [do_write_h] Invalid handle: ", sdec_(handle))
    bytes_written := E_INVALID_HANDLE
  elseif h_flags[handle] & HF_DIR
    bytes_written := E_NOT_A_DIR_HANDLE
  elseif not (h_flags[handle] & HF_WRITE)
    ' Verify handle is open for writing
    debug[CH_FILE]("  [do_write_h] Handle not open for write")
    bytes_written := E_INVALID_HANDLE
  elseif count <= 0
    bytes_written := 0
  else
    debug[CH_FILE]("  [do_write_h] handle=", udec_(handle), " pos=", udec_(h_position[handle]), " count=", udec_(count))

    ' Get pointer to handle's buffer
    p_hbuf := getHandleBuffer(handle)

    ' Advance past sector boundary left by previous write that ended exactly at 512-byte boundary.
    ' Without this, the next write overwrites the unflushed handle buffer before it reaches disk.
    if (h_position[handle] & SECTOR_OFFSET_MASK) == 0 and h_position[handle] > 0 and h_buf_sector[handle] == h_sector[handle]
      if h_flags[handle] & HF_DIRTY
        debug[CH_FILE]("  [do_write_h] Flushing stale sector ", udec_(h_buf_sector[handle]))
        bytemove(@buf, p_hbuf, SECTOR_SIZE)
        writeSector(h_buf_sector[handle], BUF_DATA)
        h_flags[handle] &= !HF_DIRTY
      h_buf_sector[handle] := -1
      h_sector[handle]++
      if ((h_sector[handle] - cluster_offset) & (sec_per_clus - 1)) == 0
#ifdef SD_INCLUDE_DEFRAG
        if h_prealloc_end[handle] > 0
          new_cluster := h_cluster[handle] + 1
          if new_cluster > h_prealloc_end[handle]
            debug[CH_FILE]("  [do_write_h] Pre-allocated space exhausted")
            count := 0
          else
            h_cluster[handle] := new_cluster
            h_sector[handle] := clus2sec(new_cluster)
        else
#endif
          new_cluster := allocateCluster(h_cluster[handle])
          if new_cluster < 0
            debug[CH_FILE]("  [do_write_h] Failed to allocate cluster at boundary advance")
            count := 0                                                              ' Skip main loop
          else
            h_cluster[handle] := new_cluster
            h_sector[handle] := clus2sec(new_cluster)

    bytes_written := 0
    repeat while count > 0
      ' Ensure current sector is in handle's buffer
      if h_buf_sector[handle] <> h_sector[handle]
        ' Flush dirty buffer first if needed
        if h_flags[handle] & HF_DIRTY
          debug[CH_FILE]("  [do_write_h] Flushing dirty sector ", udec_(h_buf_sector[handle]))
          bytemove(@buf, p_hbuf, SECTOR_SIZE)
          writeSector(h_buf_sector[handle], BUF_DATA)
          h_flags[handle] &= !HF_DIRTY

        ' Load sector (or zero-fill if writing past end)
        if h_position[handle] < h_size[handle]
          ' Within existing file - load sector
          if readSector(h_sector[handle], BUF_DATA) < 0
            debug[CH_FILE]("  [do_write_h] Sector read FAILED for sector ", udec_(h_sector[handle]))
            quit                                                                  ' Return partial write count
          bytemove(p_hbuf, @buf, SECTOR_SIZE)
        else
          ' Past end of file - zero-fill buffer
          bytefill(p_hbuf, 0, SECTOR_SIZE)
        h_buf_sector[handle] := h_sector[handle]

      ' Calculate offset within sector and bytes to write to this sector
      offset := h_position[handle] & SECTOR_OFFSET_MASK
      to_write := (SECTOR_SIZE - offset) <# count

      ' Copy data from user buffer to handle buffer
      bytemove(p_hbuf + offset, p_buffer, to_write)
      h_flags[handle] |= HF_DIRTY

      ' Advance positions
      p_buffer += to_write
      h_position[handle] += to_write
      bytes_written += to_write
      count -= to_write

      ' Update file size if we've grown past it
      if h_position[handle] > h_size[handle]
        h_size[handle] := h_position[handle]

      ' If we've filled this sector, flush and advance to next
      if (h_position[handle] & SECTOR_OFFSET_MASK) == 0 and count > 0
        ' Flush current sector
        debug[CH_FILE]("  [do_write_h] Sector full, flushing sector ", udec_(h_sector[handle]))
        bytemove(@buf, p_hbuf, SECTOR_SIZE)
        writeSector(h_sector[handle], BUF_DATA)
        h_flags[handle] &= !HF_DIRTY
        h_buf_sector[handle] := -1

        h_sector[handle]++
        ' Check if we crossed a cluster boundary
        if ((h_sector[handle] - cluster_offset) & (sec_per_clus - 1)) == 0
          ' Need to allocate new cluster or follow chain
#ifdef SD_INCLUDE_DEFRAG
          if h_prealloc_end[handle] > 0
            new_cluster := h_cluster[handle] + 1
            if new_cluster > h_prealloc_end[handle]
              debug[CH_FILE]("  [do_write_h] Pre-allocated space exhausted")
              quit                                                                '  Return what we've written so far
            h_cluster[handle] := new_cluster
            h_sector[handle] := clus2sec(new_cluster)
          else
#endif
            new_cluster := allocateCluster(h_cluster[handle])
            if new_cluster < 0
              debug[CH_FILE]("  [do_write_h] Failed to allocate cluster")
              quit                                                                  ' Return what we've written so far
            debug[CH_FILE]("  [do_write_h] Allocated new cluster ", udec_(new_cluster))
            h_cluster[handle] := new_cluster
            h_sector[handle] := clus2sec(new_cluster)

    debug[CH_FILE]("  [do_write_h] Wrote ", udec_(bytes_written), " bytes, size now ", udec_(h_size[handle]))


PRI do_seek_h(handle, position) : result | target_cluster_idx, cluster, idx, fat_addr, sector_in_cluster
' Handle-based seek (V3) - seeks to absolute position in file.
' Position must be <= file size (no seeking past EOF).
'
' @param handle - Valid file handle
' @param position - Absolute byte position to seek to
' @returns result - SUCCESS (0) on success, negative error code on failure
' @local target_cluster_idx - Target cluster index from start
' @local cluster - Current cluster during walk
' @local idx - Loop counter
' @local fat_addr - Address of FAT entry
' @local sector_in_cluster - Sector offset within cluster

  ' Validate handle
  if not validateHandle(handle)
    debug[CH_FILE]("  [do_seek_h] Invalid handle: ", sdec_(handle))
    result := E_INVALID_HANDLE
  elseif h_flags[handle] & HF_DIR
    result := E_NOT_A_DIR_HANDLE
  elseif position > h_size[handle]
    ' Validate position is within file
    debug[CH_FILE]("  [do_seek_h] Position ", udec_(position), " > size ", udec_(h_size[handle]))
    result := E_END_OF_FILE
  else
    debug[CH_FILE]("  [do_seek_h] handle=", udec_(handle), " pos ", udec_(h_position[handle]), " -> ", udec_(position))

    ' Fast path: if position is in the same sector, just update position
    if (position >> SECTOR_SHIFT) == (h_position[handle] >> SECTOR_SHIFT)
      h_position[handle] := position
      debug[CH_FILE]("  [do_seek_h] Same sector, fast path")
    else
      ' Calculate which cluster the target position is in
      ' target_cluster_idx = how many clusters from the start
      target_cluster_idx := position / (sec_per_clus << SECTOR_SHIFT)

      ' Walk the FAT chain from the file's start cluster
      cluster := h_start_clus[handle]

      ' BUG FIX: Guard against Spin2's count-down behavior
      ' When target_cluster_idx is 0, "repeat idx from 0 to -1" would execute twice
      ' (counting down from 0 to -1), incorrectly walking the FAT chain.
      ' Only walk the chain if we need to move to a different cluster.
      if target_cluster_idx > 0
        repeat idx from 0 to target_cluster_idx - 1
          ' Read FAT entry for current cluster
          if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0
            debug[CH_FILE]("  [do_seek_h] FAT read FAILED for cluster ", udec_(cluster))
            result := E_IO_ERROR
            quit
          fat_addr := @fat_buf + ((cluster << 2) & SECTOR_OFFSET_MASK)
          cluster := long[fat_addr]
          if cluster +>= FAT32_EOC_MIN
            ' End of chain reached before target - shouldn't happen
            debug[CH_FILE]("  [do_seek_h] Unexpected end of FAT chain at index ", udec_(idx))
            result := E_END_OF_FILE
            quit

      if result == 0
        ' Calculate sector within cluster
        sector_in_cluster := (position >> SECTOR_SHIFT) & (sec_per_clus - 1)

        ' Update handle state
        h_cluster[handle] := cluster
        h_sector[handle] := clus2sec(cluster) + sector_in_cluster
        h_position[handle] := position
        h_buf_sector[handle] := -1                                                ' Invalidate buffer cache
        debug[CH_FILE]("  [do_seek_h] Seek complete: cluster=", udec_(cluster), " sector=", udec_(h_sector[handle]))


PRI do_sync_h(handle) : result | p_buf
' Sync handle buffer to disk (V3) - flushes pending writes and updates directory.
' Does NOT close handle - file remains open for further operations.
'
' @param handle - Valid file handle
' @returns result - SUCCESS (0) on success, E_INVALID_HANDLE on failure
' @local p_buf - Pointer to handle's buffer

  ' Validate handle
  if not validateHandle(handle)
    debug[CH_FILE]("  [do_sync_h] Invalid handle: ", sdec_(handle))
    result := E_INVALID_HANDLE
  elseif h_flags[handle] & HF_DIR
    result := E_NOT_A_DIR_HANDLE
  else
    debug[CH_FILE]("  [do_sync_h] Syncing handle=", udec_(handle), " flags=$", uhex_byte_(h_flags[handle]))

    ' If buffer is dirty, flush it to disk
    if h_flags[handle] & HF_DIRTY
      debug[CH_FILE]("  [do_sync_h] Flushing dirty buffer for sector ", udec_(h_buf_sector[handle]))
      p_buf := getHandleBuffer(handle)
      bytemove(@buf, p_buf, SECTOR_SIZE)
      writeSector(h_buf_sector[handle], BUF_DATA)
      h_flags[handle] &= !HF_DIRTY

    ' If opened for write, update directory entry with current size
    result := SUCCESS
    if h_flags[handle] & HF_WRITE
      debug[CH_FILE]("  [do_sync_h] Updating directory: size=", udec_(h_size[handle]))
      if readSector(h_dir_sector[handle], BUF_DIR) < 0
        debug[CH_FILE]("  [do_sync_h] Directory read FAILED for sector ", udec_(h_dir_sector[handle]))
        result := E_IO_ERROR
      else
        long[@dir_buf + h_dir_offset[handle] + DE_FILESIZE_OFFSET] := h_size[handle]
        long[@dir_buf + h_dir_offset[handle] + DE_WRT_TIME_OFFSET] := date_stamp    ' Update modification timestamp
        writeSector(h_dir_sector[handle], BUF_DIR)

    debug[CH_FILE]("  [do_sync_h] Sync complete")


PRI do_idle_flush() | idx
' Auto-flush dirty handles after idle period. Scans all handles for HF_DIRTY,
' syncs each, then updates FSInfo if needed. Checks pb_cmd between each handle
' sync to abort immediately if a command arrives.

  repeat idx from 0 to MAX_OPEN_FILES - 1
    if pb_cmd <> CMD_NONE
      return                                                                    ' Command arrived, abort flush
    if h_flags[idx] & HF_DIRTY
      do_sync_h(idx)
  updateFSInfo()
  flush_done := true


PRI do_sync_all() : result | idx
' Sync all open write handles (V3) - flushes all write handles to disk.
' Called by unmount() to ensure all data is written before stopping.
'
' @returns result - SUCCESS (0) on success
' @local idx - Loop variable

  debug[CH_FILE]("  [do_sync_all] Syncing all handles")
  repeat idx from 0 to MAX_OPEN_FILES - 1
    if h_flags[idx] & HF_WRITE
      debug[CH_FILE]("  [do_sync_all] Syncing write handle ", udec_(idx))
      do_sync_h(idx)

  debug[CH_FILE]("  [do_sync_all] All handles synced")
  result := SUCCESS


PRI do_open_dir(p_path) : handle | start_cluster
' Open directory for enumeration (V3 handle) - returns handle for iterating entries.
' Directory handles share the existing handle pool with file handles.
'
' @param p_path - Pointer to null-terminated path string ("." or "" for CWD)
' @returns handle - Handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure
' @local start_cluster - Starting cluster of the directory

  ' Allocate a handle slot
  handle := allocateHandle()
  if handle < 0
    debug[CH_DIR]("  [do_open_dir] No free handles")
  else
    ' Determine which directory to enumerate
    if byte[p_path] == 0 or (byte[p_path] == "." and byte[p_path + 1] == 0)
      ' Empty string or "." -- enumerate calling cog's CWD
      n_sec := cog_dir_sec[pb_caller]
      start_cluster := sec2clus(n_sec)
    elseif byte[p_path] == "/" and byte[p_path + 1] == 0
      ' Bare "/" -- enumerate root directory
      n_sec := root_sec
      start_cluster := sec2clus(root_sec)
    else
      ' Search for the named directory
      if not searchDirectory(p_path)
        debug[CH_DIR]("  [do_open_dir] Directory not found: ", zstr_(p_path))
        freeHandle(handle)
        handle := E_FILE_NOT_FOUND
      elseif not (attributes() & ATTR_DIRECTORY)
        ' Verify it's a directory
        debug[CH_DIR]("  [do_open_dir] Not a directory: ", zstr_(p_path))
        freeHandle(handle)
        handle := E_NOT_A_DIR
      else
        start_cluster := firstCluster()
        if start_cluster < 2
          start_cluster := ROOT_CLUSTER                                          ' Root directory

    ' Populate handle state (only if handle is still valid)
    if handle >= 0
      h_flags[handle] := HF_DIR
      h_start_clus[handle] := start_cluster
      h_cluster[handle] := start_cluster
      h_sector[handle] := clus2sec(start_cluster)
      h_position[handle] := 0                                                  ' Entry index
      h_size[handle] := 0                                                      ' Not used for directories
      h_buf_sector[handle] := -1                                               ' No sector cached yet
      debug[CH_DIR]("  [do_open_dir] Success: handle=", udec_(handle), " cluster=", udec_(start_cluster))


PRI do_read_dir_h(handle) : result | p_hbuf, offset, char, attrib, cluster, fat_addr, next_cluster
' Read next directory entry from handle (V3) - skips deleted and LFN entries.
' Copies valid entry into entry_buffer for caller to inspect via fileName()/attributes().
'
' @param handle - Valid directory handle (must have HF_DIR flag)
' @returns result - SUCCESS on valid entry, E_FILE_NOT_FOUND at end of directory
' @local p_hbuf - Pointer to handle's buffer
' @local offset - Byte offset within current sector
' @local char - First byte of entry
' @local attrib - Entry attribute byte
' @local cluster - Current cluster number
' @local fat_addr - Address of FAT entry
' @local next_cluster - Next cluster in chain

  ' Validate handle
  if not validateHandle(handle)
    result := E_INVALID_HANDLE
  elseif not (h_flags[handle] & HF_DIR)
    result := E_INVALID_HANDLE
  else
    p_hbuf := getHandleBuffer(handle)
    result := E_FILE_NOT_FOUND                                                  ' Default: end of directory

    repeat
      ' Check if we need to advance to next sector (16 entries per 512-byte sector)
      if h_position[handle] > 0 and (h_position[handle] & (DIR_ENTRIES_PER_SECTOR - 1)) == 0
        h_sector[handle]++
        ' Check if we crossed a cluster boundary
        if ((h_sector[handle] - cluster_offset) & (sec_per_clus - 1)) == 0
          ' Follow FAT chain to next cluster
          cluster := h_cluster[handle]
          if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0
            debug[CH_DIR]("  [do_read_dir_h] FAT read FAILED for cluster ", udec_(cluster))
            result := E_IO_ERROR
            quit
          fat_addr := @fat_buf + ((cluster << 2) & SECTOR_OFFSET_MASK)
          next_cluster := long[fat_addr]
          if next_cluster +>= FAT32_EOC_MIN
            quit                                                                ' End of directory chain
          h_cluster[handle] := next_cluster
          h_sector[handle] := clus2sec(next_cluster)
        h_buf_sector[handle] := -1                                              ' Force re-read

      ' Load current sector into handle's buffer if not cached
      if h_buf_sector[handle] <> h_sector[handle]
        if readSector(h_sector[handle], BUF_DATA) < 0
          debug[CH_DIR]("  [do_read_dir_h] Sector read FAILED for sector ", udec_(h_sector[handle]))
          result := E_IO_ERROR
          quit
        bytemove(p_hbuf, @buf, SECTOR_SIZE)
        h_buf_sector[handle] := h_sector[handle]

      ' Calculate byte offset within sector (each entry is 32 bytes)
      offset := (h_position[handle] & (DIR_ENTRIES_PER_SECTOR - 1)) * DIR_ENTRY_SIZE   ' byte offset within sector

      ' Read first byte and attributes
      char := byte[p_hbuf + offset]
      attrib := byte[p_hbuf + offset + 11]

      ' Advance position for next call
      h_position[handle]++

      ' Check for end of directory
      if char == $00
        quit                                                                    ' E_FILE_NOT_FOUND (default)

      ' Skip deleted entries and LFN entries
      if char == DIR_ENTRY_DELETED
        next
      if attrib == ATTR_LFN                                                          ' LFN entry
        next
      ' Skip entries with hidden/system attributes that aren't normally shown
      if attrib & (ATTR_HIDDEN | ATTR_SYSTEM | ATTR_VOLUME_ID) <> 0
        next

      ' Valid entry found - copy to entry_buffer
      bytemove(@entry_buffer, p_hbuf + offset, DIR_ENTRY_SIZE)
      result := SUCCESS
      quit


PRI do_close_dir_h(handle) : result
' Close directory handle (V3) - releases handle back to pool.
'
' @param handle - Valid directory handle
' @returns result - SUCCESS on success, E_INVALID_HANDLE if invalid

  if not validateHandle(handle)
    result := E_INVALID_HANDLE
  elseif not (h_flags[handle] & HF_DIR)
    result := E_INVALID_HANDLE
  else
    debug[CH_DIR]("  [do_close_dir_h] Closing handle=", udec_(handle))
    freeHandle(handle)
    result := SUCCESS


PRI do_newfile(name_ptr) : result | temp
' Internal new file operation - creates a new file in current directory.
'
' @param name_ptr - Pointer to null-terminated filename string
' @returns result - SUCCESS on success, E_FILE_EXISTS if file exists
' @local temp - Temporary calculation variable

  do_close()
  if searchDirectory(name_ptr)
    result := E_FILE_EXISTS
  elseif entry_address == 0
    ' Guard: entry_address 0 means searchDirectory never found a valid directory
    ' (e.g., path component doesn't exist). Writing at address 0 would corrupt the MBR.
    debug[CH_DIR]("  [do_newfile] entry_address=0 -- path not valid, aborting")
    result := E_FILE_NOT_FOUND
  else
    temp := (entry_address + cluster_offset << SECTOR_SHIFT) & (sec_per_clus << SECTOR_SHIFT - 1)
    if temp == (sec_per_clus << SECTOR_SHIFT - DIR_ENTRY_SIZE)
      if dir_buf[LAST_DIR_ENTRY_OFFSET] == $00                                                    ' Check dir buffer after searchDirectory
        temp := allocateCluster(byte2clus(entry_address))
        clearCluster(temp)

    dirEntSetAttr(@entry_buffer, ATTR_ARCHIVE)
    dirEntSetCreateStamp(@entry_buffer, date_stamp)
    dirEntSetStartClus(@entry_buffer, 0)
    dirEntSetModifyStamp(@entry_buffer, date_stamp)
    dirEntSetFileSize(@entry_buffer, 0)
    flags |= F_NEWDIR
    result := SUCCESS


PRI do_newdir(name_ptr) : result | temp
' Internal new directory operation - creates a new directory in current directory.
'
' @param name_ptr - Pointer to null-terminated directory name string
' @returns result - SUCCESS on success, E_FILE_EXISTS if directory exists
' @local temp - Temporary calculation variable for cluster allocation

  do_close()
  if searchDirectory(name_ptr)
    result := E_FILE_EXISTS
  elseif entry_address == 0
    ' Guard: entry_address 0 means searchDirectory never found a valid directory
    ' (e.g., path component doesn't exist). Writing at address 0 would corrupt the MBR.
    debug[CH_DIR]("  [do_newdir] entry_address=0 -- path not valid, aborting")
    result := E_FILE_NOT_FOUND
  else
    temp := (entry_address + cluster_offset << SECTOR_SHIFT) & (sec_per_clus << SECTOR_SHIFT - 1)
    if temp == sec_per_clus << SECTOR_SHIFT - DIR_ENTRY_SIZE
      if dir_buf[LAST_DIR_ENTRY_OFFSET] == $00                                                    ' Check dir buffer after searchDirectory
        temp := allocateCluster(byte2clus(entry_address))
        clearCluster(temp)

    temp := allocateCluster(0)
    dirEntSetAttr(@entry_buffer, ATTR_DIRECTORY)                                            ' Directory attribute
    dirEntSetCreateStamp(@entry_buffer, date_stamp)
    dirEntSetStartClus(@entry_buffer, temp)
    dirEntSetModifyStamp(@entry_buffer, date_stamp)
    dirEntSetFileSize(@entry_buffer, 0)

    if readSector(entry_address >> SECTOR_SHIFT, BUF_DIR) < 0
      debug[CH_DIR]("  [do_newdir] Directory read FAILED for sector ", udec_(entry_address >> SECTOR_SHIFT))
      result := E_IO_ERROR
    else
      debug[CH_DIR]("  [do_newdir] Before write: dir_buf[", udec_(entry_address & SECTOR_OFFSET_MASK), "]=[", lstr_(@dir_buf + (entry_address & SECTOR_OFFSET_MASK), 11), "]")
      bytemove(@dir_buf + (entry_address & SECTOR_OFFSET_MASK), @entry_buffer, DIR_ENTRY_SIZE)
      debug[CH_DIR]("  [do_newdir] After copy: dir_buf[", udec_(entry_address & SECTOR_OFFSET_MASK), "]=[", lstr_(@dir_buf + (entry_address & SECTOR_OFFSET_MASK), 11), "]")
      debug[CH_DIR]("  [do_newdir] entry_buffer=[", lstr_(@entry_buffer, 11), "]")
      writeSector(entry_address >> SECTOR_SHIFT, BUF_DIR)
      ' Verify write by reading back
      dir_sec_in_buf := -1                                                      ' Force re-read
      if readSector(entry_address >> SECTOR_SHIFT, BUF_DIR) < 0
        debug[CH_DIR]("  [do_newdir] Verify read FAILED for sector ", udec_(entry_address >> SECTOR_SHIFT))
      else
        debug[CH_DIR]("  [do_newdir] After verify read: dir_buf[", udec_(entry_address & SECTOR_OFFSET_MASK), "]=[", lstr_(@dir_buf + (entry_address & SECTOR_OFFSET_MASK), 11), "]")

      bytefill(@dir_buf, 0, SECTOR_SIZE)
      bytemove(@dir_buf[0], string(".          "), SFN_TOTAL_LEN)
      byte[@dir_buf + DE_ATTR_OFFSET] := ATTR_DIRECTORY
      long[@dir_buf + DE_CRT_TIME_OFFSET] := date_stamp
      word[@dir_buf + DE_CLUS_HI_OFFSET] := temp >> 16
      long[@dir_buf + DE_WRT_TIME_OFFSET] := date_stamp
      word[@dir_buf + DE_CLUS_LO_OFFSET] := temp & $FFFF

      temp := byte2clus(entry_address)
      if temp == ROOT_CLUSTER
        temp := 0
      bytemove(@dir_buf[DIR_ENTRY_SIZE], string("..         "), SFN_TOTAL_LEN)
      byte[@dir_buf + DIR_ENTRY_SIZE + DE_ATTR_OFFSET] := ATTR_DIRECTORY
      long[@dir_buf + DIR_ENTRY_SIZE + DE_CRT_TIME_OFFSET] := date_stamp
      word[@dir_buf + DIR_ENTRY_SIZE + DE_CLUS_HI_OFFSET] := temp >> 16
      long[@dir_buf + DIR_ENTRY_SIZE + DE_WRT_TIME_OFFSET] := date_stamp
      word[@dir_buf + DIR_ENTRY_SIZE + DE_CLUS_LO_OFFSET] := temp & $FFFF

      n_sec := clus2sec(firstCluster())
      debug[CH_DIR]("  [do_newdir] Writing ./.. to sector ", udec_(n_sec), ": dir_buf[0]=[", lstr_(@dir_buf, 11), "] dir_buf[32]=[", lstr_(@dir_buf + 32, 11), "]")
      writeSector(n_sec, BUF_DIR)
      dir_sec_in_buf := n_sec
      ' Verify the ./.. write
      dir_sec_in_buf := -1
      if readSector(n_sec, BUF_DIR) < 0
        debug[CH_DIR]("  [do_newdir] Verify ./.. read FAILED for sector ", udec_(n_sec))
      else
        debug[CH_DIR]("  [do_newdir] After ./.. verify: dir_buf[0]=[", lstr_(@dir_buf, 11), "] dir_buf[32]=[", lstr_(@dir_buf + 32, 11), "]")
      result := SUCCESS


PRI do_delete(name_ptr) : result
' Internal delete operation - deletes a file and frees its clusters.
'
' @param name_ptr - Pointer to null-terminated filename string
' @returns result - SUCCESS on success, E_FILE_NOT_FOUND if not found

  do_close()
  if searchDirectory(name_ptr) == 0
    result := E_FILE_NOT_FOUND
  elseif attributes() & ATTR_LFN                                               ' Check read-only, hidden, system, volume label
    result := E_FILE_NOT_FOUND                                                  ' Protected file (but allow directories)
  else
    dir_buf[entry_address & SECTOR_OFFSET_MASK] := DIR_ENTRY_DELETED                                         ' Mark entry as deleted in dir buffer
    writeSector(entry_address >> SECTOR_SHIFT, BUF_DIR)

    ' Only deallocate clusters if file has data (cluster >= 2)
    result := freeClusterChain(firstCluster())


PRI do_chdir(name_ptr) : result
' Internal change directory operation - changes current directory.
'
' @param name_ptr - Pointer to null-terminated directory name string
' @returns result - SUCCESS on success, E_NOT_A_DIR if not a directory

  do_close()
  if byte[name_ptr] == "/" and byte[name_ptr + 1] == $00
    ' Bare "/" means root directory -- no search needed
    cog_dir_sec[pb_caller] := root_sec
    result := SUCCESS
  elseif searchDirectory(name_ptr)
    if (attributes() & ATTR_DIRECTORY) or (n_sec == root_sec)
      cog_dir_sec[pb_caller] := n_sec
      result := SUCCESS
    else
      debug[CH_DIR]("  [do_chdir] NOT a directory: attr=", uhex_byte_(attributes()))
      result := E_NOT_A_DIR
  else
    debug[CH_DIR]("  [do_chdir] searchDirectory FAILED for: ", zstr(name_ptr), " dir_sec=", udec_(cog_dir_sec[pb_caller]))
    result := E_NOT_A_DIR


PRI do_freespace() : result | cluster
' Internal free space calculation - returns free sectors on card.
'
' @returns result - Number of free sectors
' @local cluster - Loop variable for FAT scan

  if not (flags & F_MOUNTED)
    result := 0
  else
    n_sec := fat_sec
    repeat sec_per_fat
      if readSector(n_sec++, BUF_FAT) < 0
        debug[CH_MOUNT]("  [do_freespace] FAT read FAILED, returning partial count")
        quit
      repeat cluster from 0 to FAT_ENTRIES_PER_SECTOR - 1
        if long[@fat_buf + cluster << 2] == 0
          result++
    result := result * sec_per_clus


PRI do_sync()
' Internal sync operation - flushes pending directory writes without closing file.

  if flags & F_NEWDIR
    if readSector(entry_address >> SECTOR_SHIFT, BUF_DIR) < 0
      debug[CH_MOUNT]("  [do_sync] Directory read FAILED for sector ", udec_(entry_address >> SECTOR_SHIFT))
    else
      bytemove(@dir_buf + (entry_address & SECTOR_OFFSET_MASK), @entry_buffer, DIR_ENTRY_SIZE)
      writeSector(entry_address >> SECTOR_SHIFT, BUF_DIR)
    flags := flags & !F_NEWDIR


PRI do_rename(old_name, new_name) : result | bookmark, temp_sec, idx, saved_entry[8], p_buf
' Internal rename operation - renames file/directory by updating directory entry.
' Finds old file, saves entry, parses new_name into 8.3 format, writes back.
'
' @param old_name - Pointer to current filename string
' @param new_name - Pointer to new filename string
' @returns result - SUCCESS on success, E_FILE_NOT_FOUND on failure
' @local bookmark - Saved entry address
' @local temp_sec - Saved directory sector
' @local idx - Loop counter
' @local saved_entry - Saved directory entry (32 bytes = 8 longs)
' @local p_buf - Pointer to buffer position

  debug[CH_DIR]("  [do_rename] old=", zstr_(old_name), " new=", zstr_(new_name), " dir_sec=", udec_(cog_dir_sec[pb_caller]))
  if not searchDirectory(old_name)
    debug[CH_DIR]("  [do_rename] Old file NOT FOUND")
    result := E_FILE_NOT_FOUND
  else
    debug[CH_DIR]("  [do_rename] Found old file, entry_address=", uhex_(entry_address))
    bookmark := entry_address
    temp_sec := cog_dir_sec[pb_caller]
    bytemove(@saved_entry, @entry_buffer, DIR_ENTRY_SIZE)                                  ' Save complete entry (32 bytes)
    cog_dir_sec[pb_caller] := entry_address >> SECTOR_SHIFT                                ' Search in same directory
    idx := 0
    repeat until byte[new_name + idx] == $00
      if byte[new_name + idx] == "/"
        new_name += idx+1
        idx := 0
      idx++
    debug[CH_DIR]("  [do_rename] Checking if new name exists...")
    if searchDirectory(new_name) <> 0                                           ' Verify new name doesn't exist
      debug[CH_DIR]("  [do_rename] New name already exists!")
      result := E_FILE_EXISTS
    else
      debug[CH_DIR]("  [do_rename] New name doesn't exist, proceeding")
      bytemove(@entry_buffer, @saved_entry, DIR_ENTRY_SIZE)                                ' Restore complete entry
      if readSector(bookmark >> SECTOR_SHIFT, BUF_DIR) < 0
        debug[CH_DIR]("  [do_rename] Directory read FAILED for sector ", udec_(bookmark >> SECTOR_SHIFT))
        result := E_IO_ERROR
      else
        ' Parse new_name directly into buffer in 8.3 format
        p_buf := @dir_buf + (bookmark & SECTOR_OFFSET_MASK)
        idx := 0
        repeat until byte[new_name + idx] == "/" or byte[new_name + idx] == $00
          idx++
        bytefill(p_buf, " ", SFN_TOTAL_LEN)                                               ' Clear name field
        bytemove(p_buf, new_name, idx <# 12)                                   ' Copy name
        ' Convert to uppercase first (must happen before 8.3 rearrangement)
        repeat idx from 0 to 10
          case byte[p_buf + idx]
            "a".."z" : byte[p_buf + idx] -= ASCII_CASE_OFFSET
        ' Handle 8.3 extension separator
        repeat idx from 0 to 10
          if byte[p_buf + idx] == "."
            bytemove(p_buf + 8, p_buf + idx + 1, 3)
            bytefill(p_buf + idx, " ", 8 - idx)
            quit
        writeSector(bookmark >> SECTOR_SHIFT, BUF_DIR)
        cog_dir_sec[pb_caller] := temp_sec
        debug[CH_DIR]("  [do_rename] SUCCESS")
        result := SUCCESS


PRI do_set_vol_label(p_label) : result | idx, ch, p_entry, label_83[3], pVBR
' Internal set volume label - updates BPB and root directory volume label entry.
'
' @param p_label - Pointer to new volume label string (max 11 chars)
' @returns result - SUCCESS on success, E_IO_ERROR on failure
' @local idx - Character index
' @local ch - Current character being processed
' @local p_entry - Pointer to directory entry
' @local label_83 - 11-byte buffer for formatted 8.3 label
' @local pVBR - Pointer to Volume Boot Record overlay

  ' Format label: uppercase, space-pad to 11 chars
  bytefill(@label_83, " ", SFN_TOTAL_LEN)
  idx := 0
  repeat while byte[p_label + idx] <> 0 and idx < 11
    ch := byte[p_label + idx]
    if ch >= "a" and ch <= "z"
      ch -= ASCII_CASE_OFFSET
    BYTE[@label_83][idx] := ch
    idx++

  debug[CH_MOUNT]("  [do_set_vol_label] new label=[", lstr_(@label_83, SFN_TOTAL_LEN), "]")

  ' Step 1: Update BPB volume label (VBR sector)
  if readSector(vbr_sec, BUF_DATA) < 0
    debug[CH_MOUNT]("  [do_set_vol_label] FAIL: read VBR")
    result := E_IO_ERROR
  else
    pVBR := @buf
    bytemove(vbrVolLabelAddr(pVBR), @label_83, SFN_TOTAL_LEN)
    if writeSector(vbr_sec, BUF_DATA) < 0
      debug[CH_MOUNT]("  [do_set_vol_label] FAIL: write VBR")
      result := E_IO_ERROR

  ' Step 2: Find and update volume label entry in root directory
  if result == 0
    n_sec := root_sec
    if readSector(n_sec, BUF_DIR) < 0
      debug[CH_MOUNT]("  [do_set_vol_label] FAIL: read root dir")
      result := E_IO_ERROR
    else
      idx := 0
      repeat
        p_entry := @dir_buf + (idx & SECTOR_OFFSET_MASK)
        if byte[p_entry] == $00                                                        ' End of directory
          quit
        if byte[p_entry] <> DIR_ENTRY_DELETED and dirEntAttr(p_entry) == ATTR_VOLUME_ID                          ' Volume label entry found
          bytemove(p_entry, @label_83, SFN_TOTAL_LEN)
          writeSector(n_sec, BUF_DIR)
          debug[CH_MOUNT]("  [do_set_vol_label] Updated root dir entry")
          quit
        idx += DIR_ENTRY_SIZE
        if idx & SECTOR_OFFSET_MASK == 0
          readNextSector(BUF_DIR)

      ' Step 3: Update in-memory copy
      bytemove(@vol_label, @label_83, SFN_TOTAL_LEN)
      vol_label[11] := 0

      debug[CH_MOUNT]("  [do_set_vol_label] SUCCESS")
      result := SUCCESS


PRI do_movefile(name_ptr, dest_folder) : result | bookmark, p_temp, temp_sec
' Internal move file operation - moves file from current directory to destination.
'
' @param name_ptr - Pointer to null-terminated filename to move
' @param dest_folder - Pointer to null-terminated destination folder name
' @returns result - SUCCESS on success, E_FILE_NOT_FOUND on failure
' @local bookmark - Saved entry address
' @local p_temp - Pointer to temporary filename buffer
' @local temp_sec - Saved directory sector

  result := E_FILE_NOT_FOUND
  p_temp := @"FILENAME.TXT"
  if do_open(name_ptr) == SUCCESS
    bookmark := entry_address
    bytemove(p_temp, filename(), 12)
    temp_sec := cog_dir_sec[pb_caller]
    if do_chdir(dest_folder) == SUCCESS
      if bookmark >> SECTOR_SHIFT == n_sec
        result := E_FILE_EXISTS                                                 ' Same directory
      elseif do_newfile(p_temp) == SUCCESS
        debug[CH_DIR]("  [do_movefile] newfile OK, new entry_address=", uhex_(entry_address))
        debug[CH_DIR]("  [do_movefile] Reading sector ", udec_(bookmark >> SECTOR_SHIFT), " (dir_sec_in_buf=", sdec_(dir_sec_in_buf), ")")
        if readSector(bookmark >> SECTOR_SHIFT, BUF_DIR) < 0
          debug[CH_DIR]("  [do_movefile] Directory read FAILED for sector ", udec_(bookmark >> SECTOR_SHIFT))
          result := E_IO_ERROR
        else
          debug[CH_DIR]("  [do_movefile] After read: dir_buf[128]=[", lstr_(@dir_buf + 128, 11), "] dir_buf[", udec_(bookmark & SECTOR_OFFSET_MASK), "]=[", lstr_(@dir_buf + (bookmark & SECTOR_OFFSET_MASK), 11), "]")
          bytemove(@entry_buffer, @dir_buf + (bookmark & SECTOR_OFFSET_MASK), 32)
          debug[CH_DIR]("  [do_movefile] Copied entry: [", lstr_(@entry_buffer, 11), "]")
          byte[@dir_buf + (bookmark & SECTOR_OFFSET_MASK)] := DIR_ENTRY_DELETED
          debug[CH_DIR]("  [do_movefile] After $E5: dir_buf[128]=[", lstr_(@dir_buf + 128, 11), "]")
          writeSector(bookmark >> SECTOR_SHIFT, BUF_DIR)
          debug[CH_DIR]("  [do_movefile] Calling do_close, flags=", uhex_(flags))
          do_close()
          result := SUCCESS
      else
        debug[CH_DIR]("  [do_movefile] do_newfile FAILED")
    else
      debug[CH_DIR]("  [do_movefile] do_chdir FAILED for: ", zstr(dest_folder))
    cog_dir_sec[pb_caller] := temp_sec


PRI do_readdir(entry_num) : result | idx, char, attrib
' Internal read directory operation - reads directory entry at specified index.
'
' @param entry_num - Entry index to read (0-based)
' @returns result - SUCCESS on success, E_FILE_NOT_FOUND if entry doesn't exist
' @local idx - Current byte offset in directory
' @local char - First character of entry
' @local attrib - Entry attributes

  result := E_FILE_NOT_FOUND
  idx := 0
  n_sec := cog_dir_sec[pb_caller]
  if readSector(n_sec, BUF_DIR) < 0
    debug[CH_DIR]("  [do_readdir] Directory read FAILED for sector ", udec_(n_sec))
    result := E_IO_ERROR
  else
    repeat until entry_num == -1
      char := byte[@dir_buf + (idx & SECTOR_OFFSET_MASK)]
      attrib := byte[@dir_buf + (idx & SECTOR_OFFSET_MASK) + DE_ATTR_OFFSET]

      if char == $00
        quit                                                                    ' E_FILE_NOT_FOUND (default)
      elseif char <> DIR_ENTRY_DELETED
        if attrib & (ATTR_HIDDEN | ATTR_SYSTEM | ATTR_VOLUME_ID) == 0
          entry_num--
          if entry_num == -1
            bytemove(@entry_buffer, @dir_buf + (idx & SECTOR_OFFSET_MASK), 32)
            result := SUCCESS
      idx += DIR_ENTRY_SIZE
      if idx & SECTOR_OFFSET_MASK == 0
        readNextSector(BUF_DIR)


#ifdef SD_INCLUDE_RAW

PRI do_init_card_only() : result
' Internal card-only init (raw mode) - initialize card for raw sector access.
' Sets driver_mode to MODE_RAW without filesystem parsing.
'
' @returns result - SUCCESS on success, E_INIT_FAILED on failure

  dir_sec_in_buf := -1
  fat_sec_in_buf := -1
  sec_in_buf := -1
  debug[CH_INIT]("  [do_init_card_only] Calling initCard()...")
  if initCard()
    debug[CH_INIT]("  [do_init_card_only] Card initialized successfully")
    driver_mode := MODE_RAW
    debug[CH_INIT]("  [do_init_card_only] SUCCESS, mode=RAW")
    if card_warning_flags & CW_CMD13_UNRELIABLE
      debug[CH_INIT]("  [do_init_card_only] WARNING: CMD13 unreliable on this card - status checks disabled")
    result := SUCCESS
  else
    debug[CH_INIT]("  [do_init_card_only] FAIL: initCard() returned false")
    driver_mode := MODE_NONE
    result := last_init_error


PRI do_get_card_size() : result | csd[4], c_size, read_bl_len, c_size_mult
' Internal get card size operation - returns total number of 512-byte sectors.
' Runs on worker cog where smart pins are configured.
'
' @returns result - Total number of 512-byte sectors on the card
' @local csd - CSD register data (4 longs = 16 bytes)
' @local c_size - Capacity size field from CSD
' @local read_bl_len - Read block length from CSD
' @local c_size_mult - Size multiplier from CSD

  ' Read CSD using CMD9
  if not readCSD(@csd)
    debug[CH_IDENT]("  [do_get_card_size] Failed to read CSD")
    result := 0
  else
    ' CSD structure version is in bits [127:126] (byte 0, bits 7:6)
    if (csd.byte[0] >> 6) == 0
      ' CSD Version 1.0 (SDSC)
      read_bl_len := csd.byte[5] & $0F
      c_size := (csd.byte[6] & $03) << 10
      c_size |= csd.byte[7] << 2
      c_size |= csd.byte[8] >> 6
      c_size_mult := (csd.byte[9] & $03) << 1
      c_size_mult |= csd.byte[10] >> 7
      result := (c_size + 1) << (c_size_mult + 2 + read_bl_len - 9)
      debug[CH_IDENT]("  [do_get_card_size] CSD v1.0: ", udec(result), " sectors")
    else
      ' CSD Version 2.0 (SDHC/SDXC)
      c_size := (csd.byte[7] & $3F) << 16
      c_size |= csd.byte[8] << 8
      c_size |= csd.byte[9]
      result := (c_size + 1) << 10                                              ' * 1024 sectors (512KB units)
      debug[CH_IDENT]("  [do_get_card_size] CSD v2.0: ", udec(result), " sectors")


PRI do_test_cmd13() : r2_response | r1, status
' Internal CMD13 test - sends CMD13 and returns raw R2 response.
' Uses sendCmd13Transaction() for the wire transaction.
'
' @returns r2_response - R2 response word ($0000=OK, $FFFF=timeout, other=error)
' @local r1 - R1 response byte
' @local status - Status byte from R2

  r1, status := sendCmd13Transaction()
  if r1 == -1
    r2_response := $FFFF
  else
    r2_response := (r1 << 8) | status

#endif

#ifdef SD_INCLUDE_REGISTERS

PRI do_read_scr(p_buf) : result
' Internal read SCR operation - reads the 8-byte SCR register into buffer.
' Runs on worker cog where smart pins are configured.
'
' @param p_buf - Pointer to 8-byte buffer to receive SCR data
' @returns result - SUCCESS on success, E_IO_ERROR on failure

  if readSCR(p_buf)
    debug[CH_IDENT]("  [do_read_scr] SCR read successfully")
    result := SUCCESS
  else
    debug[CH_IDENT]("  [do_read_scr] SCR read failed")
    result := E_IO_ERROR


PRI do_read_cid(p_buf) : result
' Internal read CID operation - reads the 16-byte CID register into buffer.
' Runs on worker cog where smart pins are configured.
'
' @param p_buf - Pointer to 16-byte buffer to receive CID data
' @returns result - SUCCESS on success, E_IO_ERROR on failure

  if readCID(p_buf)
    debug[CH_IDENT]("  [do_read_cid] CID read successfully")
    result := SUCCESS
  else
    debug[CH_IDENT]("  [do_read_cid] CID read failed")
    result := E_IO_ERROR


PRI do_read_csd(p_buf) : result
' Internal read CSD operation - reads the 16-byte CSD register into buffer.
' Runs on worker cog where smart pins are configured.
'
' @param p_buf - Pointer to 16-byte buffer to receive CSD data
' @returns result - SUCCESS on success, E_IO_ERROR on failure

  if readCSD(p_buf)
    debug[CH_IDENT]("  [do_read_csd] CSD read successfully")
    result := SUCCESS
  else
    debug[CH_IDENT]("  [do_read_csd] CSD read failed")
    result := E_IO_ERROR


PRI do_read_sd_status(p_buf) : result
' Read SD Status register (ACMD13) - 64 bytes.
'
' @param p_buf - Pointer to 64-byte buffer to receive SD Status data
' @returns result - SUCCESS on success, E_IO_ERROR on failure

  if readSDStatus(p_buf)
    debug[CH_IDENT]("  [do_read_sd_status] SD Status read successfully")
    result := SUCCESS
  else
    debug[CH_IDENT]("  [do_read_sd_status] SD Status read failed")
    result := E_IO_ERROR

#endif

#ifdef SD_INCLUDE_SPEED

PRI do_attempt_high_speed() : hs_ok | idx, mismatch
' Internal attempt high-speed mode - queries, switches, and verifies at 50 MHz.
' Runs on worker cog where smart pins are configured.
' Uses existing DAT buffers (@buf and @dir_buf) instead of stack locals
' to stay within worker cog stack limits (STACK_SIZE=160 longs).
'
' @returns hs_ok - TRUE if 50 MHz active, FALSE if fell back to 25 MHz
' @local idx - Loop counter
' @local mismatch - Count of mismatched longs

  debug[CH_HSPEED]("  [do_attempt_high_speed] Attempting high-speed mode...")

  if not queryHighSpeedSupport()
    ' Check if card supports high-speed
    debug[CH_HSPEED]("  [do_attempt_high_speed] Card does not support high-speed")
  elseif not switchToHighSpeed()
    ' Switch to high-speed mode
    debug[CH_HSPEED]("  [do_attempt_high_speed] Failed to switch to high-speed")
  else
    ' Set 50 MHz SPI clock
    applySPISpeed(50_000_000)
    debug[CH_HSPEED]("  [do_attempt_high_speed] SPI set to 50 MHz, verifying...")

    ' Verify by reading a sector, writing it back, reading again
    ' Use root directory sector as test (always valid after mount)
    ' Use @buf (BUF_DATA) for read/write and @dir_buf as saved copy
    if readSector(root_sec, BUF_DATA) < 0
      debug[CH_HSPEED]("  [do_attempt_high_speed] Read FAILED at 50 MHz")
    else
      bytemove(@dir_buf, @buf, SECTOR_SIZE)                                      ' Save original to dir_buf

      writeSector(root_sec, BUF_DATA)                                           ' Write same data back
      bytefill(@buf, $AA, SECTOR_SIZE)                                            ' Poison buf

      if readSector(root_sec, BUF_DATA) < 0                                     ' Read again
        debug[CH_HSPEED]("  [do_attempt_high_speed] Verify read FAILED at 50 MHz")
      else
        ' Compare dir_buf (original) vs buf (re-read) long-by-long
        mismatch := 0
        repeat idx from 0 to FAT_ENTRIES_PER_SECTOR - 1
          if LONG[@dir_buf][idx] <> LONG[@buf][idx]
            mismatch++

        if mismatch > 0
          debug[CH_HSPEED]("  [do_attempt_high_speed] VERIFICATION FAILED - ", udec_(mismatch), " long mismatches")
          debug[CH_HSPEED]("  [do_attempt_high_speed] Falling back to 25 MHz")
          applySPISpeed(25_000_000)
        else
          debug[CH_HSPEED]("  [do_attempt_high_speed] VERIFIED - 50 MHz high-speed mode ACTIVE")
          hs_ok := true

    ' Invalidate dir cache since we borrowed dir_buf
    dir_sec_in_buf := -1


PRI do_check_hs_capability() : capable | status[16]
' Internal check high-speed capability - queries CMD6 function group 1.
' Runs on worker cog where smart pins are configured.
'
' @returns capable - TRUE if high-speed function is supported
' @local status - CMD6 status structure (16 longs = 64 bytes)

  if not sendCMD6($00FFFFF1, @status)
    capable := false
  else
    capable := (status.byte[13] & $02) <> 0

#endif


CON ' ---- SD Directory / FAT Operations ----

PRI searchDirectory(name_ptr) : result | p_temp, p_entry, idx, search_sec, jdx
' Search directory for a file/directory by name.
'
' @param name_ptr - Pointer to null-terminated filename string
' @returns result - TRUE if found, FALSE otherwise
' @local p_temp - Pointer to temporary filename buffer
' @local p_entry - Pointer to current directory entry
' @local idx - Loop counter
' @local search_sec - Local directory sector for path resolution
' @local jdx - Loop counter for case-insensitive name comparison

  p_temp := @"FILENAMETXT"
  search_sec := cog_dir_sec[pb_caller]
  if byte[name_ptr] == "/"
    search_sec := root_sec
    name_ptr++
  n_sec := search_sec

  repeat until byte[name_ptr] == $00
    bytefill(@entry_buffer, 0, DIR_ENTRY_SIZE)
    idx := 0

    repeat until byte[name_ptr + idx] == "/" or byte[name_ptr + idx] == $00     '  advance idx up to "/" or null
      idx++
    bytemove(@entry_buffer,name_ptr,idx <# 12)                                  '  copy name into entry_buffer, max 12 characters
    name_ptr += idx                                                             '  advance ptr to "/" or null
    if byte[name_ptr] == "/"                                                    '  if "/"
      name_ptr++                                                                '   advance ptr to byte following "/"

    repeat idx from 0 to SFN_WITH_DOT_LEN - 1                                   '  convert name to uppercase
      case BYTE[@entry_buffer][idx]
        "a".."z" : BYTE[@entry_buffer][idx] -= ASCII_CASE_OFFSET

    idx := 0                                                                    '  convert 8.3 filename into short filename
    if strcomp(@entry_buffer,string("..")) == 0                                 '  exception if changing directory to ".."
      repeat strsize(@entry_buffer) <# 9                                        '  search name for extension
        if BYTE[@entry_buffer][idx++] == "."                                     '  if extension found
          bytemove(@entry_buffer + 8,@entry_buffer + idx,3)                     '   move extension to byte 8
          bytefill(@entry_buffer + idx-1," ",9-idx)                             '   fill space between name and extension
    bytefill(@entry_buffer + strsize(@entry_buffer)," ",SFN_WITH_DOT_LEN-strsize(@entry_buffer)) ' fill remaining space (in case extension < 3 characters)
    BYTE[@entry_buffer][SFN_TOTAL_LEN] := $00                                  '  append null

    idx := 0
    debug[CH_DIR]("  [searchDir] Starting search at n_sec=", udec_(n_sec), " for [", lstr_(@entry_buffer, 11), "]")
    if readSector(n_sec, BUF_DIR) < 0                                           '  read 1st sector of directory
      debug[CH_DIR]("  [searchDir] Directory read FAILED for sector ", udec_(n_sec))
      result := false
      quit
    debug[CH_DIR]("  [searchDir] After read: dir_buf[0]=[", lstr_(@dir_buf, 11), "] dir_buf[32]=[", lstr_(@dir_buf + 32, 11), "]")
    entry_address := 0
    repeat
      p_entry := @dir_buf + (idx & SECTOR_OFFSET_MASK)                                         '  locate entry in directory (FIXED precedence)
      bytemove(p_temp,p_entry,SFN_TOTAL_LEN)                                     '  copy short filename into p_temp
      byte[p_temp + SFN_TOTAL_LEN] := 0                                        '  null terminate for comparison
      repeat jdx from 0 to SFN_TOTAL_LEN - 1                                    '  uppercase on-disk entry for case-insensitive match
        case byte[p_temp + jdx]
          "a".."z" : byte[p_temp + jdx] -= ASCII_CASE_OFFSET
      if strcomp(@entry_buffer,p_temp)                                          '  if matching entry located
        result := true                                                          '   mark path component as found
        entry_address := (n_sec << SECTOR_SHIFT) | (idx & SECTOR_OFFSET_MASK)                             '   store the byte-level address of the entry
        bytemove(@entry_buffer,p_entry, DIR_ENTRY_SIZE)                                      '   copy entire entry into entry_buffer
        debug[CH_DIR]("  [searchDir] FOUND at idx=", udec_(idx), " firstCluster=", udec_(firstCluster()), " n_sec will be ", udec_(clus2sec(firstCluster())))
        if firstCluster() == 0                                                  '  exception if ".." points to root directory
          n_sec := clus2sec(2)                                                  '   root directory located in cluster 2
        else
          n_sec := clus2sec(firstCluster())                                     '   set n_sec to 1st sector of 1st cluster of file
        quit
      elseif byte[name_ptr] == $00                                              '  if end of path reached
        if (entry_address == 0) and (byte[p_temp] == DIR_ENTRY_DELETED or byte[p_temp] == $00) '  if entry_address not set, and 1st byte is $E5 or $00
          entry_address := (n_sec << SECTOR_SHIFT) | (idx & SECTOR_OFFSET_MASK)                           '    set entry_address to 1st unused entry (for newFile / newDirectory)
          debug[CH_DIR]("  [searchDir] Free slot at n_sec=", udec_(n_sec), " idx=", udec_(idx), " entry_address=$", uhex_(entry_address))

      if byte[p_temp] == $00                                                    '  entry not found in directory
        result := false
        quit
      idx += DIR_ENTRY_SIZE                                                                 '  increment to next entry
      if idx & SECTOR_OFFSET_MASK == 0                                                         '  read new directory sector/cluster if needed
        readNextSector(BUF_DIR)
    if not result                                                               '  if entry not found in directory
      quit                                                                      '   stop searching remaining path components


PRI firstCluster() : result
' Return the 1st cluster location of the currently opened file.
'
' @returns result - First cluster number (combined from entry bytes $14-$15 and $1A-$1B)

  result := dirEntStartClus(@entry_buffer)


PRI readFat(cluster) : result
' Read a FAT location and return a pointer to the location of that entry.
'
' @param cluster - Cluster number to look up
' @returns result - Pointer to FAT entry in fat_buf

  if readSector((cluster >> 7 + fat_sec), BUF_FAT) < 0                          '  128 entries in each FAT sector
    debug[CH_SECTOR]("  [readFat] FAT read FAILED for cluster ", udec_(cluster))
    result := @fat_buf                                                           '  Valid pointer but caller gets stale data
  else
    result := @fat_buf + ((cluster << 2) & SECTOR_OFFSET_MASK)


PRI allocateCluster(cluster) : result | fat_idx, buf_idx, high_bits, start_fat_idx, fat_limit, wrapped
' Search FAT for an empty cluster, allocate it, and return cluster number.
' If cluster parameter is non-zero, links the new cluster to that chain.
' Uses next-fit scanning: starts after previous cluster (or fsi_nxt_free hint)
' and wraps around to cluster 2 if end-of-FAT is reached without finding free space.
'
' @param cluster - Previous cluster to link (0 for new chain)
' @returns result - Cluster number on success, negative error code on failure
' @local fat_idx - Current FAT byte index
' @local buf_idx - Index within FAT buffer
' @local high_bits - Preserved high 4 bits of FAT entry
' @local start_fat_idx - Where scan began (for wrap-around termination)
' @local fat_limit - End of FAT in bytes (sec_per_fat * SECTOR_SIZE)
' @local wrapped - TRUE if scan has wrapped around to cluster 2

  ' Next-fit: choose starting scan position
  if cluster > 0
    fat_idx := (cluster + 1) << 2                                               ' Start after previous cluster
  elseif fsi_nxt_free <> $FFFF_FFFF and fsi_nxt_free >= ROOT_CLUSTER
    fat_idx := fsi_nxt_free << 2                                                ' Use FSInfo hint for new chains
  else
    fat_idx := 8                                                                ' Default: cluster 2

  fat_limit := sec_per_fat << SECTOR_SHIFT                                      ' End of FAT in bytes
  if fat_idx >= fat_limit                                                        ' Guard: if start is past end, wrap to cluster 2
    fat_idx := 8
  if test_max_clusters > 0 and (fat_idx >> 2) >= test_max_clusters               ' Guard: if start is past test limit, wrap
    fat_idx := 8
  start_fat_idx := fat_idx                                                       ' Remember where we started (for wrap detection)
  wrapped := false

  if readSector(fat_sec + (fat_idx >> SECTOR_SHIFT), BUF_FAT) < 0               ' Pre-load FAT sector at starting position
    debug[CH_SECTOR]("  [allocateCluster] FAT pre-load FAILED")
    result := E_IO_ERROR
  else
    '   if cluster parameter <> 0, writes newly allocated cluster number in parameter cell
    repeat
      if fat_idx & SECTOR_OFFSET_MASK == 0 and fat_idx > 0                                     '  if at sector boundary (but not first iteration)
        if fat_idx >= fat_limit                                                  '   past end of FAT?
          if wrapped                                                             '    already wrapped once — entire FAT scanned
            result := E_DISK_FULL
            quit
          fat_idx := 8                                                           '    wrap to cluster 2
          wrapped := true
        if wrapped and fat_idx >= start_fat_idx                                  '   wrapped and reached starting point?
          result := E_DISK_FULL
          quit
        if readSector(fat_sec + fat_idx >> SECTOR_SHIFT, BUF_FAT) < 0                      '   load next sector of FAT
          debug[CH_SECTOR]("  [allocateCluster] FAT scan read FAILED")
          result := E_IO_ERROR
          quit
      buf_idx := fat_idx & SECTOR_OFFSET_MASK
      if test_max_clusters > 0 and (fat_idx >> 2) >= test_max_clusters           '  test hook: artificial cluster limit
        if wrapped                                                               '   already wrapped — all visible clusters scanned
          result := E_DISK_FULL
          quit
        fat_idx := 8                                                             '   wrap to cluster 2
        buf_idx := 8
        wrapped := true
        if fat_idx >= start_fat_idx                                              '   started at cluster 2? nowhere left to scan
          result := E_DISK_FULL
          quit
      result := long[@fat_buf + buf_idx]                                        '  read a cluster cell
      if (result & FAT32_ENTRY_MASK) == $0000_0000                               '  if cluster cell is empty (check only low 28 bits)
        high_bits := result & FAT32_RESERVED_MASK                                        '  preserve high 4 bits
        long[@fat_buf + buf_idx] := high_bits | FAT32_EOC_MARK                   '  mark as end-of-chain, preserve high bits
        result := fat_idx >> 2                                                  '  store cluster number in result
        writeSector(fat_sec + result >> 7, BUF_FAT)                             '  write FAT1 sector
        writeSector(fat2_sec + result >> 7, BUF_FAT)                            '  write FAT2 sector (MIRROR)
        if cluster <> 0                                                         '  if allocateCluster was called with a non-zero cluster parameter
          if readSector(fat_sec + cluster >> 7, BUF_FAT) < 0                   '   read FAT sector containing cluster cell
            debug[CH_SECTOR]("  [allocateCluster] FAT chain-link read FAILED - cluster orphaned")
            result := E_IO_ERROR
          else
            buf_idx := (cluster << 2) & SECTOR_OFFSET_MASK
            high_bits := long[@fat_buf + buf_idx] & FAT32_RESERVED_MASK                  '  preserve high 4 bits
            long[@fat_buf + buf_idx] := high_bits | (result & FAT32_ENTRY_MASK)  '  link to new cluster, preserve high bits
            writeSector(fat_sec + cluster >> 7, BUF_FAT)                        '  write FAT1 sector
            writeSector(fat2_sec + cluster >> 7, BUF_FAT)                       '  write FAT2 sector (MIRROR)
        if result >= 0 and fsi_free_count <> $FFFF_FFFF                       '  track free count incrementally
          fsi_free_count--                                                      '   (avoids slow FAT scan on unmount)
        fsi_nxt_free := result + 1                                              '  update next-free hint (Decision #3)
        quit
      fat_idx += 4                                                              '  advance index to next cluster cell
      if fat_idx >= fat_limit and not wrapped                                    '  past end of FAT? wrap around
        fat_idx := 8
        wrapped := true
        if readSector(fat_sec, BUF_FAT) < 0                                     '   pre-load first FAT sector after wrap
          debug[CH_SECTOR]("  [allocateCluster] FAT wrap pre-load FAILED")
          result := E_IO_ERROR
          quit
      elseif wrapped and fat_idx >= start_fat_idx                                '  wrapped and back to start?
        result := E_DISK_FULL
        quit


PRI clearCluster(cluster)
' Initialize entire contents of cluster to 0 - used for new directories.
'
' @param cluster - Cluster number to clear

  n_sec := clus2sec(cluster)                                                    '  set n_sec to 1st sector of specified cluster
  bytefill(@dir_buf, 0, SECTOR_SIZE)                                             '  clear directory buffer
  repeat sec_per_clus                                                           '  repeat for all sectors in the cluster
    writeSector(n_sec++, BUF_DIR)                                               '   overwrite sector
  dir_sec_in_buf := n_sec - 1


PRI readNextSector(buf_type) | cluster, address, contents
' Load the next sector into buffer - follows FAT chain at cluster boundaries.
'
' @param buf_type - Buffer type: BUF_DIR, BUF_FAT, or BUF_DATA
' @local cluster - Current cluster number
' @local address - FAT entry address
' @local contents - FAT entry contents

  n_sec++
  if ((n_sec - cluster_offset) & (sec_per_clus - 1)) == 0                       '  if next sector is in a different cluster
    cluster := sec2clus(n_sec-1)                                                '   find current cluster number
    if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0                          '   read sector of FAT containing cluster number (128 cluster entries in each FAT sector)
      debug[CH_SECTOR]("  [readNextSector] FAT read FAILED for cluster ", udec_(cluster))
    else
      address := @fat_buf + ((cluster << 2) & SECTOR_OFFSET_MASK)                              '   find long within FAT buffer for current cluster
      contents := long[address]                                                 '   read contents to determine next cluster number
      if contents +>= FAT32_EOC_MIN                                                '   end-of-chain marker detected
        ' Fill appropriate buffer with zeros based on buf_type
        case buf_type
          BUF_DIR:
            bytefill(@dir_buf, 0, SECTOR_SIZE)
          BUF_FAT:
            bytefill(@fat_buf, 0, SECTOR_SIZE)
          other:
            bytefill(@buf, 0, SECTOR_SIZE)
      else
        n_sec := clus2sec(contents)                                             '   convert next cluster number into sector number
        if readSector(n_sec, buf_type) < 0
          debug[CH_SECTOR]("  [readNextSector] Sector read FAILED for sector ", udec_(n_sec))
  else
    if readSector(n_sec, buf_type) < 0
      debug[CH_SECTOR]("  [readNextSector] Sector read FAILED for sector ", udec_(n_sec))


PRI updateFSInfo() : result | pFSI
' Update FSInfo sector with current free cluster count.
' Uses cached fsi_free_count (tracked incrementally during alloc/delete).
' Called by unmount() to ensure other OSes see correct free space.
'
' @returns result - TRUE on success, FALSE if no valid FSInfo
' @local pFSI - Pointer overlaid on buf for fsinfo_t struct access

  if fsinfo_sec == 0 or fsi_free_count == $FFFF_FFFF
    debug[CH_MOUNT]("  [updateFSInfo] No valid FSInfo to update")
  elseif readSector(vbr_sec + fsinfo_sec, BUF_DATA) < 0
    debug[CH_MOUNT]("  [updateFSInfo] FSInfo read FAILED")
  else
    pFSI := @buf                                                                '  overlay FSInfo

    ' Verify signatures before writing
    if fsiLeadSig(pFSI) <> FSINFO_LEAD_SIG or fsiStructSig(pFSI) <> FSINFO_STRUCT_SIG
      debug[CH_MOUNT]("  [updateFSInfo] Invalid FSInfo signatures")
    else
      ' Update free count and next-free hint
      fsiSetFreeClusters(pFSI, fsi_free_count)                                  '  FSI_Free_Count (cached value)
      fsiSetNextFreeHint(pFSI, fsi_nxt_free)                                    '  FSI_Nxt_Free (keep cached value)

      ' Write updated FSInfo sector (primary at sector 1, backup at sector 7)
      writeSector(vbr_sec + fsinfo_sec, BUF_DATA)
      writeSector(vbr_sec + 7, BUF_DATA)                                        '  backup FSInfo at sector 7
      debug[CH_MOUNT]("  [updateFSInfo] Updated primary+backup: free_count=", udec(fsi_free_count))
      result := true


PRI countFreeClusters() : count | fat_idx, entry
' Count free clusters in FAT - scans entire FAT for zero entries.
' This is slow on large cards but only called on unmount().
'
' @returns count - Number of free clusters
' @local fat_idx - Current FAT byte index
' @local entry - Current FAT entry value

  count := 0
  fat_idx := ROOT_CLUSTER * 4                                                   '  start at cluster 2 (skip reserved entries 0,1)
  repeat
    if fat_idx & SECTOR_OFFSET_MASK == 0                                                       '  if at sector boundary
      if fat_idx >> SECTOR_SHIFT >= sec_per_fat                                            '  if past end of FAT
        quit
      if readSector(fat_sec + fat_idx >> SECTOR_SHIFT, BUF_FAT) < 0                         '  read next FAT sector
        debug[CH_SECTOR]("  [countFreeClusters] FAT read FAILED, returning partial count")
        quit
    entry := long[@fat_buf + (fat_idx & SECTOR_OFFSET_MASK)]
    if (entry & FAT32_ENTRY_MASK) == 0                                           '  check only low 28 bits
      count++
    fat_idx += 4
  fat_sec_in_buf := -1                                                          '  invalidate FAT buffer


PRI freeClusterChain(first_cluster) : result | clus, next_clus, last_clus, fat_sector, loop_count
' Walk a FAT chain and mark every cluster as free (zero entry).
' Writes both FAT1 and FAT2 (mirror) at sector boundaries and at end.
' Used by do_delete() and compactFile().
'
' @param first_cluster - First cluster of the chain to free
' @returns result - SUCCESS or E_IO_ERROR on safety limit

  result := SUCCESS
  clus := first_cluster
  last_clus := first_cluster
  loop_count := 0
  if clus >= ROOT_CLUSTER
    repeat
      next_clus := long[readFat(clus)]
      long[@fat_buf + ((clus << 2) & SECTOR_OFFSET_MASK)] := 0                  '  zero the FAT entry
      if fsi_free_count <> $FFFF_FFFF                                            '  track free count incrementally
        fsi_free_count++
      last_clus := clus
      if (next_clus >> 7) - (clus >> 7) <> 0                                    '  different FAT sector? (explicit precedence)
        fat_sector := clus >> 7
        writeSector(fat_sector + fat_sec, BUF_FAT)
        writeSector(fat_sector + fat2_sec, BUF_FAT)
      clus := next_clus
      loop_count++
      if loop_count > 100000                                                     '  safety limit
        result := E_IO_ERROR
        quit
    until next_clus +>= FAT32_EOC_MIN
    ' Always write the FAT sector containing the last freed cluster
    if result == SUCCESS
      fat_sector := last_clus >> 7
      writeSector(fat_sector + fat_sec, BUF_FAT)
      writeSector(fat_sector + fat2_sec, BUF_FAT)


#ifdef SD_INCLUDE_DEFRAG

PRI do_create_contiguous(p_path, file_size) : handle | cluster_count, new_first, temp, first_cluster
' Worker-side handler for CMD_CREATE_CONTIGUOUS.
' Creates a new file with a pre-allocated contiguous cluster chain.
' Reuses do_create() directory entry logic with pre-allocated first cluster.
'
' @param p_path - Pointer to null-terminated filename string
' @param file_size - Expected file size in bytes
' @returns handle - Handle on success, negative error code on failure

  ' Calculate clusters needed
  cluster_count := (file_size + (sec_per_clus << SECTOR_SHIFT) - 1) / (sec_per_clus << SECTOR_SHIFT)
  if cluster_count < 1
    cluster_count := 1                                                           '  minimum 1 cluster

  ' Find contiguous run
  new_first := findContiguousRun(cluster_count)
  if new_first < 0
    handle := new_first                                                          '  E_NO_CONTIGUOUS_SPACE or E_IO_ERROR
    return

  ' Allocate the contiguous chain in FAT
  temp := allocateContiguousChain(new_first, cluster_count)
  if temp < 0
    handle := temp
    return

  ' Allocate a handle slot
  handle := allocateHandle()
  if handle < 0
    debug[CH_FILE]("  [do_create_contiguous] No free handles")
    return

  ' Check file doesn't already exist
  if searchDirectory(p_path)
    debug[CH_FILE]("  [do_create_contiguous] File already exists: ", zstr_(p_path))
    freeHandle(handle)
    handle := E_FILE_EXISTS
    return
  if entry_address == 0
    debug[CH_FILE]("  [do_create_contiguous] entry_address=0 -- path not valid")
    freeHandle(handle)
    handle := E_FILE_NOT_FOUND
    return

  ' Check if directory needs a new cluster for the entry
  temp := (entry_address + cluster_offset << SECTOR_SHIFT) & (sec_per_clus << SECTOR_SHIFT - 1)
  if temp == (sec_per_clus << SECTOR_SHIFT - DIR_ENTRY_SIZE)
    if dir_buf[LAST_DIR_ENTRY_OFFSET] == $00
      temp := allocateCluster(byte2clus(entry_address))
      if temp < 0
        debug[CH_FILE]("  [do_create_contiguous] Failed to allocate dir cluster")
        freeHandle(handle)
        handle := E_DISK_FULL
        return
      else
        clearCluster(temp)

  ' Set up directory entry
  first_cluster := new_first
  dirEntSetAttr(@entry_buffer, ATTR_ARCHIVE)
  dirEntSetCreateStamp(@entry_buffer, date_stamp)
  dirEntSetStartClus(@entry_buffer, first_cluster)
  dirEntSetModifyStamp(@entry_buffer, date_stamp)
  dirEntSetFileSize(@entry_buffer, 0)

  ' Write directory entry to disk
  if readSector(entry_address >> SECTOR_SHIFT, BUF_DIR) < 0
    debug[CH_FILE]("  [do_create_contiguous] Directory read FAILED")
    freeHandle(handle)
    handle := E_IO_ERROR
    return
  bytemove(@dir_buf + (entry_address & SECTOR_OFFSET_MASK), @entry_buffer, DIR_ENTRY_SIZE)
  if writeSector(entry_address >> SECTOR_SHIFT, BUF_DIR) < 0
    debug[CH_FILE]("  [do_create_contiguous] Directory write FAILED")
    freeHandle(handle)
    handle := E_IO_ERROR
    return

  ' Populate handle state
  h_start_clus[handle] := first_cluster
  h_size[handle] := 0
  h_attr[handle] := ATTR_ARCHIVE
  h_dir_sector[handle] := entry_address >> SECTOR_SHIFT
  h_dir_offset[handle] := entry_address & SECTOR_OFFSET_MASK
  h_cluster[handle] := first_cluster
  h_sector[handle] := clus2sec(first_cluster)
  h_position[handle] := 0
  h_buf_sector[handle] := -1
  h_flags[handle] := HF_WRITE
  h_prealloc_end[handle] := new_first + cluster_count - 1
  debug[CH_FILE]("  [do_create_contiguous] Success: handle=", udec_(handle), " clusters=", udec_(new_first), "..", udec_(new_first + cluster_count - 1))


PRI do_compact_file(p_path) : result | dir_sec, dir_off, start_cluster, file_size, cluster_count, new_first, clus, next_clus, idx, frag_count
' Worker-side handler for CMD_COMPACT_FILE.
' Relocates a file's clusters into a contiguous chain using copy-then-free.
' 12-step process with mandatory read-back verification (Decision #5).
'
' @param p_path - Pointer to null-terminated filename string
' @returns result - SUCCESS or negative error code

  ' Step 1: Find the file
  if searchDirectory(p_path) == 0
    result := E_FILE_NOT_FOUND
    return
  dir_sec := entry_address >> SECTOR_SHIFT
  dir_off := entry_address & SECTOR_OFFSET_MASK
  start_cluster := firstCluster()
  file_size := dirEntFileSize(@entry_buffer)

  ' Step 2: Check file is not open
  if isFileOpenAny(dir_sec, dir_off)
    result := E_FILE_OPEN_FOR_COMPACT
    return

  ' Step 3: Empty file — nothing to compact
  if file_size == 0
    result := SUCCESS
    return

  ' Step 4: Count clusters and check fragmentation
  frag_count := countFileFragments(start_cluster)
  if frag_count == 1
    result := SUCCESS                                                            '  already contiguous
    return
  ' Count clusters by walking the chain
  cluster_count := 0
  clus := start_cluster
  repeat
    cluster_count++
    next_clus := long[readFat(clus)] & FAT32_ENTRY_MASK
    if next_clus >= FAT32_EOC_MIN
      quit
    if next_clus < ROOT_CLUSTER
      quit
    clus := next_clus

  ' Step 5: Find contiguous free space
  new_first := findContiguousRun(cluster_count)
  if new_first < 0
    result := new_first                                                          '  E_NO_CONTIGUOUS_SPACE or E_IO_ERROR
    return

  ' Step 6: Copy phase — walk old chain, copy each cluster to new location
  clus := start_cluster
  idx := 0
  repeat
    result := copyClusterData(clus, new_first + idx)
    if result < 0
      return                                                                     '  E_IO_ERROR
    idx++
    next_clus := long[readFat(clus)] & FAT32_ENTRY_MASK
    if next_clus >= FAT32_EOC_MIN
      quit
    if next_clus < ROOT_CLUSTER
      quit
    clus := next_clus

  ' Step 7: Verify phase (Decision #5) — read-back compare every cluster
  clus := start_cluster
  idx := 0
  repeat
    result := verifyClusterCopy(clus, new_first + idx)
    if result < 0
      return                                                                     '  E_VERIFY_FAILED
    idx++
    next_clus := long[readFat(clus)] & FAT32_ENTRY_MASK
    if next_clus >= FAT32_EOC_MIN
      quit
    if next_clus < ROOT_CLUSTER
      quit
    clus := next_clus

  ' Step 8: Build new FAT chain
  result := allocateContiguousChain(new_first, cluster_count)
  if result < 0
    return

  ' Step 9: Update directory entry to point to new first cluster
  if readSector(dir_sec, BUF_DIR) < 0
    result := E_IO_ERROR
    return
  bytemove(@entry_buffer, @dir_buf + dir_off, DIR_ENTRY_SIZE)
  dirEntSetStartClus(@entry_buffer, new_first)
  bytemove(@dir_buf + dir_off, @entry_buffer, DIR_ENTRY_SIZE)
  writeSector(dir_sec, BUF_DIR)

  ' Step 10: Free old clusters
  freeClusterChain(start_cluster)

  ' Step 11: Invalidate all caches
  invalidateAllCaches()

  ' Step 12: Success
  result := SUCCESS


PRI do_file_fragments(p_path) : count | start_cluster
' Worker-side handler for CMD_FILE_FRAGMENTS.
' Looks up the file and counts its FAT chain fragments.
'
' @param p_path - Pointer to null-terminated filename string
' @returns count - Fragment count (1 = contiguous), 0 if empty, or negative error code

  if searchDirectory(p_path) == 0
    count := E_FILE_NOT_FOUND
  else
    start_cluster := firstCluster()
    if start_cluster < ROOT_CLUSTER
      count := 0                                                                 '  empty file (no clusters)
    else
      count := countFileFragments(start_cluster)


PRI countFileFragments(first_cluster) : count | clus, next_clus, loop_count
' Count the number of non-contiguous fragments in a file's cluster chain.
' A contiguous file has fragment count 1; each gap increments the count.
'
' @param first_cluster - First cluster of the file's chain
' @returns count - Fragment count (1 = contiguous), 0 if empty chain

  if first_cluster < ROOT_CLUSTER
    count := 0                                                                   '  empty or invalid chain
    return
  count := 1
  clus := first_cluster
  loop_count := 0
  repeat
    next_clus := long[readFat(clus)] & FAT32_ENTRY_MASK
    if next_clus >= FAT32_EOC_MIN
      quit                                                                       '  end of chain
    if next_clus < ROOT_CLUSTER                                                  '  bad reference
      quit
    if next_clus <> clus + 1                                                     '  non-contiguous transition?
      count++
    clus := next_clus
    loop_count++
    if loop_count > 100000                                                       '  safety limit
      quit


PRI findContiguousRun(cluster_count) : first_cluster | fat_idx, entry, run_start, run_length
' Scan FAT for a contiguous run of N free clusters.
' Performs a linear scan from cluster 2 through end of FAT.
'
' @param cluster_count - Number of consecutive free clusters needed
' @returns first_cluster - First cluster of the run, or E_NO_CONTIGUOUS_SPACE

  run_start := ROOT_CLUSTER
  run_length := 0
  fat_idx := ROOT_CLUSTER * 4                                                   '  start at cluster 2
  repeat
    if fat_idx & SECTOR_OFFSET_MASK == 0                                         '  at sector boundary?
      if fat_idx >> SECTOR_SHIFT >= sec_per_fat                                  '   past end of FAT?
        quit
      if readSector(fat_sec + fat_idx >> SECTOR_SHIFT, BUF_FAT) < 0             '   load next FAT sector
        debug[CH_SECTOR]("  [findContiguousRun] FAT read FAILED")
        first_cluster := E_IO_ERROR
        fat_sec_in_buf := -1
        return
    if test_max_clusters > 0 and (fat_idx >> 2) >= test_max_clusters               '  test hook: artificial cluster limit
      quit
    entry := long[@fat_buf + (fat_idx & SECTOR_OFFSET_MASK)]
    if (entry & FAT32_ENTRY_MASK) == 0                                           '  free cluster?
      if run_length == 0
        run_start := fat_idx >> 2                                                '   start new run
      run_length++
      if run_length >= cluster_count                                             '  found enough?
        first_cluster := run_start
        fat_sec_in_buf := -1
        return
    else
      run_length := 0                                                            '  reset run
    fat_idx += 4
  first_cluster := E_NO_CONTIGUOUS_SPACE                                         '  no run found
  fat_sec_in_buf := -1


PRI allocateContiguousChain(first_cluster, count) : result | clus, fat_idx, buf_idx, high_bits, prev_fat_sector
' Mark N consecutive clusters as a linked sequential chain in the FAT.
' Writes both FAT1 and FAT2 (mirror). Preserves high 4 reserved bits.
'
' @param first_cluster - First cluster of the contiguous run
' @param count - Number of clusters to link
' @returns result - SUCCESS or E_IO_ERROR

  result := SUCCESS
  prev_fat_sector := -1
  repeat clus from first_cluster to first_cluster + count - 1
    fat_idx := clus << 2
    buf_idx := fat_idx & SECTOR_OFFSET_MASK
    ' Load FAT sector if needed
    if (fat_idx >> SECTOR_SHIFT) <> prev_fat_sector
      if prev_fat_sector >= 0                                                    '  write previous sector before loading new one
        writeSector(fat_sec + prev_fat_sector, BUF_FAT)
        writeSector(fat2_sec + prev_fat_sector, BUF_FAT)
      prev_fat_sector := fat_idx >> SECTOR_SHIFT
      if readSector(fat_sec + prev_fat_sector, BUF_FAT) < 0
        debug[CH_SECTOR]("  [allocateContiguousChain] FAT read FAILED at cluster ", udec_(clus))
        result := E_IO_ERROR
        quit
    ' Write chain link or EOC
    high_bits := long[@fat_buf + buf_idx] & FAT32_RESERVED_MASK                  '  preserve high 4 bits
    if clus < first_cluster + count - 1
      long[@fat_buf + buf_idx] := high_bits | ((clus + 1) & FAT32_ENTRY_MASK)    '  link to next cluster
    else
      long[@fat_buf + buf_idx] := high_bits | FAT32_EOC_MARK                     '  end of chain
  ' Write final FAT sector
  if prev_fat_sector >= 0 and result == SUCCESS
    writeSector(fat_sec + prev_fat_sector, BUF_FAT)
    writeSector(fat2_sec + prev_fat_sector, BUF_FAT)
  ' Update free cluster tracking
  if result == SUCCESS
    if fsi_free_count <> $FFFF_FFFF
      fsi_free_count -= count
    fsi_nxt_free := first_cluster + count                                        '  update next-free hint


PRI copyClusterData(src_cluster, dst_cluster) : result | idx
' Copy all sectors of one cluster from source to destination.
'
' @param src_cluster - Source cluster number
' @param dst_cluster - Destination cluster number
' @returns result - SUCCESS or E_IO_ERROR

  result := SUCCESS
  repeat idx from 0 to sec_per_clus - 1
    if readSector(clus2sec(src_cluster) + idx, BUF_DATA) < 0
      debug[CH_SECTOR]("  [copyClusterData] Read FAILED at sector ", udec_(clus2sec(src_cluster) + idx))
      result := E_IO_ERROR
      quit
    if writeSector(clus2sec(dst_cluster) + idx, BUF_DATA) < 0
      debug[CH_SECTOR]("  [copyClusterData] Write FAILED at sector ", udec_(clus2sec(dst_cluster) + idx))
      result := E_IO_ERROR
      quit


PRI verifyClusterCopy(src_cluster, dst_cluster) : result | idx, byte_idx
' Verify that all sectors in a cluster were copied correctly by reading
' both source and destination and comparing byte-by-byte.
' Repurposes dir_buf for destination reads (safe when file is closed).
' Implements Decision #5 (mandatory read-back verify after compact).
'
' @param src_cluster - Source cluster number (original data)
' @param dst_cluster - Destination cluster number (copied data)
' @returns result - SUCCESS or E_VERIFY_FAILED

  result := SUCCESS
  repeat idx from 0 to sec_per_clus - 1
    if readSector(clus2sec(src_cluster) + idx, BUF_DATA) < 0
      result := E_IO_ERROR
      quit
    if readSector(clus2sec(dst_cluster) + idx, BUF_DIR) < 0
      result := E_IO_ERROR
      quit
    repeat byte_idx from 0 to SECTOR_SIZE - 1
      if byte[@buf][byte_idx] <> byte[@dir_buf][byte_idx]
        debug[CH_FILE]("  [verifyClusterCopy] Mismatch at sector ", udec_(idx), " byte ", udec_(byte_idx))
        result := E_VERIFY_FAILED
        return


PRI invalidateAllCaches()
' Reset all three sector cache tracking variables to force re-reads.
' Called after compactFile() to prevent stale cached sectors.

  dir_sec_in_buf := -1
  fat_sec_in_buf := -1
  sec_in_buf := -1


PRI isFileOpenAny(dir_sector, dir_offset) : result | handle
' Check if a file is open in any mode (read, write, or directory).
' Used by compactFile() to reject compaction on open files.
'
' @param dir_sector - Directory sector containing the file entry
' @param dir_offset - Offset within sector of the file entry
' @returns result - TRUE if file is open in any mode, FALSE otherwise
' @local handle - Loop variable for handle search

  result := FALSE
  repeat handle from 0 to MAX_OPEN_FILES - 1
    if h_flags[handle] <> HF_FREE
      if h_dir_sector[handle] == dir_sector and h_dir_offset[handle] == dir_offset
        result := TRUE
        quit

#endif  ' SD_INCLUDE_DEFRAG


CON ' ---- SD Conversion Helpers ----

PRI byte2clus(byte_address) : result
' Convert byte address to cluster number.
'
' @param byte_address - Byte address to convert
' @returns result - Cluster number containing that byte

  result := sec2clus(byte_address >> SECTOR_SHIFT)


PRI sec2clus(sector) : result
' Convert sector number to cluster number.
'
' @param sector - Sector number to convert
' @returns result - Cluster number containing that sector

  result := (sector - root_sec) / sec_per_clus + ROOT_CLUSTER


PRI clus2sec(cluster) : result
' Convert cluster number to sector number.
'
' @param cluster - Cluster number to convert
' @returns result - Sector number of first sector in that cluster

  result := (cluster - ROOT_CLUSTER) * sec_per_clus + root_sec


CON ' ---- SD SPI Layer ----

PRI initSPIPins()
' Configure smart pins for SPI operation - initialize Smart Pins for high-speed SPI communication.
' Pattern from working isp_tile_sensor.spin2:
' - DIRL -> WRPIN -> WXPIN -> DIRH (no WYPIN during config)
' - Smart pins stay enabled, WYPIN triggers transfers
'
' SCK uses P_PULSE for clock generation (X = period | low_time<<16)
' MOSI uses P_SYNC_TX for synchronized transmit (clocked by SCK)
' MISO uses P_SYNC_RX for synchronized receive (clocked by SCK)
' CS remains standard GPIO (manual control)

  ' Smart pin mode configuration using compiler constants
  ' P_TRANSITION: clock generation with X = half-period (transitions toggle output)
  ' P_SYNC_TX: synchronized serial transmit (clocked by B-input)
  ' P_SYNC_RX: synchronized serial receive (clocked by B-input)
  ' P_PLUS2_B, P_PLUS3_B: B-input pin selector for clock source
  ' Reference: ManAtWork SpiFlash.spin2 (OBEX 2872) - working smart pin SPI
  ' CRITICAL: Do NOT use P_INVERT_OUTPUT for SD card SPI mode 0!
  ' ManAtWork's flash uses different polarity. SD cards need clock idle LOW.
  spi_clk_mode := P_TRANSITION | P_OE                                           ' Transition mode, idle LOW for SPI mode 0
  spi_tx_mode := P_SYNC_TX | P_OE | P_PLUS2_B                                   ' Sync TX, clock from pin+2 (SCK)
  spi_rx_mode := P_SYNC_RX | P_PLUS3_B                                          ' Sync RX, clock from pin+3 (SCK)

  debug[CH_INIT]("    [initSPIPins] Setting up smart pins (ManAtWork pattern)...")
  debug[CH_INIT]("    [initSPIPins] Mode values:")
  debug[CH_INIT]("    [initSPIPins]   spi_clk_mode=$", uhex_long(spi_clk_mode), " (P_TRANSITION | P_OE, idle LOW)")
  debug[CH_INIT]("    [initSPIPins]   spi_tx_mode=$", uhex_long(spi_tx_mode), " (P_SYNC_TX | P_OE | P_PLUS2_B)")
  debug[CH_INIT]("    [initSPIPins]   spi_rx_mode=$", uhex_long(spi_rx_mode), " (P_SYNC_RX | P_PLUS3_B)")
  debug[CH_INIT]("    [initSPIPins]   SCK=P", udec_(sck), " MOSI=P", udec_(mosi), " MISO=P", udec_(miso))

  ' ════════════════════════════════════════════════════════════════════
  ' CS PIN: Standard GPIO (unchanged from bit-bang)
  ' CS is manually controlled - LOW = selected, HIGH = deselected
  ' ════════════════════════════════════════════════════════════════════
  pinh(cs)                                                                      ' Start deselected

  ' ════════════════════════════════════════════════════════════════════
  ' SCK PIN: P_TRANSITION mode for clock generation
  ' X register: half-period in clocks (time between transitions)
  ' Y register: Number of transitions (2 per bit) - loaded via WYPIN per transfer
  ' Configure with FLTL -> WRPIN, then WXPIN/DRVL in applySPISpeed()
  ' ════════════════════════════════════════════════════════════════════
  pinfloat(sck)                                                                 ' FLTL - reset smart pin
  wrpin(sck, spi_clk_mode)                                                      ' P_TRANSITION | P_OE | P_INVERT_OUTPUT
  ' X register (half-period) will be set by applySPISpeed()
  debug[CH_INIT]("    [initSPIPins]   SCK configured: P_TRANSITION | P_OE (awaiting applySPISpeed)")

  ' ════════════════════════════════════════════════════════════════════
  ' MOSI PIN: P_SYNC_TX mode for synchronized transmit
  ' B-input set via P_PLUS2_B (clock from SCK which is 2 pins higher)
  ' X register: %M_NNNNN where M=mode (1=start/stop), N=bits-1
  ' Y register: Data to transmit - loaded via WYPIN per transfer
  ' Configure with DIRL -> WRPIN -> WXPIN -> DIRH (no WYPIN yet)
  ' ════════════════════════════════════════════════════════════════════
  pinfloat(mosi)                                                                ' DIRL - reset smart pin
  wrpin(mosi, spi_tx_mode)                                                      ' P_SYNC_TX | P_OE | P_PLUS2_B
  wxpin(mosi, %1_00111)                                                         ' Start-stop mode, 8 bits default
  pinh(mosi)                                                                    ' DIRH - enable smart pin
  debug[CH_INIT]("    [initSPIPins]   MOSI configured: P_SYNC_TX | P_PLUS2_B (enabled)")

  ' ════════════════════════════════════════════════════════════════════
  ' MISO PIN: P_SYNC_RX mode for synchronized receive
  ' B-input set via P_PLUS3_B (clock from SCK which is 3 pins higher)
  ' X register: %M_NNNNN where M=mode (1=post-edge for SPI mode 0), N=bits-1
  ' Z register: Received data - read via RDPIN per transfer
  ' Configure with DIRL -> WRPIN -> WXPIN -> DIRH (no WYPIN needed)
  ' ════════════════════════════════════════════════════════════════════
  pinfloat(miso)                                                                ' DIRL - reset smart pin
  wrpin(miso, spi_rx_mode)                                                      ' P_SYNC_RX | P_PLUS3_B
  wxpin(miso, %1_00111)                                                         ' On-edge sample (SPI mode 0), 8 bits
  pinh(miso)                                                                    ' DIRH - enable smart pin
  debug[CH_INIT]("    [initSPIPins]   MISO configured: P_SYNC_RX | P_PLUS3_B (enabled)")

  ' Configure event SE1 for efficient waiting on SCK completion
  ' Event format: D[5:0]=pin, D[7:6]=%01 for positive edge on IN
  ' This allows waitse1 instead of polling testp loop
  spi_event := %01_000000 | sck
  configureEvent(spi_event)
  debug[CH_INIT]("    [initSPIPins]   Event SE1 configured for SCK pin ", udec_(sck))

  debug[CH_INIT]("    [initSPIPins] Smart pins configured and enabled")


PRI configureEvent(event_config) | ev
' Configure SE1 event for waitse1 - helper to configure SE1 event from a computed value.
' Event format: D[5:0]=pin, D[7:6]=%01 for positive edge on IN
'
' @param event_config - Event configuration value
' @local ev - Copy of event config for inline assembly

  ev := event_config
  org
        setse1  ev
  end


PRI applySPISpeed(freq) | half_period, actual_freq
' Set SPI clock frequency - configure SPI clock speed for sysclk-independent operation.
' Must only be called from worker cog context (owns the SPI pins).
' Using P_TRANSITION mode: X = half-period (time between transitions)
' Reference: ManAtWork SpiFlash.spin2
'
' Formula: half_period = clkfreq / (freq * 2)
' For 400 kHz: half_period = 320M / 800k = 400 clocks
' For 25 MHz: half_period = 320M / 50M = 6.4 -> minimum 4
'
' @param freq - Target SPI frequency in Hz (e.g., 400_000 or 25_000_000)
' @local half_period - Calculated half-period in system clocks
' @local actual_freq - Actual achieved frequency

  ' Calculate half-period (time between transitions) in system clocks
  ' Use ceiling division to ensure we never exceed target frequency
  ' Formula: ceil(a/b) = (a + b - 1) / b
  half_period := (clkfreq + (freq * 2) - 1) / (freq * 2)

  ' Guard against too-small period (ManAtWork uses minimum of 4)
  if half_period < 4
    half_period := 4
    debug[CH_INIT]("    [applySPISpeed] WARNING: Half-period clamped to minimum (4)")

  ' Calculate actual achieved frequency for debugging
  actual_freq := clkfreq / (half_period * 2)

  ' Store in DAT variables for debugging/monitoring
  spi_period := half_period
  spi_freq := actual_freq

  ' Configure SCK smart pin X register and enable with DRVL
  wxpin(sck, half_period)                                                       ' Set transition period
  pinl(sck)                                                                     ' DRVL enables smart pin (ManAtWork pattern)

  debug[CH_INIT]("    [applySPISpeed] Target=", udec_(freq/1000), " kHz, Actual=", udec_(actual_freq/1000), " kHz")
  debug[CH_INIT]("    [applySPISpeed] Half-period=", udec_(half_period), " clocks")


PRI calcDataCRC(pData, len) : crc | raw
' Calculate CRC-16-CCITT for SD card data - hardware-accelerated using P2's GETCRC instruction.
' Eliminates 512-byte lookup table with equivalent results.
'
' Algorithm:
'   1. GETCRC with reflected polynomial $8408 on raw data
'   2. XOR with precomputed base value (compensates for GETCRC quirks)
'   3. REV 31 reverses all 32 bits (LSB-first to MSB-first)
'   4. >> 16 extracts 16-bit CRC from upper half
'
' Note: This formula was validated against lookup table with 100% match
'       across 10 test patterns. See TestCard/SD_CRC_solution_test.spin2
'
' @param pData - Pointer to data buffer
' @param len - Number of bytes to process (must be 512 for sector data)
' @returns crc - 16-bit CRC-16-CCITT value matching SD card's calculation
' @local raw - Raw GETCRC result before transformation

  raw := GETCRC(pData, CRC_POLY_REFLECTED, len)
  crc := ((raw ^ CRC_BASE_512) REV 31) >> 16


PRI sp_transfer(data, bits) : result
' Smart pin SPI transfer (variable bits) - dispatches to 8-bit or 32-bit transfer.
' For now, only support 8-bit and 32-bit transfers.
'
' @param data - Data to transmit
' @param bits - Number of bits to transfer (8 or 32)
' @returns result - Received data

  if bits == 8
    result := sp_transfer_8(data)
  elseif bits == 32
    result := sp_transfer_32(data)
  else
    ' Fallback to bit-bang for unsupported sizes
    result := transfer(data, bits)


PRI sp_transfer_8(data) : result | _sck, _mosi, _miso, tx_data, raw_result
' 8-bit smart pin SPI transfer - full-duplex 8-bit SPI transfer using smart pins.
' Reference: ManAtWork SpiFlash.spin2 (OBEX 2872)
' TX: shl #24, rev, wypin data, 16 transitions
' RX: wait on MISO IN flag, rdpin, rev, zerox #7
'
' @param data - Byte to transmit
' @returns result - Byte received
' @local _sck - Local copy of SCK pin number
' @local _mosi - Local copy of MOSI pin number
' @local _miso - Local copy of MISO pin number
' @local tx_data - Prepared transmit data
' @local raw_result - Raw rdpin result before processing

  _sck := sck
  _mosi := mosi
  _miso := miso
  tx_data := data
  org
        ' Prepare TX data: shift to MSB position and reverse for LSB-first transmission
        shl     tx_data, #24                    ' Move byte to bits [31:24]
        rev     tx_data                         ' Reverse for MSB-first SPI

        ' Configure MOSI for 8-bit start-stop mode and load data
        wxpin   #$27, _mosi                     ' 8 bits, start-stop mode (%1_00111)
        wypin   tx_data, _mosi
        drvl    _mosi                           ' Enable TX smart pin

        ' Configure MISO for 8-bit receive
        ' Note: wrpin already set from initSPIPins - don't use dirl which clears it!
        wxpin   #$27, _miso                     ' 8 bits, start-stop mode
        akpin   _miso                           ' Clear any pending IN flag
        dirh    _miso                           ' Enable smart pin

        ' Start clock: 16 transitions = 8 clock cycles
        wypin   #16, _sck
        nop

        ' Wait for MISO receive complete (not clock!)
.waitRx testp   _miso                   wz      ' IN=1 when receive complete
  if_nz jmp     #.waitRx

        ' Read received data - keep raw value for debug
        rdpin   raw_result, _miso
        mov     result, raw_result
        rev     result                          ' Reverse for MSB-first
        zerox   result, #7                      ' Limit to 8 bits
  end
  ' Debug: show raw rdpin value and pin info occasionally
  if sp_debug_ctr < 5
    debug[CH_INIT]("    [sp_transfer_8] pins: miso=", udec_(_miso), " sck=", udec_(_sck), " raw=", uhex_long_(raw_result), " final=", uhex_byte_(result))
    sp_debug_ctr++


PRI sp_transfer_32(data) : result | _sck, _mosi, _miso, tx_data
' 32-bit smart pin SPI transfer - full-duplex 32-bit SPI transfer using smart pins.
'
' @param data - 32-bit data to transmit
' @returns result - 32-bit data received
' @local _sck - Local copy of SCK pin number
' @local _mosi - Local copy of MOSI pin number
' @local _miso - Local copy of MISO pin number
' @local tx_data - Prepared transmit data

  _sck := sck
  _mosi := mosi
  _miso := miso
  tx_data := data
  org
        ' Prepare TX data: reverse for LSB-first transmission
        rev     tx_data                         ' Reverse for MSB-first SPI

        ' Configure MOSI for 32-bit start-stop mode and load data
        wxpin   #$3F, _mosi                     ' 32 bits, start-stop mode (%1_11111)
        wypin   tx_data, _mosi
        drvl    _mosi                           ' Enable TX smart pin

        ' Configure MISO for 32-bit receive
        wxpin   #$3F, _miso                     ' 32 bits, start-stop mode
        drvl    _miso                           ' Enable RX smart pin

        ' Start clock: 64 transitions = 32 clock cycles
        wypin   #64, _sck
        nop

        ' Wait for MISO receive complete
.waitRx testp   _miso                   wz      ' IN=1 when receive complete
  if_nz jmp     #.waitRx

        ' Read received data
        rdpin   result, _miso
        rev     result                          ' Reverse for MSB-first
  end


PRI initCard() : result | timeout, resp, card_version, acmd41_arg, got_response
' Initialize SD card - performs complete card initialization sequence per SD spec.
' Steps: power-on delay, SPI setup, card presence detection, CMD0, CMD8, ACMD41 loop, CMD58.
'
' @returns result - TRUE on successful init, FALSE on failure
' @local timeout - Timeout deadline
' @local resp - Command response byte
' @local card_version - Detected SD version (1 or 2)
' @local acmd41_arg - Argument for ACMD41 (HCS flag)
' @local got_response - TRUE if any CMD0 attempt got a non-timeout response

  debug[CH_INIT]("    [initCard] Starting card init...")
  debug[CH_INIT]("    [initCard] Reference: SPI_SD_Implementation_Reference.md")
  sec_in_buf := -1

  ' ============================================
  ' STEP 1: Power-on delay
  ' Spec: VDD must be stable, then wait 1ms minimum
  ' ============================================
  debug[CH_INIT]("    [initCard] Step 1: Power-on delay (100ms)...")
  waitms(POWER_ON_DELAY_MS)

  ' ============================================
  ' STEP 2: Configure SPI pins and slow clock
  ' Spec: Use 100-400 kHz during initialization
  ' ============================================
  bit_delay := clkfreq / 100_000                                                '  ~50kHz for init (conservative)
  debug[CH_INIT]("    [initCard] Step 2: SPI config, bit_delay=", udec(bit_delay), " (~50kHz)")

  ' SD card SPI mode 0: CPOL=0, CPHA=0
  ' Data sampled on rising edge, changed on falling edge
  pinh(cs)                                                                      '  CS HIGH = deselected
  pinh(mosi)                                                                    '  MOSI HIGH (card expects high during idle)
  pinl(sck)                                                                     '  SCK LOW (SPI mode 0 idle state)

  ' Enable 15K pull-up on MISO for card-presence detection
  ' If no card is present, MISO reads $FF (pulled high by P2 internal resistor)
  ' If card is present, card drives MISO (easily overpowers 15K pull-up)
  ' Pull-up is cleared later when initSPIPins() configures MISO for smart pin SPI
  wrpin(miso, P_HIGH_15K)
  pinf(miso)                                                                    '  MISO as input with pull-up active
  waitus(10)                                                                    '  Let pull-up settle

  debug[CH_INIT]("    [initCard] Pins: CS=", udec_(pinr(cs)), " MOSI=", udec_(pinr(mosi)), " MISO=", udec_(pinr(miso)), " SCK=", udec_(pinr(sck)))

  ' ============================================
  ' STEP 3: Card recovery + init clocks
  ' If card is stuck mid-transfer, flush with extra clocks
  ' Then send 74+ clocks per spec for power-on init
  ' ============================================
  debug[CH_INIT]("    [initCard] Step 3: Recovery flush (4096 clocks to clear stuck transfer)...")
  repeat RECOVERY_FLUSH_CLKS                                                      '  Enough to flush a full 512-byte sector
    pinh(sck)
    waitus(10)
    pinl(sck)
    waitus(10)

  debug[CH_INIT]("    [initCard] MISO after recovery flush: ", udec_(pinr(miso)), " (should be 1)")

  ' ============================================
  ' STEP 3.5: Initialize smart pins for SPI
  ' ============================================
  debug[CH_INIT]("    [initCard] Step 3.5: Initializing smart pins (ManAtWork pattern)...")
  initSPIPins()
  applySPISpeed(INIT_SPI_FREQ)                                                  ' 400 kHz for init
  waitus(SMARTPIN_SETTLE_US)                                                    ' Let smart pins settle

  ' Send dummy clocks using smart pins
  repeat INIT_DUMMY_BYTES
    sp_transfer_8($FF)
  debug[CH_INIT]("    [initCard] Dummy clocks sent via smart pins")

  ' ============================================
  ' STEP 4: CMD0 - GO_IDLE_STATE
  ' Sends: 0x40 0x00 0x00 0x00 0x00 0x95
  ' Expected R1: 0x01 (in idle state)
  ' ============================================
  debug[CH_INIT]("    [initCard] Step 4: CMD0 (GO_IDLE_STATE)...")
  resp := 0
  got_response := false
  repeat CMD0_MAX_RETRIES                                                       '  try up to 5 times
    resp := cmd(CMD0, 0)
    debug[CH_INIT]("    [initCard] CMD0 response: $", uhex_(resp))
    if resp <> 0                                                                '  cmd() returns 0 on timeout
      got_response := true
    if resp == R1_IN_IDLE
      quit
    waitms(CMD_RETRY_DELAY_MS)

  result := true                                                                '  optimistic - set false on any failure

  if resp <> $01
    if not got_response
      debug[CH_INIT]("    [initCard] No card detected (MISO idle across all CMD0 attempts)")
      result := false
      last_init_error := E_NO_CARD
    else
      debug[CH_INIT]("    [initCard] Card responded but CMD0 failed: $", uhex_(resp))
      result := false
      last_init_error := E_BAD_RESPONSE

  if result
    debug[CH_INIT]("    [initCard] CMD0 OK - card in idle state")

    ' ============================================
    ' STEP 5: CMD8 - SEND_IF_COND
    ' Sends: 0x48 0x00 0x00 0x01 0xAA 0x87
    ' Argument: VHS=0x01 (2.7-3.6V), check_pattern=0xAA
    ' Expected R7: R1 + 4 bytes echoing VHS and pattern
    ' ============================================
    debug[CH_INIT]("    [initCard] Step 5: CMD8 (SEND_IF_COND, VHS=1, pattern=$AA)...")
    resp := cmd(CMD8, CMD8_CHECK_PATTERN)                                                   '  send CMD8, get 32-bit echo
    debug[CH_INIT]("    [initCard] CMD8 response (32-bit): $", uhex_long(resp))

    card_version := 1                                                           '  assume v1.x until proven otherwise
    acmd41_arg := $00000000                                                     '  HCS=0 for v1.x cards

    if resp == 0                                                                '  timeout or no response
      debug[CH_INIT]("    [initCard] CMD8 no response -> Ver 1.x SD card (SDSC only)")
      card_version := 1
      acmd41_arg := $00000000                                                   '  no HCS for v1.x
    elseif (resp & CMD8_ECHO_MASK) == CMD8_ECHO_EXPECTED                         '  check VHS and pattern echo
      debug[CH_INIT]("    [initCard] CMD8 echo valid ($1AA) -> Ver 2.0+ SD card")
      card_version := 2
      acmd41_arg := ACMD41_HCS_BIT                                               '  HCS=1 for v2.0+ (support SDHC/SDXC)
    else
      debug[CH_INIT]("    [initCard] CMD8 echo unexpected: $", uhex_long(resp & CMD8_ECHO_MASK), " expected $1AA")
      debug[CH_INIT]("    [initCard] Treating as Ver 1.x card")
      card_version := 1
      acmd41_arg := $00000000

    ' ============================================
    ' STEP 6: ACMD41 - SD_SEND_OP_COND (loop until ready)
    ' Requires CMD55 prefix before each ACMD41
    ' CMD55: 0x77 0x00 0x00 0x00 0x00 0x65
    ' ACMD41: 0x69 [arg] CRC
    ' Expected R1: 0x00 when ready, 0x01 while initializing
    ' ============================================
    debug[CH_INIT]("    [initCard] Step 6: ACMD41 init loop (arg=$", uhex_long(acmd41_arg), ")...")
    timeout := getct() + clkfreq * ACMD41_TIMEOUT_SECS                          '  2 second timeout

    repeat
      resp := cmd(CMD55, 0)                                                        '  APP_CMD prefix
      if resp > $01                                                             '  error other than "in idle"
        debug[CH_INIT]("    [initCard] CMD55 error: $", uhex_(resp))
        waitms(ACMD41_POLL_DELAY_MS)
      else
        resp := cmd(ACMD41, acmd41_arg)                                             '  SD_SEND_OP_COND
        if resp == $00                                                          '  card ready (not in idle anymore)
          debug[CH_INIT]("    [initCard] ACMD41 complete - card ready!")
          quit
        elseif resp == R1_IN_IDLE                                                '  still initializing
          ' continue looping
        else
          debug[CH_INIT]("    [initCard] ACMD41 unexpected response: $", uhex_(resp))

      if getct() - timeout > 0
        debug[CH_INIT]("    [initCard] FAIL: ACMD41 timeout after 2 seconds")
        debug[CH_INIT]("    [initCard] Last response: $", uhex_(resp))
        result := false
        last_init_error := E_TIMEOUT
        quit
      waitms(ACMD41_POLL_DELAY_MS)

  if result
    ' ============================================
    ' STEP 7: CMD58 - READ_OCR
    ' Sends: 0x7A 0x00 0x00 0x00 0x00 0xFD
    ' Expected R3: R1 + 32-bit OCR register
    ' Check bit 31 (busy), bit 30 (CCS)
    ' ============================================
    debug[CH_INIT]("    [initCard] Step 7: CMD58 (READ_OCR)...")
    resp := cmd(CMD58, 0)
    ocr_value := resp                                                           '  Cache OCR for later retrieval
    debug[CH_INIT]("    [initCard] OCR: $", uhex_long(resp))
    debug[CH_INIT]("    [initCard]   Bit 31 (ready): ", udec((resp >> 31) & 1))
    debug[CH_INIT]("    [initCard]   Bit 30 (CCS):   ", udec((resp >> OCR_CCS_SHIFT) & 1))

    if (resp >> OCR_CCS_SHIFT) & 1
      hcs := 0                                                                  '  SDHC/SDXC: block addressing (no shift)
      debug[CH_INIT]("    [initCard] Card type: SDHC/SDXC (block addressing)")
    else
      hcs := 9                                                                  '  SDSC: byte addressing (shift by 9 = multiply by 512)
      debug[CH_INIT]("    [initCard] Card type: SDSC (byte addressing)")

    ' ============================================
    ' STEP 8: Identify card and set optimal SPI speed
    ' Reads CID for manufacturer ID, CSD for TRAN_SPEED
    ' ============================================
    pinh(cs)                                                                    '  ensure CS HIGH before CID/CSD read
    debug[CH_INIT]("    [initCard] Step 8: Card identification and speed selection...")
    identifyCard()                                                              '  read CID/CSD, identify manufacturer
    setOptimalSpeed()                                                           '  set speed based on card type
    ' Send dummy clocks with CS HIGH to stabilize new clock rate
    repeat POST_INIT_DUMMY_REPS
      sp_transfer(-1, 8)                                                        '  8 dummy bytes = 64 clocks (using smart pins)
    debug[CH_INIT]("    [initCard] Dummy clocks sent, CS HIGH")

    ' ============================================
    ' STEP 9: Probe CMD13 reliability
    ' Some older/budget controllers don't implement CMD13 in SPI mode.
    ' Detect this now so checkCardStatus() can skip CMD13 on broken cards.
    ' See DOCs/Analysis/CMD13-COMPATIBILITY-ANALYSIS.md
    ' ============================================
    cmd13_reliable := TRUE
    card_warning_flags := CW_NONE
    probeCmd13()

    ' STEP 10: Check CMD23 support from SCR CMD_SUPPORT field
    probeCmd23()

    debug[CH_INIT]("    [initCard] === INIT SUCCESS ===")


PRI cmd(op,parm) : result | timeout, timed_out
' Send a SPI command using smart pins - sends command byte, argument, and CRC.
' Handles R1, R3, and R7 response formats based on command type.
'
' @param op - Command number (0-63)
' @param parm - 32-bit command argument
' @returns result - R1 response, or R3/R7 32-bit value for CMD8/CMD58
' @local timeout - Timeout deadline
' @local timed_out - TRUE if response polling timed out

  if op == CMD0
    debug[CH_INIT]("      [cmd] CS before assert: ", udec_(pinr(cs)))
  sp_transfer(-1,8)                                                             '  required for certain cards (my 512MB card fails if not present)
  pinl(cs)                                                                      '  CS LOW = selected (standard active-LOW)
  if op == CMD0
    debug[CH_INIT]("      [cmd] CS after pinl: ", udec_(pinr(cs)), " MISO=", udec_(pinr(miso)))
  sp_transfer(-1,8)                                                             '  required for certain cards (my 512MB and 32GB cards fail if not present)
  sp_transfer($40 | op,8)
  sp_transfer(parm,32)
  if op == CMD0
    sp_transfer(CRC_CMD0,8)                                                     '  send CRC for cmd(0,0)
    debug[CH_INIT]("      [cmd] After CMD0 sent, MISO=", udec_(pinr(miso)))
  else
    sp_transfer(CRC_CMD8,8)                                                     '  send CRC for cmd(8,$1AA)
  timed_out := false
  timeout := getct() + clkfreq
  repeat
    result := sp_transfer(-1,8)                                                 '  read 1st byte of reply
    if (result & $80) == 0                                                      '  valid R1 has bit 7 = 0 (SD spec 7.3.2.1)
      quit
    if getct() - timeout > 0                                                    '  check timeout
      pinh(cs)                                                                  '  CS HIGH = deselected (standard active-LOW)
      result := false
      timed_out := true
      quit
  if not timed_out
    if op == CMD8 or op == CMD58                                                '  read 32-bit reply for cmd8 and cmd58
      result := sp_transfer(-1,32)                                              '  (memory card interface condition and operation conditions register
    if op <> CMD17 and op <> CMD24 and op <> CMD18 and op <> CMD25 and op <> CMD55  '  keep cs asserted for sector read/write and application commands
      pinh(cs)                                                                  '  CS HIGH = deselected (standard active-LOW)


PRI readSector(sector, buf_type) : result | _sck, _miso, data, loop_ctr, timeout, stream_mode, clk_count, xfrq, init_phase, p_buf, align_delay, p_cache, attempt
' Read a sector into buffer using P2 streamer - hardware DMA for bulk 512-byte transfer.
' Reference: flash_loader.spin2 pattern for SPI reads
'
' Protocol:
' 1. CMD17 (READ_SINGLE_BLOCK) with sector address
' 2. Wait for $FE start token (polled via sp_transfer_8)
' 3. Receive 512 bytes via streamer (MISO -> hub)
' 4. Receive 2 CRC bytes, validate against calculated CRC
' 5. Deselect card
'
' @param sector - Sector number to read
' @param buf_type - Buffer type: BUF_DIR, BUF_FAT, or BUF_DATA
' @returns result - 0 on success, negative error code on failure
' @local _sck - Local copy of SCK pin
' @local _miso - Local copy of MISO pin
' @local data - Received data/token
' @local loop_ctr - Token polling counter
' @local timeout - Timeout deadline
' @local stream_mode - Streamer mode word
' @local clk_count - Number of clock transitions
' @local xfrq - Streamer NCO frequency
' @local init_phase - Streamer initial phase
' @local p_buf - Pointer to destination buffer
' @local align_delay - Alignment delay before streamer
' @local p_cache - Pointer to cache variable
' @local attempt - CRC retry loop counter

  ' Select buffer and cache based on type
  case buf_type
    BUF_DIR:
      p_buf := @dir_buf
      p_cache := @dir_sec_in_buf
    BUF_FAT:
      p_buf := @fat_buf
      p_cache := @fat_sec_in_buf
    other:  ' BUF_DATA or default
      p_buf := @buf
      p_cache := @sec_in_buf

  if sector <> long[p_cache]                                                    '  cache miss - must read from card
    'debug[CH_SECTOR]("  [readSector] Reading sector ", udec_(sector), " type=", udec_(buf_type), " p_buf=", uhex_(p_buf))
    long[p_cache] := sector

    ' Pre-compute streamer constants (invariant across retries)
    _sck := sck
    _miso := miso
    stream_mode := STREAM_RX_BASE | (_miso << 17) | (SECTOR_SIZE * 8)            ' RX mode + MISO pin + bit count
    clk_count := SECTOR_SIZE * 8 * 2                                             ' 8192 clock transitions
    xfrq := $4000_0000 / spi_period                                             ' One sample per full clock period
    init_phase := $4000_0000                                                    ' Sample mid-bit for stability
    align_delay := spi_period                                                   ' Wait one half-period before streamer

    ' ══════════════════════════════════════════════════════════════════════════
    ' CRC RETRY LOOP: Re-read on CRC mismatch (industry standard practice)
    ' Card has no CRC-error state - it just sees another CMD17 on retry
    ' ══════════════════════════════════════════════════════════════════════════
    repeat attempt from 1 to MAX_READ_CRC_RETRIES

      ' Send CMD17 (READ_SINGLE_BLOCK)
      cmd(CMD17, sector << hcs)

      ' Wait for start token ($FE) - use sp_transfer_8 for token polling
      timeout := getct() + (clkfreq / 100) * card_read_timeout_ms               ' CSD-based timeout with 10x margin
      loop_ctr := 0
      repeat
        data := sp_transfer_8($FF)
        loop_ctr++
        if data == $FE
          quit                                                                  ' Got start token
        if data <> $FF
          debug[CH_SECTOR]("  [readSector] ERROR: got $", uhex_byte_(data), " instead of $FF or $FE")
          pinh(cs)
          long[p_cache] := -1
          result := E_BAD_RESPONSE
          quit
        if getct() - timeout > 0
          debug[CH_SECTOR]("  [readSector] TIMEOUT waiting for start token")
          pinh(cs)
          long[p_cache] := -1
          result := E_TIMEOUT
          quit
      if result < 0                                                             '  token error or timeout
        quit                                                                    '   exit retry loop

      ' ════════════════════════════════════════════════════════════════════════
      ' STREAMER BULK TRANSFER: Receive 512 bytes from MISO to hub buffer
      ' Pattern: SETXFRQ -> WRFAST -> WYPIN(clk) -> WAITX -> XINIT -> WAITXFI
      ' CRITICAL: Must disable MISO smart pin before streamer capture!
      ' ════════════════════════════════════════════════════════════════════════

      ' CRITICAL FIX: Disable MISO smart pin before streamer capture
      ' The smart pin interferes with streamer's direct pin reading
      ' Reference: flash_loader.spin2 does NOT configure smart pin on MISO during reads
      ' Verified fix: 2026-01-23 in SD_streamer_lut_test.spin2
      pinclear(_miso)                                                           ' Clear smart pin mode
      pinf(_miso)                                                               ' Float pin (input mode)

      ' DIAGNOSTIC: Capture buffer state BEFORE streamer
      diag_before_b0 := byte[p_buf]
      diag_before_b1 := byte[p_buf+1]
      diag_before_b2 := byte[p_buf+2]
      diag_before_b3 := byte[p_buf+3]
      diag_spi_period := spi_period

      ' ════════════════════════════════════════════════════════════════════════
      ' STREAMER BULK TRANSFER: 512 bytes from MISO to hub via DMA
      ' ════════════════════════════════════════════════════════════════════════
      org
            dirl    _sck                              ' Reset SCK: counter stops, output LOW, Y=0
            drvl    _sck                              ' Re-enable: DIR=1 restarts base period counter fresh
            setxfrq xfrq                              ' Set streamer NCO rate
            wrfast  #0, p_buf                         ' Setup WRFAST to hub buffer
            wypin   clk_count, _sck                   ' Start clock transitions
            waitx   align_delay                       ' Wait one half-period to align with first rising edge
            xinit   stream_mode, init_phase           ' Start streamer with phase offset
            waitxfi                                   ' Wait for streamer to complete
      end

      ' DIAGNOSTIC: Capture data for test cog to read
      diag_last_sector := sector
      diag_last_buftype := buf_type
      diag_last_token := data                                                   ' Start token ($FE if success)
      diag_p_buf := p_buf
      diag_buf_byte0 := byte[p_buf]
      diag_buf_byte1 := byte[p_buf+1]
      diag_buf_byte2 := byte[p_buf+2]
      diag_buf_byte3 := byte[p_buf+3]

      ' Re-enable MISO smart pin for CRC reads (sp_transfer_8 needs it)
      wrpin(_miso, spi_rx_mode)                                                 ' P_SYNC_RX | P_PLUS3_B
      wxpin(_miso, %1_00111)                                                    ' On-edge sample, 8 bits
      pinh(_miso)                                                               ' DIRH - enable smart pin

      ' Read and capture 2 CRC bytes (high byte first per SD protocol)
      diag_recv_crc := sp_transfer_8($FF) << 8
      diag_recv_crc |= sp_transfer_8($FF)

      ' CRC-16 validation: validate received data against card's CRC (when enabled)
      if not diag_crc_enabled
        pinh(cs)                                                                ' Deselect card - skip CRC check
        quit                                                                    ' Exit retry loop (assume success)
      diag_calc_crc := calcDataCRC(p_buf, SECTOR_SIZE)
      ' TEST HOOK: Force CRC mismatch for error injection testing
      if test_force_read_crc_error > 0
        diag_calc_crc ^= $FFFF
        test_force_read_crc_error--
        test_error_count++
      if diag_calc_crc == diag_recv_crc
        diag_crc_matches++
        pinh(cs)                                                                ' Deselect card - CRC OK
        quit                                                                    ' Exit retry loop on success
      else
        diag_crc_mismatches++
        pinh(cs)                                                                ' Deselect card before retry
        sp_transfer_8($FF)                                                      ' 8 NCS recovery clocks (CS HIGH, SD spec)
        if attempt < MAX_READ_CRC_RETRIES
          diag_crc_retries++
          debug[CH_SECTOR]("  [readSector] CRC MISMATCH attempt ", udec_(attempt), "/", udec_(MAX_READ_CRC_RETRIES), " recv=$", uhex_(diag_recv_crc), " calc=$", uhex_(diag_calc_crc), " - retrying")
          long[p_cache] := -1                                                   ' Invalidate cache before retry
        else
          debug[CH_SECTOR]("  [readSector] CRC FAILED after ", udec_(MAX_READ_CRC_RETRIES), " attempts recv=$", uhex_(diag_recv_crc), " calc=$", uhex_(diag_calc_crc))
          long[p_cache] := -1                                                   ' Invalidate cache on failure
          result := E_CRC_ERROR

    ' CMD13: Verify card internal state after read
    ' CRC validates wire integrity; CMD13 validates card-internal state (ECC, address, etc.)
    if result == 0 and checkCardStatus(@"readSector") < 0
      long[p_cache] := -1                                                       ' Invalidate cache on card error
      result := E_IO_ERROR
  ' else: cache hit - result stays 0 (success)


PRI readSectors(start_sector, count, p_buffer) : sectors_read | _sck, _miso, p_buf, stream_mode, clk_count, xfrq, init_phase, align_delay, resp
' Read multiple consecutive sectors using CMD18 (READ_MULTIPLE_BLOCK).
' More efficient than individual readSector() calls because:
' - Only one CMD18 command instead of N CMD17 commands
' - No inter-sector gaps from CS deassert/reassert
' - Card can pre-fetch ahead for sequential access
'
' Protocol: CMD18 -> (wait $FE -> read 512 bytes -> CRC) x N -> CMD12
'
' @param start_sector - First sector to read
' @param count - Number of sectors to read (0 returns immediately)
' @param p_buffer - Pointer to buffer (must be at least count * 512 bytes)
' @returns sectors_read - Number of sectors successfully read (0 on error)
' @local _sck - Local copy of SCK pin
' @local _miso - Local copy of MISO pin
' @local p_buf - Current buffer position
' @local stream_mode - Streamer mode word
' @local clk_count - Number of clock transitions
' @local xfrq - Streamer NCO frequency
' @local init_phase - Streamer initial phase
' @local align_delay - Alignment delay before streamer
' @local resp - Command response

  if count > 0
    ' Setup variables for streamer
    _sck := sck
    _miso := miso
    stream_mode := STREAM_RX_BASE | (_miso << 17) | (SECTOR_SIZE * 8)            ' RX mode + MISO pin + 4096 bits
    clk_count := SECTOR_SIZE * 8 * 2                                             ' 8192 clock transitions
    xfrq := $4000_0000 / spi_period                                             ' One sample per full clock period
    init_phase := $4000_0000                                                    ' Sample mid-bit for stability
    align_delay := spi_period                                                   ' Wait one half-period before streamer

    ' Send CMD23 (SET_BLOCK_COUNT) if card supports it (verified at init by probeCmd23)
    last_cmd18_fail := 0                                                        ' Clear failure path
    last_cmd23_used := FALSE
    last_cmd23_r1 := $FF                                                        ' Default: not sent
    last_cmd23_verify := $FF                                                    ' Default: idle
    if cmd23_supported
      resp := cmd(CMD23, count)
      last_cmd23_r1 := resp
      last_cmd23_used := TRUE
      debug[CH_SECTOR]("  [readSectors] CMD23 set block count=", udec_(count))

    ' Send CMD18 (READ_MULTIPLE_BLOCK) with starting sector
    ' Note: cmd() handles CS assertion and returns R1 response
    resp := cmd(CMD18, start_sector << hcs)
    last_cmd18_r1 := resp
    if resp <> $00
      last_cmd18_fail := 1                                                      ' Path 1: R1 reject
      debug[CH_SECTOR]("  [readSectors] CMD18 failed, R1=$", uhex_byte_(resp))
      pinh(cs)
    else
      ' Read each sector
      sectors_read := 0
      repeat count
        p_buf := p_buffer + (sectors_read * SECTOR_SIZE)                         ' Calculate buffer position

        ' Wait for data token ($FE) for this sector
        if waitDataToken() < 0
          last_cmd18_fail := 2                                                  ' Path 2: data token fail
          debug[CH_SECTOR]("  [readSectors] No data token for sector ", udec_(start_sector + sectors_read))
          quit                                                                  ' Exit loop on error

        ' Disable MISO smart pin before streamer capture
        pinclear(_miso)
        pinf(_miso)

        ' Streamer bulk transfer: 512 bytes from MISO to hub
        org
              dirl    _sck                              ' Reset SCK: counter stops, output LOW, Y=0
              drvl    _sck                              ' Re-enable: DIR=1 restarts base period counter fresh
              setxfrq xfrq
              wrfast  #0, p_buf
              wypin   clk_count, _sck
              waitx   align_delay
              xinit   stream_mode, init_phase
              waitxfi
        end

        ' Re-enable MISO smart pin for CRC reads
        wrpin(_miso, spi_rx_mode)
        wxpin(_miso, %1_00111)
        pinh(_miso)

        ' Read and capture 2 CRC bytes, validate against calculated CRC
        diag_recv_crc := sp_transfer_8($FF) << 8
        diag_recv_crc |= sp_transfer_8($FF)

        if diag_crc_enabled
          diag_calc_crc := calcDataCRC(p_buf, SECTOR_SIZE)
          if diag_calc_crc == diag_recv_crc
            diag_crc_matches++
          else
            diag_crc_mismatches++
            debug[CH_SECTOR]("  [readSectors] CRC MISMATCH sec ", udec_(start_sector + sectors_read), " recv=$", uhex_(diag_recv_crc), " calc=$", uhex_(diag_calc_crc))

        sectors_read++

      ' Capture sectors actually read before CMD12/CMD13 might zero the count
      last_cmd18_sread := sectors_read

      if last_cmd23_used
        ' CMD23 path: card should have auto-stopped after N sectors
        ' Verify: clock one byte — if card stopped, MISO should be $FF (idle)
        resp := sp_transfer_8($FF)
        last_cmd23_verify := resp
        if resp <> $FF
          debug[CH_SECTOR]("  [readSectors] CMD23 WARNING: card still outputting after count reached ($", uhex_byte_(resp), ")")
          ' Card didn't honor CMD23 auto-stop — fall back to CMD12 for this and future reads
          cmd23_supported := FALSE
          last_cmd23_used := FALSE
          sendStopTransmission()
        pinh(cs)                                                                ' Deselect card
        debug[CH_SECTOR]("  [readSectors] CMD23 path: ", udec_(sectors_read), " sectors, no CMD12 needed")

        ' CMD13: Verify card internal state after multi-block read
        if checkCardStatus(@"readSectors") < 0
          last_cmd18_fail := 4                                                  ' Path 4: CMD13 fail
          debug[CH_SECTOR]("  [readSectors] CMD13 status check FAILED")
          sectors_read := 0                                                     ' Card reports error - data can't be trusted
      else
        ' CMD12 path: send CMD12 to stop transmission
        if sendStopTransmission() < 0
          ' CMD12 failed — but if all requested sectors arrived with valid CRC,
          ' the data is trustworthy. Some cards (SP Elite) return garbled R1 from
          ' CMD12 while data transfer is perfect. See rpt6-cmd12-external-analysis.txt.
          recoverToIdle()                                                       ' Force card back to idle
          if sectors_read == count
            last_cmd18_fail := 5                                                ' Path 5: CMD12 fail, tolerated
            debug[CH_SECTOR]("  [readSectors] CMD12 R1 error (tolerated, all ", udec_(count), " sectors received)")
          else
            last_cmd18_fail := 3                                                ' Path 3: CMD12 fail, data incomplete
            debug[CH_SECTOR]("  [readSectors] CMD12 failed - incomplete read, recovering")
            sectors_read := 0                                                   ' Incomplete data can't be trusted
        else
          pinh(cs)                                                              ' Deselect card

          ' CMD13: Verify card internal state after multi-block read
          if checkCardStatus(@"readSectors") < 0
            last_cmd18_fail := 4                                                ' Path 4: CMD13 fail
            debug[CH_SECTOR]("  [readSectors] CMD13 status check FAILED")
            sectors_read := 0                                                   ' Card reports error - data can't be trusted


PRI writeSector(sector, buf_type) : result | _sck, _mosi, p_buf, stream_mode, clk_count, xfrq, resp, p_cache, align_delay
' Write buffer into a sector using P2 streamer - hardware DMA for bulk 512-byte transfer.
' Reference: flash_loader.spin2 pattern for SPI writes
'
' PNY COMPATIBILITY: This implementation follows strict SPI write protocol:
' 1. CMD24 with sector address
' 2. Data start token ($FE)
' 3. 512 bytes of data via streamer (hub -> MOSI)
' 4. 2 CRC bytes (calculated CRC-16-CCITT, high byte first)
' 5. Wait for data-response token ($x5 = accepted)
' 6. Wait for MISO to go HIGH ($FF = programming complete)
' CRITICAL: CS must stay LOW and clocking must continue during entire busy period!
'
' @param sector - Sector number to write
' @param buf_type - Buffer type: BUF_DIR, BUF_FAT, or BUF_DATA
' @returns result - 0 on success, negative error code on failure
' @local _sck - Local copy of SCK pin
' @local _mosi - Local copy of MOSI pin
' @local p_buf - Pointer to source buffer
' @local stream_mode - Streamer mode word
' @local clk_count - Number of clock transitions
' @local xfrq - Streamer NCO frequency
' @local resp - Response byte
' @local p_cache - Pointer to cache variable
' @local align_delay - Alignment delay before streamer

  ' Select buffer and cache based on type
  case buf_type
    BUF_DIR:
      p_buf := @dir_buf
      p_cache := @dir_sec_in_buf
    BUF_FAT:
      p_buf := @fat_buf
      p_cache := @fat_sec_in_buf
    other:  ' BUF_DATA or default
      p_buf := @buf
      p_cache := @sec_in_buf

  _sck := sck
  _mosi := mosi
  ' p_buf already set above based on buf_type

  ' Invalidate cache for this buffer type after write
  long[p_cache] := -1

  ' Cross-buffer cache coherence: if another buffer type has this
  ' sector cached, its copy is now stale after our write
  if dir_sec_in_buf == sector
    dir_sec_in_buf := -1
  if fat_sec_in_buf == sector
    fat_sec_in_buf := -1
  if sec_in_buf == sector
    sec_in_buf := -1

  ' Capture sector for diagnostics
  diag_write_sector := sector
  diag_write_result := 0                                                         ' Reset: not yet determined

  resp := cmd(CMD24, sector << hcs)
  diag_write_r1 := resp                                                          ' Capture CMD24 R1 response
  if resp & R1_FATAL_MASK                                                        ' Fatal R1 bits: illegal cmd ($04), address err ($20), parameter err ($40)
    debug[CH_SECTOR]("  [writeSector] CMD24 FATAL, R1=$", uhex_byte_(resp))
    diag_write_result := 1                                                       ' 1 = CMD24 fatal
    pinh(cs)
    result := E_IO_ERROR
  else
    if resp & R1_STALE_MASK                                                      ' Stale R1 bits: idle ($01), erase reset ($02), CRC ($08), erase seq ($10)
      debug[CH_SECTOR]("  [writeSector] CMD24 warning: R1=$", uhex_byte_(resp), " (stale bits, proceeding)")
    sp_transfer_8($FE)                                                          ' Data start token

    ' ══════════════════════════════════════════════════════════════════════════
    ' STREAMER BULK TRANSFER: Send 512 bytes from hub buffer to MOSI
    ' Pattern: SETXFRQ -> RDFAST -> XINIT -> WYPIN(clk) -> WAITXFI
    ' ══════════════════════════════════════════════════════════════════════════
    ' Mode word format: base_mode | (pin << 17) | bit_count
    ' For 512 bytes: 512 * 8 = 4096 bits = $1000
    stream_mode := STREAM_TX_BASE | (_mosi << 17) | (SECTOR_SIZE * 8)            ' TX mode + MOSI pin + bit count
    clk_count := SECTOR_SIZE * 8 * 2                                             ' 8192 clock transitions

    ' Calculate streamer NCO frequency to match SPI clock
    ' Same formula as readSector: one bit per full clock period
    xfrq := $4000_0000 / spi_period                                             ' One output per full clock period
    if ($4000_0000 // spi_period) == 0                                          ' Exact division (power-of-2 hp)?
      xfrq -= 1                                                                ' Ensure 1-cycle late rollover like truncated values
    align_delay := spi_period - 2                                                ' NCO ramp delay minus 2 instruction cycles

    pinclear(_mosi)                                                             ' Clear smart pin mode (WRPIN=0, DIR=0)
    pinl(_mosi)                                                                 ' Drive pin low (DIR=1, output mode)

    ' Streamer TX with deterministic clock alignment:
    '   1. dirl/pinl on SCK resets the P_TRANSITION base-period counter to a known state
    '      (DIR=0 resets counter, output, Y without clearing WRPIN/WXPIN config)
    '   2. xinit starts streamer NCO from phase=0
    '   3. waitx gives NCO time to output first data bit before first SCK edge
    '   4. wypin starts clock - base period counter phase is now deterministic
    '      (not dependent on free-running counter from init)
    '
    ' Timing (all relative to pinl, each PASM instruction = 2 sysclk cycles):
    '   T=0:  pinl (SCK counter starts fresh)
    '   T=2:  setxfrq
    '   T=4:  rdfast
    '   T=6:  xinit (streamer NCO starts; first data bit at T=6 + 2*spi_period)
    '   T=8:  waitx begins (waits align_delay cycles)
    '   T=8+align_delay: wypin (clock starts; first edge at next base period boundary)
    org
          dirl    _sck                              ' Reset SCK: counter stops, output LOW, Y=0
          drvl    _sck                              ' Re-enable: DIR=1 restarts base period counter fresh
          setxfrq xfrq                              ' Set streamer bit rate
          rdfast  #0, p_buf                         ' Setup RDFAST from hub buffer
          xinit   stream_mode, #0                    ' Start streamer; NCO ramps from zero
          waitx   align_delay                        ' Wait for NCO to output first data bit
          wypin   clk_count, _sck                   ' Start clock - deterministic phase from drvl
          waitxfi                                   ' Wait for streamer to complete
    end

    ' Rebuild MOSI smart pin for CRC and response byte transfers
    wrpin(_mosi, spi_tx_mode)                                                   ' P_SYNC_TX | P_OE | P_PLUS2_B
    wxpin(_mosi, %1_00111)                                                      ' Start-stop mode, 8 bits
    pinh(_mosi)                                                                 ' DIRH - enable smart pin

    ' Calculate CRC-16 of the data we just sent and transmit it
    ' SD protocol: CRC high byte first, then low byte
    diag_sent_crc := calcDataCRC(p_buf, SECTOR_SIZE)
    ' TEST HOOK: Corrupt write CRC for error injection testing (one-shot)
    if test_force_write_crc_error
      diag_sent_crc ^= $FFFF
      test_force_write_crc_error := 0
      test_error_count++
    sp_transfer_8(diag_sent_crc >> 8)                                           ' CRC high byte
    sp_transfer_8(diag_sent_crc & $FF)                                          ' CRC low byte

    ' Wait for data-response token (should be immediate, within a few bytes)
    resp := waitDataResponse()
    if resp < 0
      diag_write_result := 2                                                    ' 2 = data-response timeout
      diag_write_dresp := $FF
      pinh(cs)
      result := E_TIMEOUT
    else
      diag_write_dresp := resp                                                  ' Capture data response token (masked)
      ' Verify data-response token: bits [3:1] decode as: 010=accepted, 101=CRC error, 110=write error
      if resp <> DATA_ACCEPTED
        if resp == DATA_CRC_ERROR
          debug[CH_SECTOR]("  [writeSector] Data REJECTED: CRC error (response=$", uhex_byte_(resp), ")")
          diag_write_result := 3                                                ' 3 = CRC reject
          result := E_WRITE_REJECTED
        elseif resp == DATA_WRITE_ERROR
          debug[CH_SECTOR]("  [writeSector] Data REJECTED: Write error (response=$", uhex_byte_(resp), ")")
          diag_write_result := 4                                                ' 4 = write error reject
          result := E_WRITE_REJECTED
        else
          debug[CH_SECTOR]("  [writeSector] Data REJECTED: Unknown status (response=$", uhex_byte_(resp), ")")
          diag_write_result := 5                                                ' 5 = unknown reject
          result := E_IO_ERROR
        pinh(cs)

    if result == SUCCESS
      ' Wait for card to finish programming (busy period)
      ' CRITICAL for PNY: Keep CS LOW and keep clocking until card releases MISO!
      if waitBusyComplete() < 0
        diag_write_result := 6                                                  ' 6 = busy timeout
        pinh(cs)
        result := E_CARD_BUSY

    if result == SUCCESS
      pinh(cs)
      diag_write_result := 7                                                    ' 7 = success

      ' CMD13: Verify card internal state after write
      ' Data response $05 confirms wire-level acceptance; CMD13 validates card-internal state
      if checkCardStatus(@"writeSector") < 0
        result := E_IO_ERROR


PRI writeSectors(start_sector, count, p_buffer) : sectors_written | _sck, _mosi, p_buf, stream_mode, clk_count, xfrq, resp, align_delay
' Write multiple consecutive sectors using CMD25 (WRITE_MULTIPLE_BLOCK).
' More efficient than individual writeSector() calls because:
' - Only one CMD25 command instead of N CMD24 commands
' - Card can optimize internal flash writes for sequential access
' - Reduced overhead from CS cycling and command processing
'
' CRITICAL: Multi-block write uses different tokens than single-block!
' - Each data block uses $FC (not $FE) as start token
' - Transmission ends with $FD stop token (not CMD12!)
'
' Protocol: CMD25 -> ($FC + 512 bytes + CRC + wait busy) x N -> $FD -> wait busy
'
' @param start_sector - First sector to write
' @param count - Number of sectors to write (0 returns immediately)
' @param p_buffer - Pointer to source data (must be at least count * 512 bytes)
' @returns sectors_written - Number of sectors successfully written (0 on error)
' @local _sck - Local copy of SCK pin
' @local _mosi - Local copy of MOSI pin
' @local p_buf - Current buffer position
' @local stream_mode - Streamer mode word
' @local clk_count - Number of clock transitions
' @local xfrq - Streamer NCO frequency
' @local resp - Response byte
' @local align_delay - Alignment delay before streamer

  if count > 0
    ' Setup variables for streamer
    _sck := sck
    _mosi := mosi
    stream_mode := STREAM_TX_BASE | (_mosi << 17) | (SECTOR_SIZE * 8)            ' TX mode + MOSI pin + 4096 bits
    clk_count := SECTOR_SIZE * 8 * 2                                             ' 8192 clock transitions
    xfrq := $4000_0000 / spi_period                                             ' One output per full clock period
    if ($4000_0000 // spi_period) == 0                                          ' Exact division (power-of-2 hp)?
      xfrq -= 1                                                                ' Ensure 1-cycle late rollover like truncated values
    align_delay := spi_period - 2                                                ' NCO ramp delay minus 2 instruction cycles

    ' Send CMD25 (WRITE_MULTIPLE_BLOCK) with starting sector
    ' Note: cmd() handles CS assertion and returns R1 response
    resp := cmd(CMD25, start_sector << hcs)
    if resp <> $00
      debug[CH_SECTOR]("  [writeSectors] CMD25 failed, R1=$", uhex_byte_(resp))
      pinh(cs)
    else
      ' Write each sector
      sectors_written := 0
      repeat count
        p_buf := p_buffer + (sectors_written * SECTOR_SIZE)                      ' Calculate buffer position

        ' Send multi-block write start token ($FC, NOT $FE!)
        sp_transfer_8(TOKEN_START_MULTI_WRITE)                                  ' $FC

        pinclear(_mosi)                                                         ' Clear smart pin mode
        pinl(_mosi)                                                             ' Drive pin low (output mode)

        ' Streamer TX with deterministic clock alignment (see writeSector for full rationale)
        ' dirl/drvl resets SCK base-period counter; wypin then starts clock in known phase
        org
              dirl    _sck                              ' Reset SCK: counter stops, output LOW, Y=0
              drvl    _sck                              ' Re-enable: DIR=1 restarts base period counter fresh
              setxfrq xfrq
              rdfast  #0, p_buf
              xinit   stream_mode, #0                  ' Start streamer; NCO ramps from zero
              waitx   align_delay                      ' Wait for NCO to output first bit
              wypin   clk_count, _sck                 ' Start clock - deterministic phase from drvl
              waitxfi
        end

        ' Rebuild MOSI smart pin for CRC and response
        wrpin(_mosi, spi_tx_mode)
        wxpin(_mosi, %1_00111)
        pinh(_mosi)

        ' Calculate and send CRC-16 for this sector's data
        diag_sent_crc := calcDataCRC(p_buf, SECTOR_SIZE)
        sp_transfer_8(diag_sent_crc >> 8)                                       ' CRC high byte
        sp_transfer_8(diag_sent_crc & $FF)                                      ' CRC low byte

        ' Wait for data response token
        resp := waitDataResponse()
        if resp < 0
          debug[CH_SECTOR]("  [writeSectors] No data response for sector ", udec_(start_sector + sectors_written))
          quit
        if (resp & $0F) <> DATA_ACCEPTED
          debug[CH_SECTOR]("  [writeSectors] Data rejected for sector ", udec_(start_sector + sectors_written), " resp=$", uhex_byte_(resp))
          quit

        ' Wait for card to finish programming this block
        if waitBusyComplete() < 0
          debug[CH_SECTOR]("  [writeSectors] Busy timeout for sector ", udec_(start_sector + sectors_written))
          quit

        sectors_written++

      ' Send stop token ($FD) to terminate multi-block write (NOT CMD12!)
      sp_transfer_8(TOKEN_STOP_TRAN)                                            ' $FD
      sp_transfer_8($FF)                                                        ' Stuff byte (NWR=1, required by spec)

      ' Wait for card to finish any final programming - card is in PROGRAMMING state
      if waitBusyComplete() < 0
        debug[CH_SECTOR]("  [writeSectors] Final busy timeout - card still programming, recovering")
        recoverToIdle()                                                         ' Force card back to idle
        sectors_written := 0                                                    ' Write integrity unknown
      else
        pinh(cs)                                                                ' Deselect card

        ' CMD13: Verify card internal state after multi-block write
        if checkCardStatus(@"writeSectors") < 0
          debug[CH_SECTOR]("  [writeSectors] CMD13 status check FAILED after writing ", udec_(sectors_written), " sectors")
          sectors_written := 0                                                  ' Card reports error - writes can't be trusted


PRI waitDataToken() : result | timeout, resp
' Wait for data start token ($FE) - polls for data token before sector data.
' Error tokens: $01-$0F indicate read errors.
' Timeout: Uses card_read_timeout_ms from CSD (minimum 100ms, with 10x safety factor)
'
' @returns result - 0 on success (got $FE), negative error code on timeout or error token
' @local timeout - Timeout deadline
' @local resp - Received byte

  result := E_TIMEOUT                                                           '  default: timeout
  last_cmd18_token := $FF                                                       ' Default: no token received
  last_cmd18_result := 1                                                        ' Default: timeout
  timeout := getct() + (clkfreq / 100) * card_read_timeout_ms                   ' CSD-based timeout with 10x margin
  repeat
    resp := sp_transfer_8($FF)
    if resp == TOKEN_START_BLOCK                                                ' $FE = data coming
      last_cmd18_token := resp
      last_cmd18_result := 0                                                    ' Success
      result := 0                                                               ' Success
      quit
    if resp <> $FF                                                              ' Error token (not $FF, not $FE)
      last_cmd18_token := resp
      last_cmd18_result := 2                                                    ' Error token
      debug[CH_RECOVER]("  [waitDataToken] ERROR token: $", uhex_byte_(resp))
      result := E_BAD_RESPONSE
      quit
    if getct() - timeout > 0
      debug[CH_RECOVER]("  [waitDataToken] TIMEOUT")
      quit


PRI waitDataResponse() : result | timeout, resp
' Wait for data response token after write - polls for data response after sending a block.
' Response format: xxx0sss1 where sss = 010 (accepted), 101 (CRC err), 110 (write err)
' Timeout: 100ms
'
' @returns result - Response status on success, negative error code on timeout
' @local timeout - Timeout deadline
' @local resp - Received byte

  result := E_TIMEOUT                                                           '  default: timeout
  timeout := getct() + clkfreq / 10                                             ' 100ms timeout
  repeat
    resp := sp_transfer_8($FF)
    if resp <> $FF
      ' Got response - check if it's a valid data response token (bit 0 = 1, bit 4 = 0)
      if (resp & $11) == $01                                                    ' Valid data response format
        result := resp & DATA_RESPONSE_MASK                                                    ' Lower 5 bits
        quit
      ' Not a valid response format, keep polling (might be noise)
    if getct() - timeout > 0
      debug[CH_RECOVER]("  [waitDataResponse] TIMEOUT")
      quit


PRI waitBusyComplete() : result | timeout, resp
' Wait for card to finish programming - polls until MISO returns $FF (not busy).
' Timeout: Uses card_write_timeout_ms from CSD (default 250ms for SDHC, calculated for SDSC)
' CRITICAL: Must keep clocking and CS LOW during busy period!
'
' @returns result - 0 on success, negative error code on timeout
' @local timeout - Timeout deadline
' @local resp - Received byte

  result := E_TIMEOUT                                                           '  default: timeout
  timeout := getct() + (clkfreq / 1000) * card_write_timeout_ms                 ' CSD-based timeout
  repeat
    resp := sp_transfer_8($FF)
    if resp == $FF                                                              ' Card released MISO = done
      result := 0
      quit
    if getct() - timeout > 0
      debug[CH_RECOVER]("  [waitBusyComplete] TIMEOUT - card still busy")
      quit


PRI sendStopTransmission() : result | resp, idx, timeout
' Send CMD12 to stop multi-block operation - terminates multi-block read/write.
' Note: CMD12 has a "stuff byte" before the response - we handle this by polling.
' Captures the first 16 bytes after the stuff byte into cmd12_capture[] for framing analysis.
'
' @returns result - 0 on success, negative error code on error
' @local resp - Response byte
' @local idx - Capture buffer index
' @local timeout - Timeout deadline

  ' Capture MISO bytes during CMD12 transmission (full-duplex: card outputs while we send)
  cmd12_pre_capture[0] := sp_transfer_8($40 | CMD12)                            ' Command byte: 0x40 | 12 = 0x4C
  cmd12_pre_capture[1] := sp_transfer_8($00)                                    ' Argument bytes (ignored for CMD12)
  cmd12_pre_capture[2] := sp_transfer_8($00)
  cmd12_pre_capture[3] := sp_transfer_8($00)
  cmd12_pre_capture[4] := sp_transfer_8($00)
  cmd12_pre_capture[5] := sp_transfer_8(CRC_CMD12)                              ' CRC7 + stop bit for CMD12
  cmd12_pre_capture[6] := sp_transfer_8($FF)                                    ' Stuff byte (required by spec)

  ' Capture raw byte stream for framing analysis, then find R1
  bytefill(@cmd12_capture, $FF, 16)
  cmd12_capture_len := 0
  last_cmd12_r1 := -1                                                          ' Default: no response
  last_cmd12_busy := 1                                                         ' Default: timeout

  timeout := getct() + clkfreq / 10                                            ' 100ms timeout
  idx := 0
  repeat
    resp := sp_transfer_8($FF)
    if idx < 16
      cmd12_capture[idx] := resp
      idx++
    if resp <> $FF
      cmd12_capture_len := idx                                                 ' Record position of first non-$FF
      last_cmd12_r1 := resp
      quit
    if getct() - timeout > 0
      cmd12_capture_len := idx
      debug[CH_RECOVER]("  [sendStopTransmission] TIMEOUT waiting for R1")
      result := E_TIMEOUT
      return

  ' Capture remaining bytes after R1 (for post-R1 framing analysis)
  repeat while idx < 16
    cmd12_capture[idx] := sp_transfer_8($FF)
    idx++

  ' Evaluate R1 response
  if last_cmd12_r1 <> $00
    last_cmd12_busy := 2                                                       ' R1 error
    debug[CH_RECOVER]("  [sendStopTransmission] R1 error: $", uhex_byte_(last_cmd12_r1))
    result := E_IO_ERROR
  else
    ' Wait for busy to complete (card may still be finishing last block)
    result := waitBusyComplete()
    if result < 0
      last_cmd12_busy := 3                                                     ' Busy timeout
    else
      last_cmd12_busy := 0                                                     ' Success


PRI recoverToIdle() : result
' Force the card's SPI state machine back to idle by deasserting CS and clocking.
' In SPI mode, CS deassert aborts any pending operation (multi-block read/write, busy).
' Dummy clocks with CS high allow the card to release MISO and transition to standby.
' VERIFIES that the card actually released the bus (MISO goes high).
'
' @returns result - 0 if card released bus, negative error code if card still holding MISO low

  pinh(cs)                                                                        ' CS HIGH - abort any pending operation
  repeat 10
    sp_transfer_8($FF)                                                            ' 80 clocks with CS deasserted - let card release bus

  ' Verify card released MISO (should be high via pull-up when CS is deasserted)
  if pinr(miso) == 0
    ' Card still holding MISO low - try extended clocking
    debug[CH_RECOVER]("  [recoverToIdle] MISO still low after 80 clocks, extending...")
    repeat 20
      sp_transfer_8($FF)                                                          ' 160 more clocks - extended recovery
    if pinr(miso) == 0
      debug[CH_RECOVER]("  [recoverToIdle] FAILED: card holding MISO low after 240 clocks")
      result := E_IO_ERROR                                                        ' Card stuck - caller must handle


PRI sendCmd13Transaction() : r1, status | idx, resp, timeout
' Send CMD13 with full-duplex MISO capture — shared wire transaction for probeCmd13
' and checkCardStatus. Sends dummy clocks with CS HIGH for recovery, then CMD13 with
' full-duplex capture of both pre-command MISO bytes and post-command response stream.
' Populates cmd13_pre_capture[], cmd13_capture[], cmd13_capture_len for diagnostic
' inspection. Stages last_cmd13_r1, last_cmd13_status, last_cmd13_error.
'
' @returns r1 - R1 response byte (-1 if timeout)
' @returns status - STATUS byte (second byte of R2 response), 0 if timeout
' @local idx - Capture buffer index
' @local resp - Received byte
' @local timeout - Timeout deadline

  ' Initialize capture buffers
  bytefill(@cmd13_pre_capture, $FF, 7)
  bytefill(@cmd13_capture, $FF, 8)
  cmd13_capture_len := 0

  ' Send dummy clocks with CS HIGH (card recovery time)
  pinh(cs)
  sp_transfer_8($FF)
  sp_transfer_8($FF)

  ' Send CMD13 with full-duplex MISO capture (card may still be outputting)
  pinl(cs)
  cmd13_pre_capture[0] := sp_transfer_8($40 | CMD13)                              '  command byte
  cmd13_pre_capture[1] := sp_transfer_8($00)                                      '  argument bytes
  cmd13_pre_capture[2] := sp_transfer_8($00)
  cmd13_pre_capture[3] := sp_transfer_8($00)
  cmd13_pre_capture[4] := sp_transfer_8($00)
  cmd13_pre_capture[5] := sp_transfer_8($FF)                                      '  CRC (don't care after init)

  ' Capture raw byte stream and find R1 — skip bytes with bit 7 set (SD spec 7.3.2.1)
  timeout := getct() + clkfreq / 10                                               '  100ms timeout
  idx := 0
  r1 := -1
  repeat
    resp := sp_transfer_8($FF)
    if idx < 8
      cmd13_capture[idx] := resp
      idx++
    if (resp & $80) == 0                                                           '  valid R1 has bit 7 = 0
      cmd13_capture_len := idx
      r1 := resp
      quit
    if getct() - timeout > 0
      cmd13_capture_len := idx
      pinh(cs)
      last_cmd13_r1 := $FF
      return                                                                       '  r1 stays -1, status stays 0

  ' Capture remaining bytes after R1 (STATUS byte + extra for analysis)
  repeat while idx < 8
    cmd13_capture[idx] := sp_transfer_8($FF)
    idx++

  ' STATUS byte is immediately after R1
  status := cmd13_capture[cmd13_capture_len]

  pinh(cs)                                                                         '  deselect card

  ' Stage CMD13 results for diagnostic getters
  last_cmd13_r1 := r1
  last_cmd13_status := status
  if r1 <> 0 or status <> 0
    last_cmd13_error := (r1 << 8) | status


PRI probeCmd13() | r1, status
' Probe CMD13 reliability at end of initCard().
' Sends a single CMD13 on an idle card and checks whether the response is valid.
' If the response violates the SD spec (R1 bit 7 set, or 3+ simultaneous error
' bits in STATUS on an idle card), marks cmd13_reliable := FALSE and sets
' CW_CMD13_UNRELIABLE in card_warning_flags.
'
' @local r1 - R1 response byte from CMD13
' @local status - STATUS byte (second byte of R2 response)

  r1, status := sendCmd13Transaction()

  ' Log full capture for diagnostics
  debug[CH_STATUS]("    [probeCmd13] pre=[", uhex_byte_(cmd13_pre_capture[0]), " ", uhex_byte_(cmd13_pre_capture[1]), " ", uhex_byte_(cmd13_pre_capture[2]), " ", uhex_byte_(cmd13_pre_capture[3]), " ", uhex_byte_(cmd13_pre_capture[4]), " ", uhex_byte_(cmd13_pre_capture[5]), "]")
  debug[CH_STATUS]("    [probeCmd13] cap=[", uhex_byte_(cmd13_capture[0]), " ", uhex_byte_(cmd13_capture[1]), " ", uhex_byte_(cmd13_capture[2]), " ", uhex_byte_(cmd13_capture[3]), " ", uhex_byte_(cmd13_capture[4]), " ", uhex_byte_(cmd13_capture[5]), " ", uhex_byte_(cmd13_capture[6]), " ", uhex_byte_(cmd13_capture[7]), "] NCR=", udec_(cmd13_capture_len))
  debug[CH_STATUS]("    [probeCmd13] R1=$", uhex_byte_(r1), " STATUS=$", uhex_byte_(status))

  ' Check 1: Timeout — sendCmd13Transaction returns r1 = -1
  if r1 == -1
    debug[CH_STATUS]("    [probeCmd13] TIMEOUT - marking CMD13 unreliable")
    cmd13_reliable := FALSE
    card_warning_flags |= CW_CMD13_UNRELIABLE
    return

  ' Check 2: R1 bit 7 must be 0 per SD spec
  if r1 & $80
    debug[CH_STATUS]("    [probeCmd13] R1 bit 7 set - marking CMD13 unreliable")
    cmd13_reliable := FALSE
    card_warning_flags |= CW_CMD13_UNRELIABLE
    return

  ' Check 3: 3+ error bits in STATUS on an idle card = garbage data
  if ones status >= 3
    debug[CH_STATUS]("    [probeCmd13] STATUS has ", udec_(ones status), " error bits - marking CMD13 unreliable")
    cmd13_reliable := FALSE
    card_warning_flags |= CW_CMD13_UNRELIABLE
    return

  debug[CH_STATUS]("    [probeCmd13] CMD13 OK (R1=$", uhex_byte_(r1), " STATUS=$", uhex_byte_(status), ")")


PRI probeCmd23() | scr[2], cmd_support, resp
' Probe CMD23 support at init time.
' First checks SCR CMD_SUPPORT field (bit 1 = CMD23 advertised).
' If advertised, sends a real CMD23 to verify the card accepts it in SPI mode.
' Some cards advertise CMD23 in SCR but reject it in SPI mode (R1=$04 Illegal Command).
' Sets cmd23_supported := TRUE only if the card actually accepts CMD23.
'
' @local scr - SCR register data (2 longs = 8 bytes)
' @local cmd_support - CMD_SUPPORT field from SCR
' @local resp - R1 response from CMD23 probe

  cmd23_supported := FALSE

  ' Step 1: Check SCR CMD_SUPPORT field (pre-filter)
  if readSCR(@scr)
    cmd_support := scr.byte[3] & $03
    if cmd_support & $02
      debug[CH_STATUS]("    [probeCmd23] SCR advertises CMD23 (CMD_SUPPORT=$", uhex_byte_(cmd_support), ") - verifying...")

      ' Step 2: Send real CMD23 with count=1 to verify SPI mode support
      resp := cmd(CMD23, 1)
      if resp == $00
        cmd23_supported := TRUE
        card_warning_flags |= CW_CMD23_SUPPORTED
        debug[CH_STATUS]("    [probeCmd23] CMD23 CONFIRMED - card accepts SET_BLOCK_COUNT in SPI mode")
      else
        debug[CH_STATUS]("    [probeCmd23] CMD23 REJECTED R1=$", uhex_byte_(resp), " - not supported in SPI mode")
    else
      debug[CH_STATUS]("    [probeCmd23] CMD23 not advertised (CMD_SUPPORT=$", uhex_byte_(cmd_support), ")")
  else
    debug[CH_STATUS]("    [probeCmd23] SCR read failed - assuming CMD23 not supported")


PRI checkCardStatus(caller) : result | r1, status
' Send CMD13 to verify card status after operation - checks R2 response for errors.
' R2 response format: R1 byte + status byte.
' Call this after every write operation and after CMD12.
' Skipped on cards where CMD13 was found unreliable at init (unless test_force_cmd13 is set).
'
' @param caller - String identifying the calling function (for debug)
' @returns result - 0 on success (card OK), negative error code on error
' @local r1 - R1 response byte
' @local status - Status byte (second byte of R2)

  ' Skip CMD13 on cards with broken implementation (unless diagnostic override is set)
  if not cmd13_reliable and not test_force_cmd13
    return

  r1, status := sendCmd13Transaction()

  ' Log pre-capture for diagnostic visibility
  debug[CH_STATUS]("  [checkCardStatus] ", zstr_(caller), ": pre=[", uhex_byte_(cmd13_pre_capture[0]), " ", uhex_byte_(cmd13_pre_capture[1]), " ", uhex_byte_(cmd13_pre_capture[2]), " ", uhex_byte_(cmd13_pre_capture[3]), " ", uhex_byte_(cmd13_pre_capture[4]), " ", uhex_byte_(cmd13_pre_capture[5]), "] NCR=", udec_(cmd13_capture_len), " R1=$", uhex_byte_(r1), " ST=$", uhex_byte_(status))

  ' Check for errors
  if r1 == -1
    debug[CH_STATUS]("  [checkCardStatus] ", zstr_(caller), ": TIMEOUT waiting for R1")
    result := E_TIMEOUT
  elseif r1 <> $00
    debug[CH_STATUS]("  [checkCardStatus] ", zstr_(caller), ": R1 error=$", uhex_byte_(r1))
    result := E_IO_ERROR
  elseif status <> $00
    debug[CH_STATUS]("  [checkCardStatus] ", zstr_(caller), ": STATUS error=$", uhex_byte_(status))
    if status & CSR_OUT_OF_RANGE
      debug[CH_STATUS]("    -> OUT_OF_RANGE")
    if status & CSR_ERASE_PARAM
      debug[CH_STATUS]("    -> ERASE_PARAM")
    if status & CSR_WP_VIOLATION
      debug[CH_STATUS]("    -> WP_VIOLATION")
    if status & CSR_CARD_ECC_FAILED
      debug[CH_STATUS]("    -> CARD_ECC_FAILED")
    if status & CSR_CC_ERROR
      debug[CH_STATUS]("    -> CC_ERROR")
    if status & CSR_ERROR
      debug[CH_STATUS]("    -> ERROR")
    if status & CSR_WP_ERASE_SKIP
      debug[CH_STATUS]("    -> WP_ERASE_SKIP")
    if status & CSR_CARD_IS_LOCKED
      debug[CH_STATUS]("    -> CARD_IS_LOCKED")
    result := E_IO_ERROR


PRI transfer(data,bits) : result | _cs, _mosi, _miso, _sck, delay
' Transfer data to/from SD card - bit-bang fallback for unsupported sizes.
'
' @param data - Data to transmit
' @param bits - Number of bits to transfer
' @returns result - Received data
' @local _cs - Local copy of CS pin
' @local _mosi - Local copy of MOSI pin
' @local _miso - Local copy of MISO pin
' @local _sck - Local copy of SCK pin
' @local delay - Bit delay value

  longmove(@_cs,@cs,4)
  delay := bit_delay
  result := data << (32-bits)                                                   '  move data to MSB
  org
                rep       @.end_rep,bits
                 rcl      result,#1                     wc                      '  send from msb of result, receive into lsb of result
                 drvl     _sck
                 drvc     _mosi
                 waitx    delay
                 drvh     _sck
                 waitx    delay
                 testp    _miso                         wc
.end_rep
                drvh      _mosi
                rcl       result,#1
  end
  if bits < 32                                                                   '  mask to requested bit count
    result &= (1 << bits) - 1                                                   '  (skip for 32 bits - mask would wrap)


PRI readDataRegister(cmd_num, arg, crc_byte, p_buf, byte_count) : result | timeout, idx, resp
' Consolidated register read transaction — sends command, waits for R1 and $FE data token,
' reads byte_count bytes into p_buf, consumes 2-byte CRC, deselects card.
' Used by: readCSD (CMD9, 16 bytes), readCID (CMD10, 16 bytes), sendCMD6 (CMD6, 64 bytes),
' readSCR (ACMD51, 8 bytes), readSDStatus (ACMD13, 64 bytes).
'
' @param cmd_num - SD command number (e.g., CMD9, CMD10, CMD6)
' @param arg - 32-bit command argument (0 for most register reads)
' @param crc_byte - Pre-computed CRC-7 byte for this command
' @param p_buf - Pointer to buffer to receive data
' @param byte_count - Number of data bytes to read (8, 16, or 64)
' @returns result - TRUE on success, FALSE on failure/timeout
' @local timeout - Timeout deadline
' @local idx - Loop counter
' @local resp - SPI response byte

  sp_transfer_8($FF)                                                               '  pre-command dummy clock
  pinl(cs)                                                                         '  CS LOW = selected
  sp_transfer_8($FF)                                                               '  required by some cards
  sp_transfer_8($40 | cmd_num)                                                     '  command byte
  sp_transfer(arg, 32)                                                             '  32-bit argument
  sp_transfer_8(crc_byte)                                                          '  CRC-7

  ' Wait for R1 response — skip bytes with bit 7 set (SD spec 7.3.2.1)
  timeout := getct() + clkfreq                                                    '  1s timeout
  repeat
    resp := sp_transfer_8($FF)
    if (resp & $80) == 0                                                           '  valid R1 has bit 7 = 0
      quit
    if getct() - timeout > 0
      quit

  if resp == $00
    ' Wait for data token ($FE)
    timeout := getct() + clkfreq                                                   '  1s timeout
    repeat
      resp := sp_transfer_8($FF)
      if resp == TOKEN_START_BLOCK                                                 '  $FE = data coming
        quit
      if getct() - timeout > 0
        quit

    if resp == TOKEN_START_BLOCK
      ' Read data bytes into caller's buffer
      repeat idx from 0 to byte_count - 1
        byte[p_buf + idx] := sp_transfer_8($FF)

      ' Read and discard 2-byte CRC
      sp_transfer_8($FF)
      sp_transfer_8($FF)

      result := TRUE

  pinh(cs)                                                                         '  CS HIGH = deselected


PRI readCSD(p_csd) : result
' Read CSD register using CMD9 - reads 16-byte CSD register into buffer.
'
' @param p_csd - Pointer to 16-byte buffer to receive CSD data
' @returns result - TRUE on success, FALSE on failure

  result := readDataRegister(CMD9, 0, CRC_CMD9, p_csd, 16)


PRI readCID(p_cid) : result
' Read CID register using CMD10 - reads 16-byte Card Identification register.
' CID layout: MID[1] OID[2] PNM[5] PRV[1] PSN[4] MDT[2] CRC[1] (big-endian from card).
'
' @param p_cid - Pointer to 16-byte buffer to receive CID data
' @returns result - TRUE on success, FALSE on failure

  result := readDataRegister(CMD10, 0, CRC_CMD10, p_cid, 16)


PRI parseTransSpeed(p_csd) : speed_hz | tran_speed, time_val, mult_val
' Parse TRAN_SPEED from CSD register - returns max transfer speed in Hz.
' TRAN_SPEED format: bits [2:0] = rate unit, bits [6:3] = time value.
'
' @param p_csd - Pointer to CSD register data
' @returns speed_hz - Maximum transfer speed in Hz
' @local tran_speed - Raw TRAN_SPEED byte
' @local time_val - Time value multiplier
' @local mult_val - Transfer rate unit multiplier

  tran_speed := byte[p_csd + 3]

  ' Time value multiplier (bits 6:3) - values per spec
  case (tran_speed >> 3) & $0F
    0:  time_val := 0       ' Reserved
    1:  time_val := 10      ' 1.0
    2:  time_val := 12      ' 1.2
    3:  time_val := 13      ' 1.3
    4:  time_val := 15      ' 1.5
    5:  time_val := 20      ' 2.0
    6:  time_val := 25      ' 2.5
    7:  time_val := 30      ' 3.0
    8:  time_val := 35      ' 3.5
    9:  time_val := 40      ' 4.0
    10: time_val := 45      ' 4.5
    11: time_val := 50      ' 5.0
    12: time_val := 55      ' 5.5
    13: time_val := 60      ' 6.0
    14: time_val := 70      ' 7.0
    15: time_val := 80      ' 8.0

  ' Transfer rate unit (bits 2:0) - values per spec
  case tran_speed & $07
    0:  mult_val := 100_000 / 10        ' 100 kbit/s
    1:  mult_val := 1_000_000 / 10      ' 1 Mbit/s
    2:  mult_val := 10_000_000 / 10     ' 10 Mbit/s
    3:  mult_val := 100_000_000 / 10    ' 100 Mbit/s (not used in SPI mode)
    other: mult_val := 0               ' Reserved

  speed_hz := time_val * mult_val
  debug[CH_IDENT]("  [parseTransSpeed] TRAN_SPEED=$", uhex_byte_(tran_speed), " -> ", udec(speed_hz / 1_000_000), " MHz")


PRI parseMfrId(p_cid) : mfr_id
' Extract manufacturer ID from CID register byte 0.
' Common IDs: $03=SanDisk, $1D=PNY/AData, $27=Samsung, $28=Lexar, $74=Transcend.
'
' @param p_cid - Pointer to CID register data
' @returns mfr_id - Manufacturer ID byte

  mfr_id := byte[p_cid]
  debug[CH_IDENT]("  [parseMfrId] Manufacturer ID=$", uhex_byte_(mfr_id))


PRI parseTimeouts(p_csd) | csd_ver, taac, nsac, r2w_factor, read_timeout_ns, time_val, time_unit
' Extract timeout values from CSD register - sets card_read_timeout_ms and card_write_timeout_ms.
' SDHC/SDXC: Fixed values (100ms read, 250ms write).
' SDSC: Calculated from TAAC, NSAC, and R2W_FACTOR.
'
' @param p_csd - Pointer to CSD register data
' @local csd_ver - CSD structure version
' @local taac - Data read access time-1
' @local nsac - Data read access time-2 in CLK cycles
' @local r2w_factor - Read to write factor
' @local read_timeout_ns - Read timeout in nanoseconds
' @local time_val - Time value multiplier
' @local time_unit - Time unit in nanoseconds

  csd_ver := byte[p_csd] >> 6                                                   ' CSD_STRUCTURE in bits [7:6] of byte 0

  if csd_ver == 1
    ' CSD Version 2.0 (SDHC/SDXC): Use generous timeouts
    ' SD spec says 250ms max for writes, but real cards (especially large SDXC)
    ' can exceed this on cold writes or sector 0. Use 500ms for reliability.
    card_read_timeout_ms := 100                                                 ' 100ms read timeout
    card_write_timeout_ms := 500                                                ' 500ms write timeout (2x spec for margin)
    debug[CH_IDENT]("  [parseTimeouts] SDHC/SDXC: read=", udec_(card_read_timeout_ms), "ms, write=", udec_(card_write_timeout_ms), "ms")
  else
    ' CSD Version 1.0 (SDSC): Calculate from TAAC, NSAC, R2W_FACTOR
    taac := byte[p_csd + 1]                                                     ' Data read access time-1 (TAAC)
    nsac := byte[p_csd + 2]                                                     ' Data read access time-2 (NSAC) in CLK cycles
    r2w_factor := (byte[p_csd + 12] >> 2) & $07                                 ' R2W_FACTOR bits [4:2] of byte 12

    ' Parse TAAC: time value in bits [6:3], time unit in bits [2:0]
    case (taac >> 3) & $0F                                                      ' Time value multiplier
      0:  time_val := 0                                                         ' Reserved
      1:  time_val := 10
      2:  time_val := 12
      3:  time_val := 13
      4:  time_val := 15
      5:  time_val := 20
      6:  time_val := 25
      7:  time_val := 30
      8:  time_val := 35
      9:  time_val := 40
      10: time_val := 45
      11: time_val := 50
      12: time_val := 55
      13: time_val := 60
      14: time_val := 70
      15: time_val := 80

    case taac & $07                                                             ' Time unit (nanoseconds)
      0:  time_unit := 1                                                        ' 1 ns
      1:  time_unit := 10                                                       ' 10 ns
      2:  time_unit := 100                                                      ' 100 ns
      3:  time_unit := 1_000                                                    ' 1 us
      4:  time_unit := 10_000                                                   ' 10 us
      5:  time_unit := 100_000                                                  ' 100 us
      6:  time_unit := 1_000_000                                                ' 1 ms
      7:  time_unit := 10_000_000                                               ' 10 ms

    ' Read timeout = TAAC + NSAC * 100 (NSAC is in clock cycles / 100)
    ' For safety, multiply by 100 to get worst-case timeout
    read_timeout_ns := (time_val * time_unit) * 100                             ' Apply 100x safety factor
    card_read_timeout_ms := (read_timeout_ns / 1_000_000) #> 100                ' Minimum 100ms

    ' Write timeout = read timeout * 2^R2W_FACTOR
    card_write_timeout_ms := (card_read_timeout_ms << r2w_factor) #> 250 <# 1000  ' Min 250ms, max 1000ms

    debug[CH_IDENT]("  [parseTimeouts] SDSC: TAAC=$", uhex_byte_(taac), " NSAC=", udec_(nsac), " R2W=", udec_(r2w_factor))
    debug[CH_IDENT]("  [parseTimeouts] SDSC: read=", udec_(card_read_timeout_ms), "ms, write=", udec_(card_write_timeout_ms), "ms")


PRI identifyCard() | cid[4], csd[4]
' Read card identity and configure adaptive timing.
' Reads CID/CSD, identifies brand, sets optimal SPI speed.
' PNY cards get conservative 20 MHz, others use 25 MHz.
'
' @local cid - CID register data (4 longs = 16 bytes)
' @local csd - CSD register data (4 longs = 16 bytes)

  debug[CH_IDENT]("  [identifyCard] Reading card registers...")

  ' Read CID to identify manufacturer
  if readCID(@cid)
    card_mfr_id := parseMfrId(@cid)
    debug[CH_IDENT]("  [identifyCard] Manufacturer ID: $", uhex_byte_(card_mfr_id))
  else
    debug[CH_IDENT]("  [identifyCard] WARNING: Could not read CID")
    card_mfr_id := 0

  ' Read CSD to get maximum speed and timeouts
  if readCSD(@csd)
    card_max_speed_hz := parseTransSpeed(@csd)
    parseTimeouts(@csd)
  else
    debug[CH_IDENT]("  [identifyCard] WARNING: Could not read CSD")
    card_max_speed_hz := 25_000_000                                             ' Default to 25 MHz
    card_read_timeout_ms := 100                                                 ' Safe defaults
    card_write_timeout_ms := 500


PRI setOptimalSpeed()
' Set SPI speed based on card identification.
' Called after identifyCard() to configure optimal SPI clock.
' Uses card's reported max speed, capped at 25 MHz for SPI mode.

  if card_max_speed_hz > 25_000_000
    applySPISpeed(25_000_000)
  else
    applySPISpeed(card_max_speed_hz)
  debug[CH_IDENT]("  [setOptimalSpeed] Set to card's max speed (up to 25 MHz)")


#ifdef SD_INCLUDE_SPEED

PRI sendCMD6(arg, p_status) : result
' Send CMD6 (SWITCH_FUNC) and receive 64-byte status structure.
' arg format: [31]=mode (0=check, 1=switch), [3:0]=function group 1 selection.
'
' @param arg - CMD6 argument word
' @param p_status - Pointer to 64-byte buffer to receive status
' @returns result - TRUE on success, FALSE on failure/timeout

  result := readDataRegister(CMD6, arg, CRC_NONE, p_status, 64)


PRI queryHighSpeedSupport() : result | scr[2], status[16], sd_spec
' Check if card supports high-speed mode - queries SCR and function group 1.
'
' @returns result - TRUE if high-speed (50 MHz) is supported
' @local scr - SCR register data (2 longs = 8 bytes)
' @local status - CMD6 status structure (16 longs = 64 bytes)
' @local sd_spec - SD spec version from SCR

  debug[CH_HSPEED]("  [queryHighSpeedSupport] Checking card capabilities...")

  ' First check SCR for CMD6 support (SD 2.0+ cards support CMD6)
  if not readSCR(@scr)
    debug[CH_HSPEED]("  [queryHighSpeedSupport] Failed to read SCR")
  else
    sd_spec := scr.byte[0] & $0F                                                '  SD_SPEC in bits [3:0]
    debug[CH_HSPEED]("  [queryHighSpeedSupport] SD_SPEC=", udec_(sd_spec))
    if sd_spec < 2
      debug[CH_HSPEED]("  [queryHighSpeedSupport] Card is SD 1.x - CMD6 not supported")
    else
      debug[CH_HSPEED]("  [queryHighSpeedSupport] Card is SD 2.0+ - CMD6 supported")

      ' Query function group 1 using CMD6 mode 0 (check)
      ' Argument: 0x00FFFFF1 = check mode, access function group 1, query high-speed
      if not sendCMD6($00FFFFF1, @status)
        debug[CH_HSPEED]("  [queryHighSpeedSupport] CMD6 query failed")
      else
        ' Status bytes 12-13 contain function group 1 support bits
        ' Bit 1 of byte 13 indicates high-speed support
        if (status.byte[13] & $02) == 0
          debug[CH_HSPEED]("  [queryHighSpeedSupport] High-speed function not supported")
        else
          debug[CH_HSPEED]("  [queryHighSpeedSupport] High-speed (50 MHz) IS SUPPORTED")
          result := true


PRI switchToHighSpeed() : result | status[16]
' Switch card to high-speed mode - sends CMD6 to switch function group 1.
'
' @returns result - TRUE if switch succeeded
' @local status - CMD6 status structure (16 longs = 64 bytes)

  debug[CH_HSPEED]("  [switchToHighSpeed] Sending CMD6 switch command...")

  ' Switch to high-speed using CMD6 mode 1 (switch)
  ' Argument: 0x80FFFFF1 = switch mode, access function group 1, select high-speed
  if not sendCMD6($80FFFFF1, @status)
    debug[CH_HSPEED]("  [switchToHighSpeed] CMD6 switch failed")
  else
    ' Verify switch succeeded - check function group 1 selection in status
    ' Byte 16, bits 3:0 should be 1 (high-speed selected)
    if (status.byte[16] & $0F) <> 1
      debug[CH_HSPEED]("  [switchToHighSpeed] Switch not accepted, status=$", uhex_byte_(status.byte[16]))
    else
      debug[CH_HSPEED]("  [switchToHighSpeed] Successfully switched to high-speed mode")
      result := true

#endif


PRI sendAppCmdPrefix() : resp
' Send CMD55 (APP_CMD) prefix for application-specific commands (ACMD*).
' Uses cmd() for the command transaction, then deasserts CS for the ACMD to follow.
'
' @returns resp - R1 response from CMD55 ($00 or $01 = success, >$01 = error)

  resp := cmd(CMD55, 0)
  pinh(cs)                                                                         '  deselect between CMD55 and ACMD


PRI readSCR(p_scr) : result | resp
' Read SCR register using ACMD51 - reads 8-byte SD Configuration Register.
' Requires CMD55 prefix before ACMD51.
'
' @param p_scr - Pointer to 8-byte buffer to receive SCR data
' @returns result - TRUE on success, FALSE on failure
' @local resp - CMD55 R1 response

  resp := sendAppCmdPrefix()
  if resp > $01                                                                    '  accept $00 or $01 (idle)
    debug[CH_STATUS]("  [readSCR] CMD55 error response: $", uhex_byte_(resp))
  else
    result := readDataRegister(ACMD51, 0, CRC_ACMD51, p_scr, 8)


PRI readSDStatus(p_buf) : result | resp
' Read SD Status register using ACMD13 - reads 64-byte SD Status.
' Requires CMD55 prefix before ACMD13.
'
' @param p_buf - Pointer to 64-byte buffer to receive SD Status data
' @returns result - TRUE on success, FALSE on failure
' @local resp - CMD55 R1 response

  resp := sendAppCmdPrefix()
  if resp > $01                                                                    '  accept $00 or $01 (idle)
    debug[CH_STATUS]("  [readSDStatus] CMD55 error response: $", uhex_byte_(resp))
  else
    result := readDataRegister(CMD13, 0, CRC_NONE, p_buf, 64)


#ifdef SD_INCLUDE_DEBUG

PRI readSectorSlow(sector, p_buffer) : result | data, idx, timeout
' DEBUG: Read sector byte-by-byte (no streamer) - for streamer debugging.
' This is SLOW (~50x slower than streamer) but helps isolate timing issues.
'
' @param sector - Sector number to read
' @param p_buffer - Pointer to 512-byte destination buffer
' @returns result - 0 on success, negative error code on failure
' @local data - Received byte/token
' @local idx - Loop counter
' @local timeout - Timeout deadline

  ' Send CMD17 (READ_SINGLE_BLOCK)
  cmd(CMD17, sector << hcs)

  ' Wait for start token ($FE)
  result := E_TIMEOUT                                                            '  assume failure
  timeout := getct() + (clkfreq / 100) * card_read_timeout_ms
  repeat
    data := sp_transfer_8($FF)
    if data == $FE
      result := 0                                                                '  got start token
      quit
    if data <> $FF
      result := E_BAD_RESPONSE
      quit                                                                       '  error token
    if getct() - timeout > 0
      quit                                                                       '  timeout

  if result == 0
    ' Read 512 bytes one at a time using sp_transfer_8
    repeat idx from 0 to 511
      byte[p_buffer + idx] := sp_transfer_8($FF)

    ' Read and capture 2 CRC bytes (high byte first per SD protocol)
    diag_recv_crc := sp_transfer_8($FF) << 8
    diag_recv_crc |= sp_transfer_8($FF)

    ' CRC-16 validation: calculate CRC of received data and compare with card's CRC
    if diag_crc_enabled
      diag_calc_crc := calcDataCRC(p_buffer, SECTOR_SIZE)
      if diag_calc_crc == diag_recv_crc
        diag_crc_matches++
      else
        diag_crc_mismatches++
        debug[CH_SECTOR]("  [readSectorSlow] CRC MISMATCH! recv=$", uhex_(diag_recv_crc), " calc=$", uhex_(diag_calc_crc))

  pinh(cs)                                                                       '  Deselect card

#endif


' ---- FAT32 file system ----
'    ┌─────────────────────────┐     The master boot record contains 446 bytes of boot code
'    │ Master Boot Record      │      followed by four 16-byte partition entries
'    │                         │      terminated with $55 $AA in the final 2 bytes
'    │ Partitions      $55 $AA │     The 16-byte partition
'    ├─────────────────────────┤     ┌──────┬───────┬──────┬─────┬───────┬───────────┐
'    │ Reserved                │     │ Boot │ CHS   │ Type │ CHS │ LBA   │ Number of │  Type code located at byte address $1C2
'    ├─────────────────────────┤     │ Flag │ Begin │ Code │ End │ Begin │ Sectors   │   Type code = $0B or $0C for FAT32
'    │ Volume Boot Record 1    │     ├──────┼───────┼──────┼─────┼───────┼───────────┤  LBA Begin contains address of volume boot record (VBR)
'    ├─────────────────────────┤     │      │       │  5   │     │ 9-12  │           │   VBR address located at byte address $1C6
'    │ Reserved                │     └──────┴───────┴──────┴─────┴───────┴───────────┘
'    ├─────────────────────────┤     Volume boot record contains
'    │ Volume Boot Record 2    │     ┌─────────────────────────────────┬────────┬──────┬────────────────────┐
'    ├─────────────────────────┤     │          Field                  │ Offset │ Size │ Value              │
'    │ Reserved                │     ├─────────────────────────────────┼────────┼──────┼────────────────────┤
'    ├─────────────────────────┤     │ Bytes per Sector                │  $0B   │ 16b  │       512          │
'    │ File allocation table 1 │     │ Sectors per Cluster             │  $0D   │  8b  │1/2/4/8/16/32/64/128│
'    ├─────────────────────────┤     │ Number of Reserved Sectors      │  $0E   │ 16b  │                    │
'    │ File allocation table 2 │     │ Number of FATs                  │  $10   │  8b  │        2           │
'    ├─────────────────────────┤     │ Sectors per FAT                 │  $24   │ 32b  │                    │
'    │ Root directory and      │     │ Root Directory of First Cluster │  $2C   │ 32b  │        2           │
'    │  Data region            │     │ Signature                       │ $1FE   │ 16b  │      $AA55         │
'    │                         │     └─────────────────────────────────┴────────┴──────┴────────────────────┘
'    │                         │      The address of the 1st FAT is VBR address + number of reserved sectors
'    │                         │      The address of the root directory is FAT address + number of FATs x sectors per fat
'    └─────────────────────────┘
'                                    The file system directory contains 32-byte entries for each file in the root directory
'                                    ┌─────────────────────────────────┬────────┬──────┐
'                                    │          Field                  │ Offset │ Size │  The first byte of the short filename indicates the type of entry
'                                    ├─────────────────────────────────┼────────┼──────┤   Normal entry     - as expected   "FILENAMETXT"
'                                    │ Short Filename                  │  $00   │ 11B  │   Unused/deleted   - 1st byte $E5  "åILENAMETXT"
'                                    │ Attrib Byte                     │  $0B   │  1B  │   End of directory - 1st byte $00
'                                    │ Date of creation                │  $0E   │  4B  │
'                                    │ First Cluster High              │  $14   │  2B  │
'                                    │ Date of modification            │  $16   │  4B  │
'                                    │ First Cluster Low               │  $1A   │  2B  │
'                                    │ File Size                       │  $1C   │  4B  │
'                                    └─────────────────────────────────┴────────┴──────┘
'                                    Attrib byte contains bitfields
'                                    ┌───┬───────────┬─────┬────────────────────────────────────┐
'                                    │bit│ Function  │ LFN │ Comment                            │
'                                    ├───┼───────────┼─────┼────────────────────────────────────┤
'                                    │ 7 │ Unused    │  0  │ Should be zero                     │
'                                    │ 6 │ Unused    │  0  │ Should be zero                     │
'                                    │ 5 │ Archive   │  x  │ Has been changed since last backup │
'                                    │ 4 │ Directory │  x  │ Is a subdirectory                  │
'                                    │ 3 │ Volume ID │  1  │ Filename is Volume ID              │
'                                    │ 2 │ System    │  1  │ File is operating system           │
'                                    │ 1 │ Hidden    │  1  │ Should not show in dir listing     │
'                                    │ 0 │ Read Only │  1  │ Should not allow writing           │
'                                    └───┴───────────┴─────┴────────────────────────────────────┘
'                                    Each entry in the file allocation table is 32 bits, entry 0 is associated with cluster 0, entry 1/cluster 1, and so on
'                                     The 32-bit value contains 0 if the associated cluster is available
'                                     contains $0FFF_FFFF if the data in the associated cluster ends in that cluster
'                                     contains the address of the next cluster in the file if the file occupies multiple clusters
'                                    ┌───────────┬───────────┬───────────┬───────────┐
'                clusters $00 - $03  │ 0FFF_FFFF │ 0FFF_FFFF │ 0FFF_FFFF │ 0FFF_FFFF │  1st four clusters occupied by self-contained files
'                         $04 - $07  │ 0000_0005 │ 0000_0006 │ 0000_0007 │ 0FFF_FFFF │  next four clusters occupied by a file in sequential clusters
'                         $08 - $0B  │ 0000_000A │ 0FFF_FFFF │ 0000_000C │ 0FFF_FFFF │  a fragmented file starts in cluster 8, and occupies clusters 10, 12, and ends in 14
'                         $0C - $0F  │ 0000_000E │ 0000_0000 │ 0FFF_FFFF │ 0000_0000 │  clusters 13 and 15 are unused
'                                    └───────────┴───────────┴───────────┴───────────┘
' ---- end FAT32 file system ----


