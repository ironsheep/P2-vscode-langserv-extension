{Spin2_v50}
''
'' v50 Regression Test: DITTO Directive
''
'' Tests the new DITTO count / DITTO END directive with $$ index.
''

CON

    _CLKFREQ = 160_000_000

VAR

    long  results[30]

PUB main() | i, p

    ' ========================================
    ' Test DITTO-generated lookup tables
    ' ========================================

    ' Test 1: Basic DITTO 4 with $$ index
    p := @table1
    results[0] := long[p][0]            ' expect 0
    results[1] := long[p][1]            ' expect 1
    results[2] := long[p][2]            ' expect 2
    results[3] := long[p][3]            ' expect 3

    ' Test 2: DITTO with multiplication
    p := @table2
    results[4] := long[p][0]            ' expect 0
    results[5] := long[p][1]            ' expect 100
    results[6] := long[p][2]            ' expect 200
    results[7] := long[p][3]            ' expect 300

    ' Test 3: DITTO 8 entries
    p := @table3
    results[8] := long[p][0]            ' expect 0
    results[9] := long[p][7]            ' expect 7

    ' Test 4: DITTO with expression
    p := @table4
    results[10] := long[p][0]           ' expect 10 (10 + 0)
    results[11] := long[p][1]           ' expect 11 (10 + 1)
    results[12] := long[p][2]           ' expect 12 (10 + 2)

    ' Test 5: DITTO with shift
    p := @table5
    results[13] := long[p][0]           ' expect 1 (1 << 0)
    results[14] := long[p][1]           ' expect 2 (1 << 1)
    results[15] := long[p][2]           ' expect 4 (1 << 2)
    results[16] := long[p][3]           ' expect 8 (1 << 3)

    ' Test 6: DITTO 0 generates nothing
    p := @table6_before
    results[17] := long[p][0]           ' expect $AAAA (before marker)
    results[18] := long[p][1]           ' expect $BBBB (after marker, no gap)

    ' Test 7: DITTO 1 generates one entry
    p := @table7
    results[19] := long[p][0]           ' expect 42

    ' Test 8: Multiple DITTO blocks in sequence
    p := @table8
    results[20] := long[p][0]           ' expect 0 (first block)
    results[21] := long[p][1]           ' expect 1
    results[22] := long[p][2]           ' expect 100 (second block)
    results[23] := long[p][3]           ' expect 101

    repeat


DAT
        org     0

' Basic DITTO with $$ index
table1
        DITTO   4
        long    $$
        DITTO   END

' DITTO with multiplication
table2
        DITTO   4
        long    $$ * 100
        DITTO   END

' DITTO 8 entries
table3
        DITTO   8
        long    $$
        DITTO   END

' DITTO with addition
table4
        DITTO   3
        long    10 + $$
        DITTO   END

' DITTO with shift (power of 2 table)
table5
        DITTO   4
        long    1 << $$
        DITTO   END

' DITTO 0 test - should generate no code
table6_before
        long    $AAAA
        DITTO   0
        long    $DEADBEEF       ' this should be skipped
        DITTO   END
        long    $BBBB           ' immediately after $AAAA

' DITTO 1 - single entry
table7
        DITTO   1
        long    42 + $$         ' 42 + 0 = 42
        DITTO   END

' Sequential DITTO blocks
table8
        DITTO   2
        long    $$              ' 0, 1
        DITTO   END
        DITTO   2
        long    100 + $$        ' 100, 101
        DITTO   END
