{spin2_v52}

CON
  _xtlfreq		= 25_000_000
  _clkfreq		= 200_000_000

  SRV_COUNT		= 3

  STRUCT SERVO_CFGx(	PLimitBrakeJerk,	...	'Jerk for braking after PLimit hit
			PLimitBrakeAccelLimit,	...	'Acceleration limit for braking after PLimit hit
			NLimitBrakeJerk,	...	'Jerk for braking after NLimit hit
			NLimitBrakeAccelLimit,	...	'Acceleration limit for braking after NLimit hit
			PLimitDIO,		...	'DIO pin for PLimit sensing
			NLimitDIO,		...	'DIO pin for NLimit sensing
			HomeDIO)			'DIO pin for Home sensing

  STRUCT DATA_CFGx(	SERVO_CFGx Servo[12])		'12 servo instances
