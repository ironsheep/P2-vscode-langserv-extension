{spin2_v52}

CON

  _xtlfreq		= 25_000_000
  _clkfreq		= 200_000_000

  XIO_RATE		= 1

  NS300			= round(float(clkfreq_) * 300e-9)	'clocks in 300ns
  XIO_CLOCKS		= NS300 * 4 * (XIO_RATE + 1)		'clocks in XIO update

  LED_COUNT		= 15
  NCV_COUNT		= 1
  AIO_COUNT		= 4

  STRUCT DIO_DATA(	led_rgb	   [LED_COUNT],	...	'LED RGB data	- driver reads these RGB values and outputs them to LEDs
			xio_out	   [2],		...	'XIO data out	- driver reads this data for XIO chain output
			xio_in	   [2],		...	'XIO data in	- driver writes this data from XIO chain input
			ncv_out	   [NCV_COUNT],	...	'NCV data out	- driver reads this data for NCV chain output
			ncv_in     [NCV_COUNT])		'NCV data in	- driver writes this data from NCV chain input

  STRUCT AIO_DATA(	dac_target [AIO_COUNT],	...	'DAC targets	- driver reads these mV values to control the analog outputs
			adc_sample [AIO_COUNT],	...	'ADC samples	- driver writes these mV values read from the analog inputs
			dac_sample [AIO_COUNT],	...	'DAC samples	- driver writes these mV values read from the analog outputs	(diagnostic)
			dac_gain   [AIO_COUNT],	...	'DAC gains	- driver writes these 16.16-bit gain correction values		(diagnostic)
			dac_input  [AIO_COUNT])		'DAC inputs	- driver writes these gain-corrected 16-bit DAC values		(diagnostic)

  P2_RX			= 63				'P2 pins
  P2_TX			= 62

  P2_FLASH_CSn		= 61
  P2_FLASH_CLK		= 60
  P2_FLASH_MOSI		= 59
  P2_FLASH_MISO		= 58

  P2_AUX_TX		= 57
  P2_AUX_RX		= 56

  P2_W6100_CSn1		= 55
  P2_W6100_CLK1		= 54
  P2_W6100_MOSI1	= 53
  P2_W6100_MISO1	= 52

  P2_W6100_CSn0		= 51
  P2_W6100_CLK0		= 50
  P2_W6100_MOSI0	= 49
  P2_W6100_MISO0	= 48

  P2_NCV7724B_CSn	= 47
  P2_NCV7724B_CLK	= 46
  P2_NCV7724B_MOSI	= 45
  P2_NCV7724B_MISO	= 44

  P2_XIO_LAT		= 43
  P2_XIO_CLK		= 42
  P2_XIO_MOSI		= 41
  P2_XIO_MISO		= 40

  P2_IOLINK_TX3		= 39
  P2_IOLINK_RX3		= 38
  P2_IOLINK_TX2		= 37
  P2_IOLINK_RX2		= 36
  P2_IOLINK_TX1		= 35
  P2_IOLINK_RX1		= 34
  P2_IOLINK_TX0		= 33
  P2_IOLINK_RX0		= 32

  P2_ADC7		= 31
  P2_ADC6		= 30
  P2_ADC5		= 29
  P2_ADC4		= 28
  P2_ADC3		= 27
  P2_ADC2		= 26
  P2_ADC1		= 25
  P2_ADC0		= 24

  P2_ADCx		= P2_ADC0 addpins AIO_COUNT - 1

  P2_DAC7		= 23
  P2_DAC6		= 22
  P2_DAC5		= 21
  P2_DAC4		= 20
  P2_DAC3		= 19
  P2_DAC2		= 18
  P2_DAC1		= 17
  P2_DAC0		= 16

  P2_DACx		= P2_DAC0 addpins AIO_COUNT - 1

  P2_SERVO_PUL7		= 15
  P2_SERVO_DIR7		= 14
  P2_SERVO_PUL6		= 13
  P2_SERVO_DIR6		= 12
  P2_SERVO_PUL5		= 11
  P2_SERVO_DIR5		= 10
  P2_SERVO_PUL4		= 9
  P2_SERVO_DIR4		= 8
  P2_SERVO_PUL3		= 7
  P2_SERVO_DIR3		= 6
  P2_SERVO_PUL2		= 5
  P2_SERVO_DIR2		= 4
  P2_SERVO_PUL1		= 3
  P2_SERVO_DIR1		= 2
  P2_SERVO_PUL0		= 1
  P2_SERVO_DIR0		= 0

  'XIO output bits, in order of shifting first-to-last
  #0
  DSS0,DSS1,DSS2,DSS3,DSS4,DSS5,DSS6,DSS7
  SERVO_ENA0
  SERVO_ENA1
  SERVO_ENA2
  SHUNT_ENA0
  SHUNT_ENA1
  IOLINK_HS_ENA0
  ADC_MUX0
  ADC_MUX1

  'XIO input bits, in order of shifting first-to-last
  #0
  DIN0,DIN1,DIN2,DIN3,DIN4,DIN5,DIN6,DIN7
  SERVO_FB0
  SERVO_FB1
  SERVO_FB2
  {0,0,0,0,0}


VAR

  DIO_DATA dio			'DIO data structure
  AIO_DATA aio			'AIO data structure


PUB Start() : pDIO, pAIO

  return @dio, @aio