' regr-mixed-tab-space-indent.spin2
' Regression D.11: Mixed tab/space indent within a method must not change nesting.
' Tab-indented lines (8 cols) and space-indented lines (4 spaces) both at level 1.

CON
  _clkfreq = 10_000_000

VAR
  long  result

PUB main() | x, y
	if x > 0
		y := 1

    x := y + 1
    result := x
